# Copy to .env for Docker Compose deployments.

RAILS_ENV=production
RAILS_LOG_LEVEL=info
SECRET_KEY_BASE=3c7f9a6b1e2d4f8c9a0b5e7d3f1c6a8b2d9e4c7f0a1b3d5e6f8c2a9d7b4e1c6f9a2b5d7e3c8f1a4b6d9e0c2f7a5b8d3e6c1f4a9b7d2e5c8f0a3b6d9e1c4f7a2
ACTIVE_STORAGE_SERVICE=local
# Generate a real value with: bundle exec rails secret

# Optional bootstrap admin created by `rails db:seed` when both values are present.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_TIME_ZONE=UTC
SEED_ADMIN_LOCALE=en

# Compose defaults use service names (postgres, redis) for networking.
DOCKER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/inkcreate_production
DOCKER_REDIS_URL=redis://redis:6379/0

POSTGRES_DB=inkcreate_production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

GCP_PROJECT_ID=your-gcp-project
GCP_REGION=asia-south1
GCS_UPLOAD_BUCKET=inkcreate-uploads

# For Compose deployment we run Sidekiq worker.
JOB_BACKEND=sidekiq

OCR_PROVIDER=tesseract
OCR_LANGUAGE=eng

# Add both /api/v1/drive_connection/callback and /auth/google/callback to your
# Google OAuth authorized redirect URIs for the same client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://your-domain.example/api/v1/drive_connection/callback

DEVISE_MAILER_SENDER=noreply@your-domain.example
FORCE_SSL=true
RAILS_SERVE_STATIC_FILES=true

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
