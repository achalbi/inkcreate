<!DOCTYPE html>
<html lang="en" data-time-zone="<%= effective_time_zone_name %>">
  <head>
    <title><%= content_for?(:page_title) ? yield(:page_title) : "Inkcreate" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta
      name="description"
      content="<%= content_for?(:page_description) ? yield(:page_description) : "Inkcreate turns notebook photos into structured, searchable pages with background OCR and Google Drive export." %>"
    >
    <meta name="theme-color" content="#17392d">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Open Graph / WhatsApp link-preview tags — pages override via content_for %>
    <meta property="og:type"        content="website">
    <meta property="og:site_name"   content="Inkcreate">
    <meta property="og:title"       content="<%= content_for?(:og_title)       ? yield(:og_title).strip       : 'Inkcreate' %>">
    <meta property="og:description" content="<%= content_for?(:og_description) ? yield(:og_description).strip : 'Capture, organise, and export your handwritten notes with background OCR and Google Drive sync.' %>">
    <meta property="og:image"       content="<%= content_for?(:og_image)       ? yield(:og_image).strip       : "#{request.base_url}/icons/og-install.png" %>">
    <meta property="og:url"         content="<%= content_for?(:og_url)         ? yield(:og_url).strip         : request.url %>">
    <meta name="twitter:card"       content="summary_large_image">
    <script src="<%= versioned_public_asset_path("/scripts/device_time_zone.js") %>" defer></script>
    <% if Rails.env.test? %>
      <script src="<%= versioned_public_asset_path("/scripts/test_browser_mocks.js") %>"></script>
    <% end %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="<%= versioned_public_asset_path("/inapp/page_loader.css") %>">
    <link rel="manifest" href="<%= versioned_public_asset_path("/manifest.json") %>">
    <link rel="icon" href="<%= versioned_public_asset_path("/icons/app-icon.svg") %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= versioned_public_asset_path("/icons/app-icon.svg") %>">
    <style>
      :root {
        --canvas: #f4eee2;
        --canvas-strong: #efe2c9;
        --paper: rgba(255, 251, 243, 0.9);
        --paper-strong: #fffaf1;
        --ink: #14261f;
        --ink-soft: #395146;
        --accent: #d07a2a;
        --accent-deep: #a95814;
        --forest: #17392d;
        --forest-soft: #3d785d;
        --line: rgba(20, 38, 31, 0.1);
        --shadow: 0 24px 60px rgba(24, 41, 32, 0.15);
        --shadow-soft: 0 14px 30px rgba(24, 41, 32, 0.08);
        --heading-font: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        --body-font: "Trebuchet MS", "Gill Sans", "Segoe UI", sans-serif;
        --mono-font: "Courier Prime", "Liberation Mono", "Courier New", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(208, 122, 42, 0.28), transparent 28%),
          radial-gradient(circle at top right, rgba(61, 120, 93, 0.2), transparent 26%),
          linear-gradient(180deg, var(--canvas) 0%, #f7f2e7 52%, #efe0c6 100%);
        color: var(--ink);
        font-family: var(--body-font);
      }

      img,
      svg {
        display: block;
        max-width: 100%;
        height: auto;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(20, 38, 31, 1) 1px, transparent 1px),
          linear-gradient(90deg, rgba(20, 38, 31, 1) 1px, transparent 1px);
        background-size: 100% 28px, 28px 100%;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.35), transparent 85%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page-shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 32px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 28px;
      }

      .topbar-right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        flex: 1 1 420px;
        flex-wrap: wrap;
        gap: 18px;
        min-width: 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        max-width: 100%;
        min-width: 0;
      }

      .brand-mark {
        flex: 0 0 52px;
        width: 52px;
        height: 52px;
        border-radius: 16px;
        box-shadow: var(--shadow-soft);
      }

      .brand-copy {
        min-width: 0;
      }

      .brand-copy strong {
        display: block;
        font-family: var(--heading-font);
        font-size: 1.2rem;
        letter-spacing: 0.02em;
        overflow-wrap: anywhere;
      }

      .brand-copy span,
      .topbar nav a,
      .eyebrow,
      .mini-label,
      .pill,
      .api-code,
      .footer-note {
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .brand-copy span,
      .topbar nav a,
      .eyebrow,
      .mini-label,
      .footer-note {
        color: var(--ink-soft);
        font-size: 0.72rem;
      }

      .topbar nav {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 14px;
        min-width: 0;
      }

      .topbar nav a {
        padding: 10px 0;
      }

      .topbar nav a.is-active {
        color: var(--forest);
        font-weight: 700;
      }

      .nav-actions {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 10px;
        max-width: 100%;
        min-width: 0;
      }

      .nav-actions-auth {
        flex-wrap: nowrap;
      }

      .mini-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(20, 38, 31, 0.1);
        background: rgba(255, 250, 241, 0.7);
        color: var(--forest);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: normal;
        text-align: center;
        line-height: 1.25;
      }

      .mini-button-primary {
        background: linear-gradient(135deg, var(--forest) 0%, var(--forest-soft) 100%);
        border-color: transparent;
        color: #fffaf1;
      }

      .nav-actions-auth .mini-button {
        border-color: rgba(20, 38, 31, 0.22);
        background: rgba(255, 250, 241, 0.97);
      }

      .nav-actions-auth .mini-button-primary {
        background: linear-gradient(135deg, rgba(23, 57, 45, 1) 0%, rgba(61, 120, 93, 1) 100%);
      }

      .hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
        gap: 28px;
        align-items: stretch;
        min-width: 0;
        padding-top: 32px;
      }

      .hero-copy,
      .hero-stack,
      .section-card,
      .feature-card,
      .flow-step,
      .api-card,
      .auth-panel,
      .dashboard-card,
      .table-card,
      .stat,
      .stack-note {
        background: linear-gradient(180deg, rgba(255, 250, 241, 0.92), rgba(255, 255, 255, 0.72));
        border: 1px solid rgba(20, 38, 31, 0.08);
        border-radius: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        width: 100%;
        max-width: 100%;
        min-width: 0;
      }

      .hero-copy {
        padding: 42px;
        min-width: 0;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        color: var(--forest);
        font-weight: 700;
      }

      .eyebrow::before {
        content: "";
        display: inline-block;
        width: 42px;
        height: 1px;
        background: linear-gradient(90deg, var(--accent), transparent);
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: var(--heading-font);
        font-weight: 700;
        line-height: 0.96;
      }

      h1 {
        font-size: clamp(2.8rem, 6.7vw, 5rem);
        max-width: 9ch;
        overflow-wrap: anywhere;
      }

      .hero-copy p {
        margin: 22px 0 0;
        max-width: 52ch;
        color: var(--ink-soft);
        font-size: 1.08rem;
        line-height: 1.7;
      }

      .cta-row,
      .stat-row,
      .feature-grid,
      .api-grid {
        display: grid;
        gap: 14px;
      }

      .cta-row {
        margin-top: 28px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        min-height: 52px;
        padding: 0 20px;
        border-radius: 999px;
        font-weight: 700;
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
        width: 100%;
        max-width: 100%;
        white-space: normal;
        text-align: center;
        line-height: 1.3;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        background: linear-gradient(135deg, var(--forest) 0%, var(--forest-soft) 100%);
        color: #fffaf1;
        box-shadow: 0 18px 30px rgba(23, 57, 45, 0.22);
      }

      .button-secondary {
        background: rgba(255, 250, 241, 0.75);
        border: 1px solid rgba(20, 38, 31, 0.1);
        color: var(--forest);
      }

      .button-google {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(20, 38, 31, 0.12);
        color: var(--ink);
        box-shadow: 0 14px 28px rgba(20, 38, 31, 0.08);
      }

      .google-mark {
        display: inline-grid;
        place-items: center;
        width: 28px;
        height: 28px;
        border-radius: 999px;
        background: #ffffff;
        color: #db4437;
        font-size: 1rem;
        font-weight: 800;
        box-shadow: inset 0 0 0 1px rgba(20, 38, 31, 0.1);
      }

      .stat-row {
        margin-top: 34px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .stat {
        padding: 18px 18px 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.56);
        border: 1px solid rgba(20, 38, 31, 0.07);
      }

      .stat strong {
        display: block;
        margin-top: 6px;
        font-size: 1.15rem;
      }

      .hero-stack {
        position: relative;
        padding: 26px;
        overflow: hidden;
      }

      .hero-stack::after {
        content: "";
        position: absolute;
        inset: 18px;
        border-radius: 24px;
        border: 1px dashed rgba(20, 38, 31, 0.12);
        pointer-events: none;
      }

      .paper-column {
        position: relative;
        display: grid;
        gap: 14px;
        z-index: 1;
      }

      .paper {
        position: relative;
        padding: 20px 20px 18px;
        border-radius: 24px;
        background: var(--paper-strong);
        border: 1px solid rgba(20, 38, 31, 0.08);
        box-shadow: var(--shadow-soft);
        transform-origin: center;
        animation: float-card 8s ease-in-out infinite;
      }

      .paper:nth-child(2) {
        margin-left: 34px;
        animation-delay: 0.8s;
      }

      .paper:nth-child(3) {
        margin-left: 12px;
        animation-delay: 1.6s;
      }

      .paper:nth-child(4) {
        margin-left: 48px;
        animation-delay: 2.4s;
      }

      .paper h3 {
        font-size: 1.45rem;
        margin-bottom: 10px;
      }

      .paper p {
        margin: 0;
        color: var(--ink-soft);
        line-height: 1.55;
      }

      .paper::before {
        content: "";
        position: absolute;
        left: 20px;
        right: 20px;
        top: 54px;
        height: 1px;
        background: linear-gradient(90deg, rgba(20, 38, 31, 0.1), transparent);
      }

      .paper-accent {
        position: absolute;
        right: 18px;
        top: 16px;
        width: 14px;
        height: 14px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 8px rgba(208, 122, 42, 0.12);
      }

      main {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 28px;
        margin-top: 28px;
        width: 100%;
        max-width: 100%;
        min-width: 0;
      }

      main > * {
        max-width: 100%;
        min-width: 0;
      }

      .section-card {
        padding: 34px;
        min-width: 0;
      }

      .section-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 12px;
        margin-bottom: 24px;
      }

      h2 {
        font-size: clamp(2.2rem, 5vw, 3.3rem);
        max-width: 11ch;
        overflow-wrap: anywhere;
      }

      .section-header p {
        margin: 0;
        max-width: 60ch;
        color: var(--ink-soft);
        line-height: 1.7;
      }

      .install-prompt-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 24px;
      }

      .install-prompt-header-main {
        flex: 1 1 auto;
        min-width: 0;
        margin-bottom: 0;
      }

      .install-prompt-summary {
        margin: 0 0 24px;
        max-width: 60ch;
        color: var(--ink-soft);
        line-height: 1.7;
      }

      .install-prompt-note {
        margin: 18px 0 0;
        max-width: 60ch;
        color: var(--ink-soft);
        line-height: 1.65;
      }

      .install-step-list {
        margin: 14px 0 0;
        padding-left: 1.25rem;
        color: rgba(20, 38, 31, 0.82);
      }

      .install-step-list li + li {
        margin-top: 8px;
      }

      .install-prompt-header .ibox-toggle-button {
        width: 1.75rem;
        height: 1.75rem;
        border: 1px solid rgba(23, 57, 45, 0.12);
        border-radius: 999px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 250, 241, 0.78);
        color: var(--forest);
        box-shadow: var(--shadow-soft);
        transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
      }

      .install-prompt-header .ibox-toggle-button:hover {
        background: rgba(23, 57, 45, 0.1);
        color: var(--ink);
      }

      .install-prompt-header .ibox-toggle-button:focus-visible {
        outline: 2px solid rgba(23, 57, 45, 0.2);
        outline-offset: 2px;
      }

      .install-prompt-header .ibox-toggle-icon {
        display: block;
        transition: transform 0.2s ease;
      }

      .install-prompt-header .ibox-toggle-button[aria-expanded="false"] .ibox-toggle-icon {
        transform: rotate(180deg);
      }

      .feature-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .feature-card {
        padding: 24px;
      }

      .feature-card h3 {
        font-size: 1.55rem;
        margin: 12px 0 10px;
      }

      .feature-card p {
        margin: 0;
        color: var(--ink-soft);
        line-height: 1.65;
      }

      .pill {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 8px;
        padding: 7px 11px;
        border-radius: 999px;
        background: rgba(23, 57, 45, 0.08);
        color: var(--forest);
        font-size: 0.72rem;
        font-weight: 700;
      }

      .flow {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
      }

      .flow-step {
        position: relative;
        padding: 22px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.52);
        border: 1px solid rgba(20, 38, 31, 0.08);
      }

      .flow-step strong {
        display: block;
        margin: 14px 0 10px;
        font-size: 1.05rem;
        overflow-wrap: anywhere;
      }

      .flow-step p {
        margin: 0;
        color: var(--ink-soft);
        line-height: 1.55;
      }

      .flow-step::after {
        content: "";
        position: absolute;
        top: 38px;
        right: -8px;
        width: 16px;
        height: 16px;
        border-top: 2px solid rgba(20, 38, 31, 0.22);
        border-right: 2px solid rgba(20, 38, 31, 0.22);
        transform: rotate(45deg);
      }

      .flow-step:last-child::after {
        display: none;
      }

      .api-grid {
        grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
      }

      .api-card {
        padding: 24px;
        min-width: 0;
      }

      .api-card p {
        margin: 0 0 18px;
        color: var(--ink-soft);
        line-height: 1.65;
      }

      .api-list {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 10px;
      }

      .api-code {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        padding: 12px 14px;
        border-radius: 16px;
        background: rgba(20, 38, 31, 0.05);
        font-family: var(--mono-font);
        font-size: 0.82rem;
        text-transform: none;
        letter-spacing: 0.03em;
      }

      .api-code span:first-child {
        color: var(--accent-deep);
        font-weight: 700;
        flex: 0 0 auto;
      }

      .api-code span:last-child {
        flex: 1 1 240px;
        min-width: 0;
        overflow-wrap: anywhere;
        word-break: break-word;
        text-align: right;
      }

      .stack-note {
        position: relative;
        padding: 18px 18px 18px 22px;
        border-left: 4px solid var(--accent);
        background: rgba(255, 255, 255, 0.55);
        border-radius: 0 18px 18px 0;
      }

      .stack-note + .stack-note {
        margin-top: 12px;
      }

      .stack-note strong {
        display: block;
        margin-bottom: 6px;
      }

      .stack-note p,
      footer p {
        margin: 0;
        color: var(--ink-soft);
        line-height: 1.6;
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 18px;
        margin-top: 28px;
        padding: 20px 4px 0;
      }

      .footer-note {
        font-weight: 700;
      }

      .footer-body {
        display: grid;
        gap: 8px;
        max-width: 52ch;
      }

      .footer-links {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
      }

      .footer-links a {
        color: var(--forest);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-credit {
        width: 100%;
        padding-top: 4px;
        text-align: center;
        color: var(--ink-soft);
        font-size: 0.9rem;
      }

      .footer-credit a {
        color: var(--forest);
        font-weight: 700;
      }

      .footer-heart {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #d94b5c;
        vertical-align: middle;
        transform: translateY(-1px);
      }

      .footer-heart-icon {
        width: 1rem;
        height: 1rem;
        fill: currentColor;
      }

      /* Auth google-only notice */
      .auth-google-only-notice {
        margin-top: 18px;
        padding: 14px 18px;
        border-radius: 16px;
        background: rgba(23, 57, 45, 0.06);
        border: 1px solid rgba(23, 57, 45, 0.1);
        color: var(--ink-soft);
        font-size: 0.92rem;
        line-height: 1.55;
        text-align: center;
      }

      /* CTA section at bottom of landing */
      .cta-section {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        align-items: center;
        gap: 28px;
        padding: 42px;
        background: linear-gradient(135deg, var(--forest) 0%, var(--forest-soft) 100%);
        border-radius: 28px;
        box-shadow: var(--shadow);
        color: #fffaf1;
      }

      .cta-section .eyebrow {
        color: rgba(255, 250, 241, 0.7);
      }

      .cta-section h2 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        max-width: none;
        color: #fffaf1;
      }

      .cta-section p {
        margin: 14px 0 0;
        color: rgba(255, 250, 241, 0.78);
        line-height: 1.65;
      }

      .cta-section-actions {
        display: grid;
        gap: 12px;
      }

      .cta-install-action {
        display: grid;
        gap: 8px;
      }

      .cta-install-note {
        margin: 0;
        color: rgba(255, 250, 241, 0.78);
        font-size: 0.92rem;
        line-height: 1.55;
      }

      .cta-section .button-primary {
        background: rgba(255, 250, 241, 0.95);
        color: var(--forest);
        box-shadow: 0 12px 28px rgba(0,0,0,0.18);
      }

      .cta-section .button-secondary {
        background: rgba(255, 250, 241, 0.12);
        border-color: rgba(255, 250, 241, 0.28);
        color: rgba(255, 250, 241, 0.9);
      }

      .public-cta-section {
        margin-top: 28px;
      }

      .landing-top-cta {
        padding-top: 16px;
      }

      .legal-shell {
        display: grid;
        grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
        gap: 28px;
        align-items: start;
        margin-top: 28px;
      }

      .legal-sidebar {
        position: sticky;
        top: 18px;
        display: grid;
        gap: 20px;
      }

      .legal-page-title {
        font-size: clamp(2.4rem, 6vw, 4.4rem);
        max-width: none;
        overflow-wrap: anywhere;
      }

      .legal-lead {
        margin: 18px 0 0;
        color: var(--ink-soft);
        line-height: 1.7;
      }

      .legal-meta {
        display: grid;
        gap: 14px;
        margin: 24px 0 0;
      }

