      .workspace-link span {
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .workspace-link strong {
        font-size: 0.98rem;
      }

      .workspace-nav-footer {
        display: grid;
        gap: 10px;
        padding-top: 18px;
        border-top: 1px solid rgba(20, 38, 31, 0.08);
      }

      .workspace-nav-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .workspace-main,
      .workspace-panel,
      .workspace-grid,
      .capture-list,
      .context-form-grid {
        min-width: 0;
      }

      .workspace-main {
        display: grid;
        gap: 22px;
      }

      .workspace-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 18px;
        padding: 28px 24px;
      }

      .workspace-header-main {
        flex: 1 1 480px;
        min-width: 0;
      }

      .workspace-header h1 {
        margin: 8px 0 10px;
        font-size: clamp(2rem, 4vw, 3rem);
      }

      .workspace-header p {
        max-width: 720px;
        margin: 0;
        color: var(--ink-soft);
      }

      .workspace-header-flashes {
        flex: 1 0 100%;
      }

      .workspace-grid {
        display: grid;
        gap: 22px;
      }

      .workspace-grid-halves {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .workspace-panel {
        padding: 24px;
      }

      .capture-list {
        display: grid;
        gap: 16px;
      }

      .capture-card {
        display: grid;
        gap: 10px;
        padding: 18px;
        border-radius: 22px;
        border: 1px solid rgba(20, 38, 31, 0.08);
        background: rgba(255, 255, 255, 0.62);
        min-width: 0;
      }

      .capture-card h3 {
        margin: 4px 0 0;
        font-size: 1.05rem;
      }

      .capture-card p {
        margin: 0;
        color: var(--ink-soft);
      }

      .capture-card-top {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 16px;
      }

      .capture-meta,
      .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .capture-meta {
        color: var(--ink-soft);
        font-size: 0.8rem;
      }

      .empty-state {
        min-height: 140px;
        align-content: center;
      }

      .context-form-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .compact-form {
        padding: 16px;
        border-radius: 20px;
        border: 1px solid rgba(20, 38, 31, 0.08);
        background: rgba(255, 255, 255, 0.58);
      }

      .capture-form {
        display: grid;
        gap: 16px;
      }

      .capture-camera-frame {
        min-height: 280px;
        display: grid;
        place-items: center;
        padding: 18px;
        border-radius: 24px;
        border: 1px dashed rgba(20, 38, 31, 0.16);
        background: rgba(20, 38, 31, 0.03);
        overflow: hidden;
      }

      .capture-camera-frame video,
      .capture-camera-frame img {
        width: 100%;
        border-radius: 18px;
      }

      @keyframes float-card {
        0%, 100% {
          transform: translateY(0) rotate(-0.6deg);
        }

        50% {
          transform: translateY(-8px) rotate(0.6deg);
        }
      }

      @media (max-width: 1080px) {
        .hero,
        .admin-app,
        .admin-hero,
        .auth-shell,
        .dashboard-shell,
        .legal-shell,
        .workspace-shell,
        .workspace-grid-halves,
        .context-form-grid,
        .admin-secondary-grid,
        .api-grid,
        .feature-grid,
        .flow {
          grid-template-columns: minmax(0, 1fr);
        }

        .admin-sidebar {
          position: static;
        }

        .legal-sidebar {
          position: static;
        }

        .admin-topbar {
          flex-direction: column;
        }

        .admin-topbar-actions {
          width: 100%;
          flex: none;
        }

        .workspace-nav {
          position: static;
        }

        .workspace-header,
        .capture-card-top {
          flex-direction: column;
          align-items: flex-start;
        }

        .admin-kpi-grid,
        .admin-metric-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .flow-step::after {
          display: none;
        }
      }

      @media (max-width: 900px) {
        .topbar-right {
          justify-content: flex-start;
        }

        .stat-row,
        .dashboard-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .auth-form-row {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .page-shell {
          width: min(1180px, calc(100% - 20px));
          padding-top: 18px;
          padding-bottom: 24px;
        }

        main {
          gap: 20px;
          margin-top: 20px;
        }

        .topbar {
          align-items: flex-start;
          justify-content: flex-start;
          flex-wrap: wrap;
          gap: 12px;
          margin-bottom: 0;
        }

        .topbar-right {
          display: flex;
          flex-direction: column;
          align-items: stretch;
          width: 100%;
          gap: 16px;
          margin-top: 14px;
          padding: 20px;
          background: rgba(255, 250, 241, 0.97);
          border: 1px solid rgba(20, 38, 31, 0.1);
          border-radius: 20px;
          box-shadow: var(--shadow-soft);
          order: 3;
        }

        footer,
        .install-prompt-header {
          flex-direction: column;
          align-items: flex-start;
        }

        .topbar nav,
        .nav-actions {
          width: 100%;
        }

        .nav-actions {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .nav-actions-auth {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .nav-actions .mini-button {
          width: 100%;
        }

        .cta-section {
          grid-template-columns: minmax(0, 1fr);
          padding: 28px 24px;
        }

        .hero-copy,
        .hero-stack,
        .section-card,
        .feature-card,
        .api-card,
        .legal-article,
        .legal-summary,
        .legal-nav {
          padding: 24px;
          border-radius: 24px;
        }

        .cta-row,
        .admin-topbar-buttons,
        .admin-link-grid,
        .workspace-nav-links,
        .stat-row,
        .admin-actions,
        .admin-kpi-grid,
        .admin-metric-grid,
        .dashboard-grid,
        .auth-form-row {
          grid-template-columns: minmax(0, 1fr);
        }

        .auth-mode-strip {
          gap: 8px;
        }

        .api-code span:last-child {
          text-align: left;
        }

        .paper:nth-child(2),
        .paper:nth-child(3),
        .paper:nth-child(4) {
          margin-left: 0;
        }

        h1 {
          font-size: clamp(2.5rem, 14.5vw, 3.8rem);
        }

        .admin-activity {
          flex-direction: column;
        }

        .admin-activity-meta {
          justify-items: start;
        }

        .admin-status-row {
          flex-direction: column;
          align-items: flex-start;
        }

        .admin-sidebar {
          padding: 20px 18px;
          border-radius: 24px;
        }

        .workspace-nav,
        .workspace-header,
        .workspace-panel {
          padding: 20px 18px;
          border-radius: 24px;
        }

        .admin-topbar {
          padding: 24px 20px;
          border-radius: 24px;
        }
      }

      @media (max-width: 480px) {
        .page-shell {
          padding-bottom: 20px;
        }

        .hero-copy,
        .hero-stack,
        .section-card,
        .feature-card,
        .api-card,
        .legal-article,
        .legal-summary,
        .legal-nav,
        .auth-panel,
        .dashboard-card,
        .table-card {
          padding: 20px;
          border-radius: 20px;
        }

        .admin-nav {
          grid-template-columns: minmax(0, 1fr);
        }

        .topbar nav {
          gap: 10px 16px;
        }

        .nav-actions {
          grid-template-columns: minmax(0, 1fr);
        }

        .nav-actions-auth {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .flash-stack--floating {
          top: calc(env(safe-area-inset-top, 0px) + 12px);
          width: calc(100vw - 16px);
        }

        .flash-banner {
          gap: 12px;
          padding: 13px 15px;
        }

        .flash-banner__icon {
          width: 28px;
          height: 28px;
          font-size: 0.85rem;
        }

        .flash-banner__message {
          font-size: 0.86rem;
        }

        /* Auth pages: full-width single column on small phones */
        .auth-shell-single .auth-panel {
          width: 100%;
        }

        .auth-panel h1 {
          font-size: clamp(1.8rem, 10vw, 2.8rem);
        }

        /* Make form inputs and buttons easier to tap */
        .field input,
        .field select {
          min-height: 56px;
          font-size: 1rem;
        }

        .button {
          min-height: 56px;
          font-size: 0.95rem;
        }

        .cta-section {
          padding: 24px 20px;
          border-radius: 20px;
        }
      }
    </style>
  </head>

  <body>
    <%= render "shared/page_loader" %>
    <%= render "shared/flash_banners" unless workspace_layout_page? %>

    <%= yield %>
    <%= render "shared/install_popup_modal" %>
    <script src="<%= versioned_public_asset_path("/scripts/page_loader.js") %>" defer></script>
    <script type="module" src="/scripts/app.js"></script>
  </body>
</html>
