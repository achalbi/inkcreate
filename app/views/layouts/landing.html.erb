      .flash-banner {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: start;
        gap: 14px;
        padding: 14px 18px;
        border-radius: 18px;
        border: 1px solid rgba(20, 38, 31, 0.08);
        box-shadow: var(--shadow-soft);
        animation: flashBannerIn 0.32s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .flash-stack {
        display: grid;
        gap: 12px;
      }

      .flash-stack--floating {
        position: fixed;
        top: calc(env(safe-area-inset-top, 0px) + 16px);
        left: 50%;
        transform: translateX(-50%);
        width: min(560px, calc(100vw - 24px));
        z-index: 1085;
        pointer-events: none;
      }

      .flash-banner.notice {
        background: rgba(28, 109, 73, 0.12);
        color: #153a2d;
      }

      .flash-banner.alert {
        background: rgba(181, 74, 24, 0.12);
        color: #6b3110;
      }

      .flash-stack--floating .flash-banner {
        pointer-events: auto;
        backdrop-filter: blur(14px);
        background-clip: padding-box;
      }

      .flash-banner__icon {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1;
        background: rgba(20, 38, 31, 0.08);
      }

      .flash-banner__body {
        min-width: 0;
      }

      .flash-banner__title {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.78;
      }

      .flash-banner__message {
        margin-top: 4px;
        font-size: 0.92rem;
        font-weight: 600;
        line-height: 1.45;
        overflow-wrap: anywhere;
      }

      @keyframes flashBannerIn {
        from {
          opacity: 0;
          transform: translateY(-12px) scale(0.97);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes flashBannerOut {
        from {
          opacity: 1;
          transform: translateY(0) scale(1);
        }

        to {
          opacity: 0;
          transform: translateY(-10px) scale(0.98);
          visibility: hidden;
        }
      }

