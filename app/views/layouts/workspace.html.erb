<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Inkcreate Workspace</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#e66239">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.35.0/dist/tabler-icons.min.css" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/inapp/inapp_workspace.css") %>" rel="stylesheet">
    <link rel="manifest" href="<%= versioned_public_asset_path("/manifest.json") %>">
    <link rel="icon" type="image/svg+xml" href="<%= versioned_public_asset_path("/icons/app-icon.svg") %>">
  </head>

  <body class="workspace-body">
    <div id="overlay" class="overlay"></div>

    <%= render "shared/workspace_nav" %>
    <%= render "shared/workspace_topbar" %>

    <main id="content" class="content py-6 py-lg-6">
      <div class="container-fluid px-3 px-lg-4">
        <%= yield %>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="<%= versioned_public_asset_path("/inapp/inapp_workspace.js") %>" defer></script>
    <script type="module" src="<%= versioned_public_asset_path("/scripts/app.js") %>"></script>
  </body>
</html>
