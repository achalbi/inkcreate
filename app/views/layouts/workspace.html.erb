<!DOCTYPE html>
<html lang="en" data-time-zone="<%= effective_time_zone_name %>">
  <head>
    <title>Inkcreate Workspace</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f5eee3">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="<%= versioned_public_asset_path("/scripts/device_time_zone.js") %>" defer></script>
    <% if Rails.env.test? %>
      <script src="<%= versioned_public_asset_path("/scripts/test_browser_mocks.js") %>"></script>
    <% end %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.35.0/dist/tabler-icons.min.css" rel="stylesheet">
    <link href="https://unpkg.com/trix@2.1.18/dist/trix.css" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/vendor/photoswipe/photoswipe.css") %>" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/inapp/page_loader.css") %>" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/inapp/inapp_workspace.css") %>" rel="stylesheet">
    <link rel="manifest" href="<%= versioned_public_asset_path("/manifest.json") %>">
    <link rel="icon" type="image/svg+xml" href="<%= versioned_public_asset_path("/icons/app-icon.svg") %>">
  </head>

  <% show_workspace_sidebar = current_user&.admin? %>

  <body
    class="<%= ["workspace-body", ("workspace-body--no-sidebar" unless show_workspace_sidebar)].compact.join(" ") %>"
    data-controller="reminder-dismiss-confirm"
  >
    <div id="overlay" class="overlay"></div>
    <%= render "shared/page_loader" %>

    <%= render "shared/flash_banners" %>

    <%= render "shared/workspace_nav" if show_workspace_sidebar %>
    <%= render "shared/workspace_topbar", show_workspace_sidebar: show_workspace_sidebar %>

    <main id="content" class="content py-6 py-lg-6">
      <div class="container-fluid px-3 px-lg-4">
        <%= yield %>
      </div>
    </main>

    <%= render "shared/workspace_footer_nav" %>
    <%= render "shared/photo_removal_confirm_modal" %>
    <%= render "shared/reminder_dismiss_confirm_modal" %>
    <% if current_user %>
      <%= render "shared/onboarding_wizard",
            autoshow: !current_user.onboarding_completed? %>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/trix@2.1.18/dist/trix.umd.min.js" defer></script>
    <script src="<%= versioned_public_asset_path("/scripts/page_loader.js") %>" defer></script>
    <script src="<%= versioned_public_asset_path("/inapp/inapp_workspace.js") %>" defer></script>
    <script type="module" src="<%= versioned_public_asset_path("/scripts/app.js") %>"></script>
  </body>
</html>
