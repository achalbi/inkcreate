<% content_for :admin_topbar do %>
  <%= render "admin/topbar",
    eyebrow: "Capture oversight",
    title: "Review every notebook page moving through the system.",
    primary_label: "Admin overview",
    primary_path: admin_dashboard_path,
    secondary_label: "Operations",
    secondary_path: admin_operations_path %>
<% end %>

<%= render "admin/page_header",
  eyebrow: "Capture oversight",
  title: "Review every notebook page moving through the system.",
  description: "This screen keeps the content pipeline grounded: what has arrived, what still needs OCR or backup attention, and which captures are still living only in the inbox.",
  primary_label: "Admin overview",
  primary_path: admin_dashboard_path,
  secondary_label: "Operations",
  secondary_path: admin_operations_path %>

<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card">
      <div class="card-body">
        <h6 class="mb-3 text-secondary">Total captures</h6>
        <h3 class="fw-bold mb-1"><%= @capture_count %></h3>
        <p class="metric-trend text-soft-info mb-0">All notebook pages stored in the system.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card">
      <div class="card-body">
        <h6 class="mb-3 text-secondary">In flight</h6>
        <h3 class="fw-bold mb-1"><%= @inflight_capture_count %></h3>
        <p class="metric-trend text-soft-warning mb-0">Uploads and active processing not fully settled yet.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card">
      <div class="card-body">
        <h6 class="mb-3 text-secondary">Inbox only</h6>
        <h3 class="fw-bold mb-1"><%= @inbox_capture_count %></h3>
        <p class="metric-trend text-soft-primary mb-0">Still waiting to be organized into project or day context.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card">
      <div class="card-body">
        <h6 class="mb-3 text-secondary">Failed</h6>
        <h3 class="fw-bold mb-1"><%= @failed_capture_count %></h3>
        <p class="metric-trend text-soft-danger mb-0">Need retry or manual investigation.</p>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Ready</h6>
        <h3 class="fw-bold mb-1"><%= @ready_capture_count %></h3>
        <p class="mb-0 text-secondary small">Captures already settled and available for retrieval.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">OCR backlog</h6>
        <h3 class="fw-bold mb-1"><%= @ocr_backlog_count %></h3>
        <p class="mb-0 text-secondary small">Pages not yet extracted or still being processed.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Backup review</h6>
        <h3 class="fw-bold mb-1"><%= @backup_backlog_count %></h3>
        <p class="mb-0 text-secondary small">Pending or failed backup states that need visibility.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Sync issues</h6>
        <h3 class="fw-bold mb-1"><%= @sync_issue_count %></h3>
        <p class="mb-0 text-secondary small">Pending, conflict, or failed sync states across the capture set.</p>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 surface-card">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
      <div>
        <h2 class="fs-5 mb-1">Recent capture list</h2>
        <p class="text-secondary mb-0">Ownership, organization context, and status stack in one admin table.</p>
      </div>
      <div class="admin-chip-row">
        <span class="status-pill ready"><%= pluralize(@favorite_capture_count, "favorite") %></span>
        <span class="status-pill not_started"><%= pluralize(@archived_capture_count, "archived capture") %></span>
      </div>
    </div>

    <div class="admin-scroll-table">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Capture</th>
            <th>Owner</th>
            <th>Context</th>
            <th>Status</th>
            <th>Captured</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @captures.each do |capture| %>
            <tr>
              <td>
                <div class="fw-semibold break-anywhere"><%= capture.display_title %></div>
                <div class="text-secondary small mt-1">
                  <%= capture.page_type.to_s.humanize %> • <%= pluralize(capture.attachments.size, "attachment") %>
                  <% if capture.favorite? %>
                    • Favorited
                  <% end %>
                </div>
              </td>
              <td><span class="break-anywhere"><%= capture.user.email %></span></td>
              <td>
                <% if capture.project.present? %>
                  Project: <%= capture.project.title %>
                <% elsif capture.daily_log.present? %>
                  Day: <%= capture.daily_log.display_title %>
                <% elsif capture.notebook.present? %>
                  Notebook: <%= capture.notebook.name %>
                <% else %>
                  Inbox only
                <% end %>
              </td>
              <td>
                <div class="admin-chip-row">
                  <span class="status-pill <%= capture.status %>"><%= capture.status.humanize %></span>
                  <span class="status-pill <%= capture.ocr_status %>"><%= capture.ocr_status.humanize %></span>
                  <span class="status-pill <%= capture.backup_status %>"><%= capture.backup_status.humanize %></span>
                  <span class="status-pill <%= capture.sync_status %>"><%= capture.sync_status.humanize %></span>
                </div>
              </td>
              <td><%= (capture.captured_at || capture.created_at).strftime("%b %-d, %Y") %></td>
              <td><%= link_to "Open capture", capture_path(capture), class: "btn btn-outline-secondary btn-sm" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
