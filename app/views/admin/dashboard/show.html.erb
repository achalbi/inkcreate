<% content_for :admin_topbar do %>
  <%= render "admin/topbar",
    eyebrow: "Admin dashboard",
    title: "Run the notebook pipeline with confidence.",
    primary_label: "Review captures",
    primary_path: admin_captures_path,
    secondary_label: "Operations",
    secondary_path: admin_operations_path %>
<% end %>

<%= render "admin/page_header",
  eyebrow: "Admin dashboard",
  title: "Run the notebook pipeline with confidence.",
  description: "Track adoption, capture flow, queue health, and role access from one operations surface designed for daily review.",
  primary_label: "Review captures",
  primary_path: admin_captures_path,
  secondary_label: "Manage users",
  secondary_path: admin_users_path %>

<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card bg-primary bg-opacity-10">
      <div class="card-body">
        <div class="d-flex gap-3">
          <div class="metric-icon primary"><i class="ti ti-users"></i></div>
          <div>
            <h2 class="fs-6 mb-2">Accounts</h2>
            <h3 class="fw-bold mb-0"><%= @user_count %></h3>
            <p class="metric-trend text-soft-primary mb-0"><%= pluralize(@new_users_this_week, "new user") %> in the last 7 days</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card bg-success bg-opacity-10">
      <div class="card-body">
        <div class="d-flex gap-3">
          <div class="metric-icon success"><i class="ti ti-device-camera-phone"></i></div>
          <div>
            <h2 class="fs-6 mb-2">Captures</h2>
            <h3 class="fw-bold mb-0"><%= @capture_count %></h3>
            <p class="metric-trend text-soft-success mb-0"><%= pluralize(@captures_this_week, "new capture") %> this week</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card bg-info bg-opacity-10">
      <div class="card-body">
        <div class="d-flex gap-3">
          <div class="metric-icon info"><i class="ti ti-briefcase"></i></div>
          <div>
            <h2 class="fs-6 mb-2">Projects</h2>
            <h3 class="fw-bold mb-0"><%= @project_count %></h3>
            <p class="metric-trend text-soft-info mb-0"><%= @daily_log_count %> daily logs preserving date-based context</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card metric-card border-0 surface-card bg-warning bg-opacity-10">
      <div class="card-body">
        <div class="d-flex gap-3">
          <div class="metric-icon warning"><i class="ti ti-list-check"></i></div>
          <div>
            <h2 class="fs-6 mb-2">Open tasks</h2>
            <h3 class="fw-bold mb-0"><%= @open_task_count %></h3>
            <p class="metric-trend text-soft-warning mb-0"><%= @ready_capture_count %> captures are fully ready for retrieval</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-xl-8">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
          <div>
            <h2 class="fs-5 mb-1">Command center</h2>
            <p class="text-secondary mb-0">Use the admin workspace to monitor capture quality, queue health, and account access from one in-app surface.</p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Capture oversight", admin_captures_path, class: "btn btn-outline-secondary btn-sm" %>
            <%= link_to "Queue health", admin_operations_path, class: "btn btn-primary btn-sm" %>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <div class="admin-note h-100">
              <h6 class="mb-2">Role balance</h6>
              <p class="text-secondary mb-2">Keep access changes grounded in the overall operator mix.</p>
              <div class="admin-chip-row">
                <span class="status-pill ready"><%= pluralize(@admin_count, "admin") %></span>
                <span class="status-pill not_started"><%= pluralize(@standard_user_count, "standard user") %></span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="admin-note h-100">
              <h6 class="mb-2">Backup readiness</h6>
              <p class="text-secondary mb-2">Drive-linked users can move straight into export and backup flows.</p>
              <div class="admin-chip-row">
                <span class="status-pill synced"><%= pluralize(@connected_drive_count, "Drive-linked user") %></span>
                <span class="status-pill pending"><%= pluralize(@backup_backlog_count, "capture") %> pending review</span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="admin-note h-100">
              <h6 class="mb-2">OCR readiness</h6>
              <p class="text-secondary mb-2">Manual OCR is explicit, so backlog matters when users start expecting extraction.</p>
              <div class="admin-chip-row">
                <span class="status-pill processing"><%= pluralize(@ocr_backlog_count, "capture") %> waiting on OCR</span>
                <span class="status-pill completed"><%= pluralize(@ready_capture_count, "ready capture") %></span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="admin-note h-100">
              <h6 class="mb-2">Sync health</h6>
              <p class="text-secondary mb-2">Pending, conflict, and failed sync states signal where local-first flow is drifting.</p>
              <div class="admin-chip-row">
                <span class="status-pill conflict"><%= pluralize(@sync_issue_count, "sync issue") %></span>
                <span class="status-pill uploaded"><%= pluralize(@capture_count - @sync_issue_count, "capture") %> stable</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-4">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h2 class="fs-5 mb-3">Watchlist</h2>
        <div class="admin-list-item">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <h6 class="mb-1"><%= pluralize(@active_capture_count, "capture") %> in flight</h6>
              <p class="text-secondary mb-0 small">Uploads and live processing that have not settled yet.</p>
            </div>
            <span class="status-pill processing"><%= @active_capture_count %></span>
          </div>
        </div>
        <div class="admin-list-item">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <h6 class="mb-1"><%= pluralize(@failed_capture_count, "failed capture") %></h6>
              <p class="text-secondary mb-0 small">Use this as the first signal for retries or broken file flows.</p>
            </div>
            <span class="status-pill failed"><%= @failed_capture_count %></span>
          </div>
        </div>
        <div class="admin-list-item">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <h6 class="mb-1"><%= pluralize(@backup_backlog_count, "backup item") %> need review</h6>
              <p class="text-secondary mb-0 small">Pending and failed backup states visible before trust erodes.</p>
            </div>
            <span class="status-pill pending"><%= @backup_backlog_count %></span>
          </div>
        </div>
        <div class="admin-list-item">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <h6 class="mb-1"><%= pluralize(@sync_issue_count, "sync issue") %></h6>
              <p class="text-secondary mb-0 small">Conflicts and failed syncs can leave offline users out of parity.</p>
            </div>
            <span class="status-pill conflict"><%= @sync_issue_count %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Notebooks</h6>
        <h3 class="fw-bold mb-1"><%= @notebook_count %></h3>
        <p class="mb-0 text-secondary small">Structured containers created across the product.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Tags</h6>
        <h3 class="fw-bold mb-1"><%= @tag_count %></h3>
        <p class="mb-0 text-secondary small">Classification labels attached to saved notebook pages.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Ready captures</h6>
        <h3 class="fw-bold mb-1"><%= @ready_capture_count %></h3>
        <p class="mb-0 text-secondary small">Searchable and settled captures available for retrieval.</p>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6 col-xl-3">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <h6 class="text-secondary mb-3">Connected Drive</h6>
        <h3 class="fw-bold mb-1"><%= @connected_drive_count %></h3>
        <p class="mb-0 text-secondary small">Users who can export results directly into Google Drive.</p>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-12 col-xl-6">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h2 class="fs-5 mb-1">Recent users</h2>
            <p class="text-secondary mb-0">Role review and onboarding context one click away.</p>
          </div>
          <%= link_to "Open user management", admin_users_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>

        <div class="admin-scroll-table">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Drive</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_users.each do |user| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      <span class="table-avatar"><%= user.email.first.upcase %></span>
                      <div class="min-w-0">
                        <div class="fw-semibold break-anywhere"><%= user.email %></div>
                      </div>
                    </div>
                  </td>
                  <td><span class="status-pill <%= user.admin? ? "ready" : "not_started" %>"><%= user.role %></span></td>
                  <td><%= user.created_at.strftime("%b %-d, %Y") %></td>
                  <td><%= user.google_drive_connected? ? "Connected" : "Not connected" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-6">
    <div class="card border-0 surface-card h-100">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h2 class="fs-5 mb-1">Recent captures</h2>
            <p class="text-secondary mb-0">Use the live feed to spot stalled processing or repeated failures.</p>
          </div>
          <%= link_to "Review all captures", admin_captures_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>

        <% if @recent_captures.any? %>
          <% @recent_captures.each do |capture| %>
            <div class="admin-list-item">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div class="min-w-0">
                  <h6 class="mb-1 break-anywhere"><%= capture.display_title %></h6>
                  <p class="text-secondary mb-2 small break-anywhere">
                    <%= capture.user.email %>
                    <% if capture.project.present? %>
                      • Project <%= capture.project.title %>
                    <% elsif capture.daily_log.present? %>
                      • <%= capture.daily_log.display_title %>
                    <% elsif capture.notebook.present? %>
                      • Notebook <%= capture.notebook.name %>
                    <% else %>
                      • Inbox
                    <% end %>
                  </p>
                  <div class="admin-chip-row">
                    <span class="status-pill <%= capture.status %>"><%= capture.status.humanize %></span>
                    <span class="status-pill <%= capture.ocr_status %>"><%= capture.ocr_status.humanize %></span>
                  </div>
                </div>
                <div class="text-secondary small text-nowrap"><%= capture.created_at.strftime("%b %-d, %Y") %></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="admin-empty">The feed will populate as soon as notebook pages begin moving through the capture pipeline.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
