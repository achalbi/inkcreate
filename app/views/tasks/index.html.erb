<%
  filter_copy = {
    "all" => {
      title: "All tasks",
      description: "Everything you are tracking across notebooks, pages, and promoted to-dos stays here."
    },
    "active" => {
      title: "Active tasks",
      description: "Open work that still needs attention, without the completed noise."
    },
    "done" => {
      title: "Completed tasks",
      description: "Closed loops, finished work, and recent wins remain easy to review."
    },
    "overdue" => {
      title: "Overdue tasks",
      description: "These tasks slipped past their due date and likely need a quick decision."
    },
    "today" => {
      title: "Due today",
      description: "Work that deserves attention before the day wraps up."
    }
  }.fetch(@tasks_filter)

  total = @counts[:all]
  done_count = @counts[:done]
  pct = total.zero? ? 0 : (done_count.to_f / total * 100).round
  list_intro = filter_copy[:description]
  list_intro = "#{list_intro} Filtered by ##{@tag_filter}." if @tag_filter.present?

  sort_options = [
    ["manual", "Recent first", "Keep the latest task updates nearest the top."],
    ["priority", "Priority", "Surface urgent and high-priority work before the rest."],
    ["due", "Due date", "Pull deadlines and time-sensitive tasks forward."],
    ["created", "Created", "Review tasks in the order they were captured."]
  ]

  group_options = [
    ["none", "None", "Show one continuous task list without grouping."],
    ["priority", "Priority", "Cluster tasks by urgency level."],
    ["severity", "Severity", "Group by impact so blockers stand out faster."],
    ["due", "Due date", "Separate tasks by their deadline window."]
  ]

  current_sort_label = sort_options.find { |value, _, _| value == @tasks_sort }&.at(1) || "Recent first"
  current_group_label = group_options.find { |value, _, _| value == @tasks_group }&.at(1) || "None"
%>

<%= render "shared/workspace_header",
  # breadcrumbs: [["Home", dashboard_path], "Tasks"],
  eyebrow: "Tasks",
  title: "Keep follow-up work visible across notebooks and days.",
  description: "Standalone work, promoted page to-dos, reminders, and linked context all stay in one shared task workspace." %> 

<div class="wrapper wrapper-content animated fadeInRight"
     data-controller="task-manager"
     data-task-manager-filter-value="<%= @tasks_filter %>">

  <div class="workspace-index-actions task-index-actions"
       data-controller="section-shortcuts"
       data-section-shortcuts-collapse-threshold-value="56"
       data-section-shortcuts-target="rail">
    <div class="workspace-index-actions__left">
      <div class="workspace-index-controls">
        <div class="task-filter-tabs" role="tablist" aria-label="Task filters">
          <% [
            ["all", "All", @counts[:all]],
            ["active", "Active", @counts[:active]],
            ["done", "Done", @counts[:done]],
            ["overdue", "Overdue", @counts[:overdue]],
            ["today", "Today", @counts[:today]]
          ].each do |filter, label, count| %>
            <%= link_to tasks_path(filter: filter, sort: @tasks_sort, group: @tasks_group, tag: @tag_filter),
              class: ["task-filter-tab", ("active" if @tasks_filter == filter)].compact.join(" "),
              role: "tab",
              aria: { selected: (@tasks_filter == filter) } do %>
              <span class="task-filter-tab-label"><%= label %></span>
              <span class="task-filter-tab-count"><%= count %></span>
            <% end %>
          <% end %>
        </div>

        <% if @tag_filter.present? %>
          <span class="task-tag-filter-pill">
            #<%= @tag_filter %>
            <%= link_to tasks_path(filter: @tasks_filter, sort: @tasks_sort, group: @tasks_group), class: "task-tag-filter-clear", aria: { label: "Clear tag filter" } do %>
              <i class="ti ti-x" aria-hidden="true"></i>
            <% end %>
          </span>
        <% end %>

        <div class="task-index-actions__right">
          <button
            type="button"
            class="btn btn-primary btn-sm d-none d-md-inline-flex"
            data-action="task-manager#openQuickAdd"
            aria-label="New task"
          >
            <i class="ti ti-plus" aria-hidden="true"></i>
            New task
          </button>

          <div class="task-index-selectors">
            <div class="dropdown notepad-entry-move-modal__dropdown task-toolbar-dropdown">
              <button
                id="tasks_sort_dropdown"
                type="button"
                class="btn btn-white dropdown-toggle notepad-entry-move-modal__dropdown-toggle task-toolbar-dropdown__toggle"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <span class="task-toolbar-dropdown__label">Sort</span>
                <span class="task-toolbar-dropdown__value"><%= current_sort_label %></span>
              </button>
              <div
                class="dropdown-menu w-100 notepad-entry-move-modal__dropdown-menu task-toolbar-dropdown__menu"
                aria-labelledby="tasks_sort_dropdown"
              >
                <% sort_options.each do |value, label, meta| %>
                  <%= link_to tasks_path(filter: @tasks_filter, sort: value, group: @tasks_group, tag: @tag_filter),
                    class: ["dropdown-item", "notepad-entry-move-modal__dropdown-item", ("active" if @tasks_sort == value)].compact.join(" ") do %>
                    <span class="notepad-entry-move-modal__dropdown-item-title"><%= label %></span>
                    <span class="notepad-entry-move-modal__dropdown-item-meta"><%= meta %></span>
                  <% end %>
                <% end %>
              </div>
            </div>

            <div class="dropdown notepad-entry-move-modal__dropdown task-toolbar-dropdown">
              <button
                id="tasks_group_dropdown"
                type="button"
                class="btn btn-white dropdown-toggle notepad-entry-move-modal__dropdown-toggle task-toolbar-dropdown__toggle"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <span class="task-toolbar-dropdown__label">Group</span>
                <span class="task-toolbar-dropdown__value"><%= current_group_label %></span>
              </button>
              <div
                class="dropdown-menu w-100 notepad-entry-move-modal__dropdown-menu task-toolbar-dropdown__menu"
                aria-labelledby="tasks_group_dropdown"
              >
                <% group_options.each do |value, label, meta| %>
                  <%= link_to tasks_path(filter: @tasks_filter, sort: @tasks_sort, group: value, tag: @tag_filter),
                    class: ["dropdown-item", "notepad-entry-move-modal__dropdown-item", ("active" if @tasks_group == value)].compact.join(" ") do %>
                    <span class="notepad-entry-move-modal__dropdown-item-title"><%= label %></span>
                    <span class="notepad-entry-move-modal__dropdown-item-meta"><%= meta %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="task-completion-overview"
         aria-label="Task completion"
         data-section-shortcuts-target="collapseOnDock">
      <div class="task-completion-overview__copy">
        <span><%= done_count %> of <%= total %> tasks completed</span>
      </div>
      <div class="task-progress-row">
        <div class="task-progress-bar" role="progressbar" aria-valuenow="<%= done_count %>" aria-valuemax="<%= [total, 1].max %>">
          <div class="task-progress-fill" style="width: <%= pct %>%"></div>
        </div>
        <span class="task-progress-label"><%= pct %>%</span>
      </div>
    </div>
  </div>

  <div class="task-quick-add-panel"
       data-task-manager-target="quickAddPanel"
       aria-hidden="true"
       style="display:none">
    <section class="ibox float-e-margins">
      <div class="ibox-title">
        <h5>New task</h5>
        <div class="ibox-tools">
          <button type="button" class="btn btn-xs btn-white" data-action="task-manager#closeQuickAdd" aria-label="Cancel">
            <i class="ti ti-x" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <div class="ibox-content collapse show">
        <%= form_with url: tasks_path(filter: @tasks_filter, sort: @tasks_sort, group: @tasks_group, tag: @tag_filter),
          method: :post,
          class: "task-quick-add-form",
          data: { action: "submit->task-manager#handleQuickAddSubmit" } do |f| %>
          <div class="task-quick-add-row">
            <%= f.text_field :title,
              name: "task[title]",
              placeholder: "Task title... press Enter to save",
              required: true,
              autocomplete: "off",
              class: "task-quick-add-input",
              data: { task_manager_target: "quickAddInput" } %>
          </div>

          <div class="task-quick-add-meta">
            <div class="field-inline">
              <%= f.select :priority,
                Task.priorities.keys.map { |priority| [priority.humanize, priority] },
                { selected: "medium" },
                name: "task[priority]",
                class: "task-meta-select" %>
            </div>

            <div class="field-inline">
              <%= f.select :severity,
                Task.severities.keys.map { |severity| [severity.humanize, severity] },
                { selected: "minor" },
                name: "task[severity]",
                class: "task-meta-select" %>
            </div>

            <div class="field-inline">
              <%= f.date_field :due_date, name: "task[due_date]", class: "task-meta-select", placeholder: "Due date" %>
            </div>

            <div class="field-inline">
              <%= f.text_field :tags_input, name: "task[tags_input]", placeholder: "Tags (comma-separated)", class: "task-meta-select" %>
            </div>
          </div>

          <div class="task-quick-add-actions">
            <%= f.submit "Add task", class: "btn btn-primary btn-sm" %>
            <button type="button" class="btn btn-white btn-sm" data-action="task-manager#closeQuickAdd">Cancel</button>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="ibox float-e-margins">
    <div class="ibox-title task-section-titlebar">
      <div class="task-section-heading">
        <h5 class="task-section-title"><%= filter_copy[:title] %></h5>
        <span class="label label-info task-section-count"><%= @tasks.size %></span>
      </div>
      <div class="ibox-tools d-flex align-items-center gap-2 task-section-tools">
        <%= render "shared/ibox_toggle_button", target_id: "tasks-list-content" %>
      </div>
    </div>

    <div id="tasks-list-content" class="ibox-content collapse show task-list-section__content">
      <p class="task-list-section__intro"><%= list_intro %></p>

      <% if @tasks.empty? %>
        <%= render "shared/empty_state",
          title: (@tasks_filter == "all" ? "No tasks yet" : "No matching tasks"),
          description: (@tasks_filter == "all" ? "Create your first task to keep work visible across notebooks, pages, and daily capture." : "Try another filter, remove the current tag, or switch back to all tasks.") %>

        <% if @tasks_filter == "all" %>
          <p class="task-list-section__empty-hint">Use the <kbd>N</kbd> shortcut or the floating add button on mobile to get started.</p>
        <% end %>
      <% else %>
        <div class="task-list-shell">
          <div class="task-list" data-task-manager-target="list">
            <% grouped = group_tasks_for_display(@tasks, @tasks_group) %>
            <% grouped.each do |group_label, group_tasks| %>
              <% if group_label.present? %>
                <div class="task-group-heading">
                  <span><%= group_label %></span>
                  <span class="task-group-count"><%= group_tasks.size %></span>
                </div>
              <% end %>

              <% group_tasks.each do |task| %>
                <%= render "tasks/task_card", task: task, filter: @tasks_filter, sort: @tasks_sort, group: @tasks_group, tag_filter: @tag_filter %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <div class="task-detail-backdrop"
       data-task-manager-target="backdrop"
       data-action="click->task-manager#closeDetail"
       aria-hidden="true"></div>

  <aside class="task-detail-drawer"
         data-task-manager-target="drawer"
         role="dialog"
         aria-modal="true"
         aria-label="Task details">
    <div class="task-detail-drawer-inner" data-task-manager-target="drawerContent"></div>
  </aside>

  <div class="task-new-modal-backdrop"
       data-task-manager-target="newModalBackdrop"
       data-action="click->task-manager#closeNewModal"
       aria-hidden="true"></div>

  <div class="task-new-modal"
       data-task-manager-target="newModal"
       role="dialog"
       aria-modal="true"
       aria-labelledby="taskNewModalTitle"
       aria-hidden="true">

    <div class="task-new-modal-handle" aria-hidden="true"></div>

    <div class="task-new-modal-header">
      <h2 class="task-new-modal-title" id="taskNewModalTitle">New task</h2>
      <button class="task-action-btn" data-action="task-manager#closeNewModal" aria-label="Close">
        <i class="ti ti-x" aria-hidden="true"></i>
      </button>
    </div>

    <%= form_with url: tasks_path(filter: @tasks_filter, sort: @tasks_sort, group: @tasks_group, tag: @tag_filter),
      method: :post,
      class: "task-new-modal-form",
      data: { action: "submit->task-manager#handleNewModalSubmit" } do |f| %>

      <%= f.text_field :title,
        name: "task[title]",
        placeholder: "Capture your thoughts or action plan...",
        required: true,
        autocomplete: "off",
        class: "task-new-modal-title-input",
        data: { task_manager_target: "newModalInput" } %>

      <%= f.text_area :description,
        name: "task[description]",
        placeholder: "Add notes...",
        rows: 2,
        class: "task-new-modal-desc" %>

      <div class="task-new-modal-props">
        <div class="task-new-modal-prop">
          <label class="task-new-modal-prop-label">Priority</label>
          <%= f.select :priority,
            Task.priorities.keys.map { |priority| [priority.humanize, priority] },
            { selected: "medium" },
            name: "task[priority]",
            class: "task-new-modal-select" %>
        </div>

        <div class="task-new-modal-prop">
          <label class="task-new-modal-prop-label">Severity</label>
          <%= f.select :severity,
            Task.severities.keys.map { |severity| [severity.humanize, severity] },
            { selected: "minor" },
            name: "task[severity]",
            class: "task-new-modal-select" %>
        </div>

        <div class="task-new-modal-prop">
          <label class="task-new-modal-prop-label">Due date</label>
          <%= f.date_field :due_date,
            name: "task[due_date]",
            class: "task-new-modal-select" %>
        </div>

        <div class="task-new-modal-prop">
          <label class="task-new-modal-prop-label">Tags</label>
          <%= f.text_field :tags_input,
            name: "task[tags_input]",
            placeholder: "launch, bug...",
            class: "task-new-modal-select" %>
        </div>
      </div>

      <div class="task-new-modal-footer">
        <%= f.submit "Add task", class: "btn btn-primary" %>
        <button type="button" class="btn btn-white" data-action="task-manager#closeNewModal">Cancel</button>
      </div>
    <% end %>
  </div>

  <button type="button"
          class="workspace-fab photo-capture-fab d-lg-none"
          data-action="task-manager#openNewModal"
          aria-label="Create new task"
          title="Create new task">
    <i class="ti ti-plus" aria-hidden="true"></i>
  </button>
</div>
