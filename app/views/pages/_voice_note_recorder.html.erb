<%
  recorder_mode = local_assigns.fetch(:mode, :persisted).to_s
  recorder_form = local_assigns[:form]
  create_url = local_assigns[:create_url]
  param_key = local_assigns[:param_key].presence || recorder_form&.object_name.to_s.presence || "page"
  auto_submit_on_save = local_assigns.fetch(:auto_submit_on_save, false)
  start_button_label = local_assigns.fetch(:start_button_label, "Record voice note")
  show_start_button = local_assigns.fetch(:show_start_button, true)
%>

<div
  class="voice-note-recorder"
  data-controller="voice-recorder"
  data-voice-recorder-auto-submit-on-save-value="<%= auto_submit_on_save %>"
  data-voice-recorder-mode-value="<%= recorder_mode %>"
  data-voice-recorder-max-duration-seconds-value="<%= VoiceNote::MAX_DURATION_SECONDS %>"
  data-voice-recorder-param-key-value="<%= param_key %>"
  <% if create_url.present? %>
    data-voice-recorder-create-url-value="<%= create_url %>"
  <% end %>
>
  <%= render "pages/voice_note_recorder_content",
    recorder_mode: recorder_mode,
    recorder_form: recorder_form,
    show_start_button: show_start_button,
    start_button_label: start_button_label %>
</div>
