<article
  class="notebook-list-card notebook-list-card--page"
  data-card-link="<%= notebook_chapter_page_path(notebook, chapter, page) %>"
  tabindex="0"
  role="link"
  aria-label="Open <%= page.display_title %>"
>
  <div class="notebook-list-card__body">
    <div class="notebook-list-card__content notebook-list-card__content--chapter">
      <div class="notebook-list-card__symbol" aria-hidden="true">
        <i class="ti ti-file-text"></i>
      </div>

      <div class="notebook-list-card__main">
        <div class="notebook-list-card__title-row">
          <h6 class="notebook-list-card__title"><%= page.display_title %></h6>
          <span class="label label-default notebook-list-card__status">Pg. <%= page.position %></span>
        </div>

        <p class="notebook-list-card__description"><%= page.plain_notes.truncate(140).presence || page.contact_preview_text.to_s.truncate(140).presence || page.location_preview_text.to_s.truncate(140).presence || "No notes yet." %></p>

        <div class="notebook-list-card__meta notebook-list-card__meta--chapter">
          <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
            <i class="ti ti-camera" aria-hidden="true"></i>
            <strong><%= page.photos.count %></strong> <%= "photo".pluralize(page.photos.count) %>
          </span>

          <% if VoiceNote.schema_ready? %>
            <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
              <i class="ti ti-microphone" aria-hidden="true"></i>
              <strong><%= page.voice_notes.count %></strong> <%= "voice note".pluralize(page.voice_notes.count) %>
            </span>
          <% end %>

          <% if TodoList.schema_ready? && TodoItem.schema_ready? && page.todo_list&.enabled? %>
            <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
              <i class="ti ti-list-check" aria-hidden="true"></i>
              <%= page.todo_list.progress_label %>
            </span>
          <% end %>

          <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
            <i class="ti ti-calendar-event" aria-hidden="true"></i>
            <% if page.captured_on.present? %>
              <%= page.captured_on.strftime("%b %-d, %Y") %>
            <% else %>
              No capture date
            <% end %>
          </span>

          <% if page.location_present? %>
            <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
              <i class="ti ti-map-pin" aria-hidden="true"></i>
              <%= page.location_count_label %>
            </span>
          <% end %>

          <% if page.contact_present? %>
            <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
              <i class="ti ti-address-book" aria-hidden="true"></i>
              <%= page.contact_count_label %>
            </span>
          <% end %>

          <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
            <i class="ti ti-clock-hour-4" aria-hidden="true"></i>
            <%= time_ago_in_words(page.updated_at) %> ago
          </span>
        </div>
      </div>

      <div class="notebook-list-card__trailing">
        <%= button_to move_notebook_chapter_page_path(notebook, chapter, page, direction: :up),
          method: :patch,
          class: "btn btn-white btn-sm btn-icon chapter-move-btn",
          title: "Move page up",
          aria: { label: "Move #{page.display_title} up" },
          form: { class: "content-list-actions__form" } do %>
          <i class="ti ti-chevron-up" aria-hidden="true"></i>
        <% end %>

        <%= button_to move_notebook_chapter_page_path(notebook, chapter, page, direction: :down),
          method: :patch,
          class: "btn btn-white btn-sm btn-icon chapter-move-btn",
          title: "Move page down",
          aria: { label: "Move #{page.display_title} down" },
          form: { class: "content-list-actions__form" } do %>
          <i class="ti ti-chevron-down" aria-hidden="true"></i>
        <% end %>
      </div>
    </div>
  </div>
</article>
