<%= form_with model: [notebook, chapter, page] do |form| %>
  <% if page.errors.any? %>
    <% error_body = capture do %>
      <ul class="m-b-none m-t-sm">
        <% page.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
    <%= render "shared/inline_alert", type: :danger, title: "Please fix the following:", body_html: error_body %>
  <% end %>

  <div class="row">
    <div class="col-lg-7">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Page details</h5>
          <div class="ibox-tools">
            <%= render "shared/ibox_toggle_button", target_id: "page-form-details-content" %>
          </div>
        </div>
        <div id="page-form-details-content" class="ibox-content collapse show">
          <div class="row">
            <div class="col-lg-8">
              <div class="form-group">
                <%= form.label :title, class: "control-label" %>
                <%= form.text_field :title, class: "form-control", placeholder: "Interview notes - stakeholder round 1 - Page 1" %>
              </div>
            </div>
            <div class="col-lg-4">
              <div class="form-group">
                <%= form.label :captured_on, class: "control-label" %>
                <%= form.date_field :captured_on, class: "form-control" %>
              </div>
            </div>
          </div>

          <div class="form-group">
            <%= form.label :notes, class: "control-label" %>
            <%= form.text_area :notes, rows: 10, class: "form-control", placeholder: "Store text context, observations, transcript notes, action items, or any supporting detail for this page." %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="ibox" id="page_photos" data-controller="photo-capture">
        <div class="ibox-title">
          <h5>Photos</h5>
          <div class="ibox-tools">
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-camera-button"
              data-action="photo-capture#start"
              data-photo-capture-target="cameraToggle"
              aria-pressed="false"
              title="Open live preview"
            >
              <i class="ti ti-camera" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-info-button"
              data-bs-toggle="collapse"
              data-bs-target="#page-form-capture-tips"
              aria-expanded="false"
              aria-controls="page-form-capture-tips"
              title="Capture tips"
            >
              <i class="ti ti-info-circle" aria-hidden="true"></i>
            </button>
            <%= render "shared/ibox_toggle_button", target_id: "page-form-photos-content" %>
          </div>
        </div>
        <div id="page-form-photos-content" class="ibox-content collapse show">
          <%= render "shared/photo_capture_field", form:, field_name: :photos, tips_target_id: "page-form-capture-tips" %>

          <% if page.photos.attached? %>
            <hr>
            <h5 class="m-t-none m-b-md">Current photos</h5>
            <div>
              <div class="row">
                <% page.photos.each do |photo| %>
                  <div class="col-sm-6">
                    <div class="thumbnail">
                      <%= render "shared/photo_lightbox", photo:, alt: page.display_title, image_style: "width: 100%; height: 220px; object-fit: cover;" %>
                      <div class="caption">
                        <%= button_to "Remove", photo_notebook_chapter_page_path(notebook, chapter, page, photo),
                          method: :delete,
                          form: { style: "margin: 0;", onsubmit: "return confirm('Remove this photo?');" },
                          class: "btn btn-danger btn-sm" %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="m-t-md">
    <%= form.submit class: "btn btn-primary btn-sm" %>
    <%= link_to "Cancel", page.persisted? ? notebook_chapter_page_path(notebook, chapter, page) : notebook_chapter_path(notebook, chapter), class: "btn btn-white btn-sm" %>
  </div>
<% end %>
