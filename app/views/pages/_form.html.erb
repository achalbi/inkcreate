<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.schema_ready?
  persisted_page = page.persisted?
  form_id = dom_id(page, :edit_form)
  quick_create_form_id = persisted_page ? dom_id(page, :quick_create_form) : nil
  details_section_id = dom_id(page, :details_section)
  contact_section_id = dom_id(page, :contact_section)
  contact_add_button_id = dom_id(page, :contact_add_button)
  location_section_id = dom_id(page, :location_section)
  location_input_id = dom_id(page, :location_search_input)
  notes_section_id = dom_id(page, :notes_section)
  photos_section_id = dom_id(page, :photos_section)
  photo_camera_input_id = dom_id(page, :photo_camera_input)
  photo_camera_button_id = dom_id(page, :photo_camera_button)
  voice_notes_section_id = dom_id(page, :voice_notes_section)
  todo_list_section_id = persisted_page ? dom_id(page, :todo_list_section) : dom_id(page, :todo_form_list_section)
  scanned_documents_section_id = dom_id(page, :scanned_documents_section)
  photo_count = [page.photos.count, page.pending_photo_blobs.size].max
  voice_note_count = (persisted_page && voice_notes_available ? page.voice_notes.count : 0) + page.pending_voice_note_uploads.size
  todo_items = persisted_page && todo_lists_available ? page.todo_list&.display_todo_items&.to_a || [] : []
  todo_count = persisted_page ? todo_items.size : page.pending_todo_item_contents.size
  completed_todo_count = todo_items.count(&:completed?)
  scanned_document_count = if persisted_page
    page.scanned_documents.count + page.pending_scanned_document_payloads.size
  else
    page.pending_existing_scanned_document_count.to_i + page.pending_scanned_document_payloads.size
  end
  section_shortcuts = [
    { label: "Details", short_label: "Details", icon: "ti-file-text", target: details_section_id },
    { label: "Notes", short_label: "Notes", icon: "ti-notes", target: notes_section_id },
    { label: "Photos", short_label: "Photos", icon: "ti-photo", target: photos_section_id }
  ]
  section_shortcuts << { label: "Voice notes", short_label: "Voice", icon: "ti-microphone", target: voice_notes_section_id } if voice_notes_available
  section_shortcuts << { label: "To-do list", short_label: "To-do", icon: "ti-checkbox", target: todo_list_section_id } if todo_lists_available
  section_shortcuts << { label: "Scanned documents", short_label: "Scans", icon: "ti-scan", target: scanned_documents_section_id }
  section_shortcuts << { label: "Contacts", short_label: "Contacts", icon: "ti-address-book", target: contact_section_id }
  section_shortcuts << { label: "Location", short_label: "Location", icon: "ti-map-pin", target: location_section_id }
%>

<nav class="detail-section-shortcuts" aria-label="Jump to page edit sections" data-controller="section-shortcuts">
  <div class="detail-section-shortcuts__rail" data-section-shortcuts-target="rail">
    <span class="detail-section-shortcuts__indicator" data-section-shortcuts-target="indicator" aria-hidden="true"></span>
    <% section_shortcuts.each_with_index do |shortcut, index| %>
      <a
        href="#<%= shortcut[:target] %>"
        class="detail-section-shortcut<%= " is-active" if index.zero? %>"
        title="<%= shortcut[:label] %>"
        aria-label="Jump to <%= shortcut[:label] %>"
        <% if index.zero? %>aria-current="location"<% end %>
        data-section-shortcuts-target="link"
        data-action="click->section-shortcuts#markActive"
      >
        <i class="ti <%= shortcut[:icon] %>" aria-hidden="true"></i>
        <span class="detail-section-shortcut__label"><%= shortcut[:short_label] %></span>
      </a>
    <% end %>
  </div>
</nav>

<div class="notepad-doc notepad-doc--edit notepad-doc-edit">
  <%= form_with model: [notebook, chapter, page], data: { controller: "photo-capture", photo_capture_auto_save: true }, html: { id: form_id } do |form| %>
    <% if page.errors.any? %>
      <% error_body = capture do %>
        <ul class="m-b-none m-t-sm">
          <% page.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
      <div class="m-b-md">
        <%= render "shared/inline_alert", type: :danger, title: "Please fix the following:", body_html: error_body %>
      </div>
    <% end %>

    <div class="notepad-doc__canvas notepad-doc-edit__canvas">
      <input
        id="<%= photo_camera_input_id %>"
        type="file"
        accept="image/*"
        capture="environment"
        tabindex="-1"
        aria-hidden="true"
        class="photo-section-camera-input"
        data-photo-capture-target="cameraInput"
        data-action="change->photo-capture#acceptCameraCapture"
      >

      <header class="notepad-doc__header notepad-doc-edit__head detail-section-anchor" id="<%= details_section_id %>">
        <div class="notepad-doc__header-row">
          <div class="notepad-doc__header-content">
            <div class="notepad-doc-edit__title-row">
              <div class="form-group m-b-none">
                <%= form.text_field :title,
                  class: "form-control notepad-doc-edit__title-input",
                  placeholder: "Interview notes - stakeholder round 1 - Page 1" %>
              </div>
              <div class="form-group m-b-none">
                <%= form.date_field :captured_on,
                  class: "form-control notepad-doc-edit__date-input" %>
              </div>
            </div>
          </div>
        </div>

        <div class="notepad-doc__meta">
          <% if page.plain_notes.present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-file-text" aria-hidden="true"></i> Notes
            </span>
          <% end %>
          <% if page.location_present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-map-pin" aria-hidden="true"></i>
              <%= page.location_count_label %>
            </span>
          <% end %>
          <% if page.contact_present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-address-book" aria-hidden="true"></i>
              <%= page.contact_count_label %>
            </span>
          <% end %>
          <% if photo_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-photo" aria-hidden="true"></i>
              <%= pluralize(photo_count, "photo") %>
            </span>
          <% end %>
          <% if voice_notes_available && voice_note_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-microphone" aria-hidden="true"></i>
              <%= pluralize(voice_note_count, "voice note") %>
            </span>
          <% end %>
          <% if todo_lists_available && todo_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-checkbox" aria-hidden="true"></i>
              <% if persisted_page %>
                <%= completed_todo_count %>/<%= todo_count %> to-dos
              <% else %>
                <%= pluralize(todo_count, "to-do") %>
              <% end %>
            </span>
          <% end %>
          <% if scanned_document_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-scan" aria-hidden="true"></i>
              <%= pluralize(scanned_document_count, "scan") %>
            </span>
          <% end %>

          <% if persisted_page %>
            <%= link_to notebook_chapter_page_path(notebook, chapter, page),
              class: "notepad-doc__meta-chip notepad-doc__meta-action",
              title: "View page",
              aria: { label: "View page" } do %>
              <i class="ti ti-arrow-left" aria-hidden="true"></i>
              View
            <% end %>

            <%= button_tag type: "submit",
              class: "notepad-doc__meta-chip notepad-doc__meta-action",
              form: quick_create_form_id,
              title: "Create new page",
              aria: { label: "Create new page" } do %>
              <i class="ti ti-plus" aria-hidden="true"></i>
              New page
            <% end %>
          <% else %>
            <%= link_to notebook_chapter_path(notebook, chapter),
              class: "notepad-doc__meta-chip notepad-doc__meta-action",
              title: "View chapter",
              aria: { label: "View chapter" } do %>
              <i class="ti ti-arrow-left" aria-hidden="true"></i>
              Chapter
            <% end %>
          <% end %>
        </div>
      </header>

      <div class="notepad-doc__body notepad-doc-edit__body-form">
        <div class="notepad-doc__block notepad-doc__block--text notepad-doc-edit__notes detail-section-anchor" id="<%= notes_section_id %>">
          <% notes_input_id = dom_id(page, :notes_input) %>
          <div class="notepad-doc__block-header">
            <div class="notepad-doc__block-label">
              <i class="ti ti-file-text" aria-hidden="true"></i> Notes
            </div>
          </div>
          <%= form.hidden_field :notes, id: notes_input_id %>
          <div class="notepad-doc-edit__notes-shell">
            <trix-editor
              input="<%= notes_input_id %>"
              class="workspace-rich-text-editor page-notes-field"
              placeholder="Store text context, observations, transcript notes, action items, or any supporting detail for this page."
              data-controller="rich-text"
              data-action="trix-file-accept->rich-text#preventFileAccept"
            ></trix-editor>
          </div>
        </div>

        <div class="notepad-doc__block notepad-doc__block--media notepad-doc-edit__section detail-section-anchor" id="<%= photos_section_id %>">
          <div class="notepad-doc__block-header">
            <div class="notepad-doc__block-label">
              <i class="ti ti-photo" aria-hidden="true"></i>
              Photos<% if photo_count.positive? %> · <%= photo_count %><% end %>
            </div>
            <div class="notepad-doc__block-actions">
              <button
                type="button"
                id="<%= photo_camera_button_id %>"
                class="btn btn-white btn-sm"
                data-action="photo-capture#openCameraApp"
                data-photo-capture-target="cameraToggle"
                aria-pressed="false"
                title="Open camera"
              >
                <i class="ti ti-camera" aria-hidden="true"></i><span> Capture</span>
              </button>
              <button
                type="button"
                class="btn btn-white btn-sm"
                data-action="photo-capture#chooseFromGallery"
                title="Upload from gallery"
              >
                <i class="ti ti-photo-plus" aria-hidden="true"></i><span> Upload</span>
              </button>
            </div>
          </div>

          <%= render "shared/photo_capture_field", form:, field_name: :photos %>

          <% if page.photos.attached? %>
            <div class="m-t-sm">
              <%= render "pages/photo_strip",
                notebook:,
                chapter:,
                page:,
                group: dom_id(page, :edit_gallery) %>
            </div>
          <% else %>
            <p class="text-muted m-b-none" style="font-size: 0.875rem;">No photos yet — use the buttons above to capture or upload.</p>
          <% end %>
        </div>
      </div>

      <div class="notepad-doc-edit__footer">
        <% if persisted_page %>
          <%= link_to notebook_chapter_page_path(notebook, chapter, page),
            class: "btn btn-white btn-sm",
            title: "View page" do %>
            <i class="ti ti-arrow-left" aria-hidden="true"></i> View
          <% end %>
        <% else %>
          <%= link_to notebook_chapter_path(notebook, chapter),
            class: "btn btn-white btn-sm",
            title: "View chapter" do %>
            <i class="ti ti-arrow-left" aria-hidden="true"></i> Chapter
          <% end %>
        <% end %>

        <div class="ms-auto d-flex gap-2 align-items-center">
          <% if persisted_page %>
            <%= button_tag type: "submit",
              class: "btn btn-white btn-sm",
              form: quick_create_form_id,
              title: "Create new page" do %>
              <i class="ti ti-plus" aria-hidden="true"></i> New page
            <% end %>
            <%= button_to notebook_chapter_page_path(notebook, chapter, page),
              method: :delete,
              class: "btn btn-white btn-sm btn-icon notebook-overview-delete-button",
              form_class: "button_to d-inline-block",
              form: { onsubmit: "return confirm('Delete this page?');" },
              title: "Delete page" do %>
              <i class="ti ti-trash" aria-hidden="true"></i>
            <% end %>
            <%= button_tag "Save changes",
              type: "submit",
              form: form_id,
              class: "btn btn-primary btn-sm page-details-save-button" %>
          <% else %>
            <%= form.submit "Create page",
              class: "btn btn-primary btn-sm page-details-save-button" %>
          <% end %>
        </div>
      </div>
    </div>

    <% unless persisted_page %>
      <div class="row g-3 m-t-md">
        <% if voice_notes_available %>
          <div class="col-12">
            <%= render "pages/voice_notes_section", notebook:, chapter:, page:, form: form %>
          </div>
        <% end %>

        <% if todo_lists_available %>
          <div class="col-12">
            <%= render "pages/todo_list_form_section", notebook:, chapter:, page:, form: form %>
          </div>
        <% else %>
          <div class="col-12">
            <%= render "pages/todo_list_unavailable_section" %>
          </div>
        <% end %>

        <div class="col-12">
          <%= render "pages/scanned_documents_form_section", form:, page: page %>
        </div>

        <div class="col-12">
          <%= render "pages/contact_form_section",
            record: page,
            form_id:,
            section_id: contact_section_id,
            add_button_id: contact_add_button_id %>
        </div>

        <div class="col-12">
          <%= render "pages/location_form_section",
            record: page,
            form_id:,
            section_id: location_section_id %>
        </div>
      </div>
    <% end %>
  <% end %>

  <% if persisted_page %>
    <%= form_with url: quick_create_notebook_chapter_pages_path(notebook, chapter),
      method: :post,
      html: { id: quick_create_form_id, class: "d-none" } do %>
    <% end %>
  <% end %>

  <% if persisted_page %>
    <div class="row g-3 m-t-md">
      <% if voice_notes_available %>
        <div class="col-12">
          <%= render "pages/voice_notes_section", notebook:, chapter:, page: page %>
        </div>
      <% end %>

      <% if todo_lists_available %>
        <div class="col-12">
          <%= render "pages/todo_list_section", notebook:, chapter:, page: page %>
        </div>
      <% else %>
        <div class="col-12">
          <%= render "pages/todo_list_unavailable_section" %>
        </div>
      <% end %>

      <div class="col-12">
        <%= render "pages/scanned_documents_section", notebook:, chapter:, page: page %>
      </div>

      <div class="col-12">
        <%= render "pages/contact_form_section",
          record: page,
          form_id:,
          section_id: contact_section_id,
          add_button_id: contact_add_button_id %>
      </div>

      <div class="col-12">
        <%= render "pages/location_form_section",
          record: page,
          form_id:,
          section_id: location_section_id %>
      </div>
    </div>
  <% end %>

  <%= render "pages/quick_actions",
    photos_section_id:,
    camera_input_id: photo_camera_input_id,
    camera_button_id: photo_camera_button_id,
    voice_notes_section_id:,
    voice_notes_enabled: voice_notes_available,
    todo_list_section_id:,
    todo_lists_enabled: todo_lists_available,
    scanned_documents_section_id:,
    contact_section_id:,
    contact_button_id: contact_add_button_id,
    location_section_id:,
    location_input_id: %>
</div>
