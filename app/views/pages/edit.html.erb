<%= render "shared/workspace_header",
  eyebrow: "Page",
  title: "Edit page",
  description: "Update notes, dates, and attached photos for this page." %>

<div class="wrapper wrapper-content animated fadeInRight">
  <nav aria-label="breadcrumb" class="m-b-md">
    <ol class="breadcrumb">
      <li><%= link_to "Home", dashboard_path %></li>
      <li><%= link_to "Notebook", notebooks_path %></li>
      <li><%= link_to @notebook.title, notebook_path(@notebook) %></li>
      <li><%= link_to @chapter.title, notebook_chapter_path(@notebook, @chapter) %></li>
      <li><%= link_to @page.display_title, notebook_chapter_page_path(@notebook, @chapter, @page) %></li>
      <li class="active">Edit page</li>
    </ol>
  </nav>

  <%= render "form", notebook: @notebook, chapter: @chapter, page: @page %>

  <section class="ibox float-e-margins page-actions-section">
    <div class="ibox-title">
      <h5>Page actions</h5>
      <div class="ibox-tools">
        <span class="label label-default">Page <%= @page.position %></span>
      </div>
    </div>
    <div class="ibox-content collapse show">
      <p class="text-muted m-b-md">Delete this page only when you are sure its notes and attached photos are no longer needed.</p>
      <%= button_to "Delete page", notebook_chapter_page_path(@notebook, @chapter, @page),
        method: :delete,
        form: { style: "display: inline-block; margin: 0;", onsubmit: "return confirm('Delete this page?');" },
        class: "btn btn-danger btn-sm" %>
    </div>
  </section>
</div>
