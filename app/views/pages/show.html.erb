<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.schema_ready?
  voice_note_count = voice_notes_available ? @page.voice_notes.size : 0
  photo_count = @page.photos.count
  scanned_document_count = @page.scanned_documents.count
  todo_items = todo_lists_available ? @page.todo_list&.display_todo_items&.to_a || [] : []
  move_form_id = dom_id(@page, :move_form)
  overview_section_id = dom_id(@page, :overview_section)
  photos_section_id = dom_id(@page, :photos_section)
  voice_notes_section_id = dom_id(@page, :voice_notes_section)
  todo_list_section_id = dom_id(@page, :todo_list_section)
  scanned_documents_section_id = dom_id(@page, :scanned_documents_section)
  move_to_notebook_section_id = dom_id(@page, :move_to_notebook_section)
  section_shortcuts = [
    { label: "Overview", short_label: "Overview", icon: "ti-file-text", target: overview_section_id },
    { label: "Photos", short_label: "Photos", icon: "ti-photo", target: photos_section_id }
  ]
  section_shortcuts << { label: "Voice notes", short_label: "Voice", icon: "ti-microphone", target: voice_notes_section_id } if voice_notes_available
  section_shortcuts << { label: "To-do list", short_label: "To-do", icon: "ti-checkbox", target: todo_list_section_id } if todo_lists_available
  section_shortcuts << { label: "Scanned documents", short_label: "Scans", icon: "ti-scan", target: scanned_documents_section_id }
  section_shortcuts << { label: "Move to notebook", short_label: "Move", icon: "ti-arrows-transfer-up-down", target: move_to_notebook_section_id }
  todo_progress_label = if todo_lists_available && @page.todo_list&.enabled?
    "#{@page.todo_list.completed_count}/#{@page.todo_list.total_count} to-dos"
  end
  has_content = @page.plain_notes.present? || @page.photos.attached? ||
                voice_note_count.positive? || todo_items.any? || scanned_document_count.positive?
%>

<div class="wrapper wrapper-content animated fadeInRight">
  <nav class="detail-section-shortcuts" aria-label="Jump to page sections" data-controller="section-shortcuts">
    <div class="detail-section-shortcuts__rail" data-section-shortcuts-target="rail">
      <span class="detail-section-shortcuts__indicator" data-section-shortcuts-target="indicator" aria-hidden="true"></span>
      <% section_shortcuts.each_with_index do |shortcut, index| %>
        <a
          href="#<%= shortcut[:target] %>"
          class="detail-section-shortcut<%= " is-active" if index.zero? %>"
          title="<%= shortcut[:label] %>"
          aria-label="Jump to <%= shortcut[:label] %>"
          <% if index.zero? %>aria-current="location"<% end %>
          data-section-shortcuts-target="link"
          data-action="click->section-shortcuts#markActive"
        >
          <i class="ti <%= shortcut[:icon] %>" aria-hidden="true"></i>
          <span class="detail-section-shortcut__label"><%= shortcut[:short_label] %></span>
        </a>
      <% end %>
    </div>
  </nav>

  <div class="notepad-doc">
    <div class="notepad-doc__canvas">
      <header id="<%= overview_section_id %>" class="notepad-doc__header detail-section-anchor">
        <div class="notepad-doc__header-row">
          <div class="notepad-doc__header-content">
            <h1 class="notepad-doc__title"><%= @page.display_title %></h1>
            <p class="notepad-doc__date m-b-none">
              <%= @chapter.title %> · Page <%= @page.position %>
              <% if @page.captured_on.present? %>
                · <%= @page.captured_on.strftime("%A, %B %-d, %Y") %>
              <% end %>
            </p>
          </div>
        </div>

        <div class="notepad-doc__meta">
          <% if @page.plain_notes.present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-file-text" aria-hidden="true"></i> Notes
            </span>
          <% end %>
          <% if photo_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-photo" aria-hidden="true"></i>
              <%= pluralize(photo_count, "photo") %>
            </span>
          <% end %>
          <% if voice_notes_available && voice_note_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-microphone" aria-hidden="true"></i>
              <%= pluralize(voice_note_count, "voice note") %>
            </span>
          <% end %>
          <% if todo_progress_label.present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-checkbox" aria-hidden="true"></i>
              <%= todo_progress_label %>
            </span>
          <% end %>
          <% if scanned_document_count.positive? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-scan" aria-hidden="true"></i>
              <%= pluralize(scanned_document_count, "scan") %>
            </span>
          <% end %>

          <%= link_to edit_notebook_chapter_page_path(@notebook, @chapter, @page),
            class: "notepad-doc__meta-chip notepad-doc__meta-action",
            title: "Edit page",
            aria: { label: "Edit page" } do %>
            <i class="ti ti-pencil" aria-hidden="true"></i>
            Edit
          <% end %>

          <%= button_to quick_create_notebook_chapter_pages_path(@notebook, @chapter),
            method: :post,
            class: "notepad-doc__meta-chip notepad-doc__meta-action",
            form_class: "button_to d-inline-block",
            title: "Create new page",
            aria: { label: "Create new page" } do %>
            <i class="ti ti-plus" aria-hidden="true"></i>
            New page
          <% end %>

          <%= button_to notebook_chapter_page_path(@notebook, @chapter, @page),
            method: :delete,
            class: "notepad-doc__meta-chip notepad-doc__meta-action",
            form_class: "button_to d-inline-block",
            form: { onsubmit: "return confirm('Delete this page?');" },
            title: "Delete page",
            aria: { label: "Delete page" } do %>
            <i class="ti ti-trash" aria-hidden="true"></i>
            Delete
          <% end %>
        </div>
      </header>

      <div class="notepad-doc__body">
        <% if @page.plain_notes.present? %>
          <div class="notepad-doc__block notepad-doc__block--text">
            <div class="detail-notes-copy trix-content workspace-trix-content">
              <%= render "shared/rich_notes", notes: @page.notes %>
            </div>
          </div>
        <% end %>

        <div
          id="<%= photos_section_id %>"
          class="notepad-doc__block notepad-doc__block--media detail-section-anchor"
        >
          <%= form_with model: [@notebook, @chapter, @page],
            data: { photo_capture_auto_save: true, controller: "photo-capture" },
            html: { class: "d-contents" } do |form| %>
            <input
              type="file"
              accept="image/*"
              capture="environment"
              tabindex="-1"
              aria-hidden="true"
              class="photo-section-camera-input"
              data-photo-capture-target="cameraInput"
              data-action="change->photo-capture#acceptCameraCapture"
            >
            <%= render "shared/photo_capture_field",
              form:,
              field_name: :photos %>

            <div class="notepad-doc__block-header">
              <div class="notepad-doc__block-label">
                <i class="ti ti-photo" aria-hidden="true"></i>
                Photos<% if photo_count.positive? %> · <%= photo_count %><% end %>
              </div>
              <div class="notepad-doc__block-actions">
                <button
                  type="button"
                  class="btn btn-white btn-sm"
                  data-action="photo-capture#openCameraApp"
                  data-photo-capture-target="cameraToggle"
                  aria-pressed="false"
                  title="Capture photo"
                >
                  <i class="ti ti-camera" aria-hidden="true"></i><span> Capture</span>
                </button>
                <button
                  type="button"
                  class="btn btn-white btn-sm"
                  data-action="photo-capture#chooseFromGallery"
                  title="Upload photo"
                >
                  <i class="ti ti-photo-plus" aria-hidden="true"></i><span> Upload</span>
                </button>
              </div>
            </div>

            <% if @page.photos.attached? %>
              <div>
                <%= render "pages/photo_strip",
                  notebook: @notebook,
                  chapter: @chapter,
                  page: @page %>
              </div>
            <% else %>
              <p class="text-muted m-b-none" style="font-size: 0.875rem;">No photos yet — use the buttons above to capture or upload.</p>
            <% end %>
          <% end %>
        </div>

        <% if voice_notes_available %>
          <%= render "pages/voice_notes_section", notebook: @notebook, chapter: @chapter, page: @page %>
        <% end %>

        <% if todo_lists_available %>
          <%= render "pages/todo_list_section", notebook: @notebook, chapter: @chapter, page: @page %>
        <% else %>
          <%= render "pages/todo_list_unavailable_section" %>
        <% end %>

        <%= render "pages/scanned_documents_section",
          notebook: @notebook,
          chapter: @chapter,
          page: @page %>

        <% unless has_content %>
          <div class="notepad-doc__block notepad-doc__block--empty">
            <p class="text-muted m-b-none">No content yet. Use the <strong>+</strong> button below to add photos, voice notes, to-dos, or scanned documents.</p>
          </div>
        <% end %>
      </div>
    </div>

    <%= form_with model: [@notebook, @chapter, @page],
      method: :patch,
      html: { id: move_form_id, class: "d-none" } do %>
      <%# Hidden patch form used by the move section below. %>
    <% end %>

    <div id="<%= move_to_notebook_section_id %>" class="detail-section-anchor m-t-lg">
      <%= render "pages/move_to_notebook_section",
        notebook: @notebook,
        chapter: @chapter,
        page: @page,
        form_id: move_form_id,
        move_destination_notebooks: @move_destination_notebooks,
        selected_move_destination_chapter_id: @selected_move_destination_chapter_id,
        selected_move_destination_label: @selected_move_destination_label %>
    </div>
  </div>

  <%= render "pages/quick_actions",
    photos_section_id:,
    voice_notes_section_id:,
    voice_notes_enabled: voice_notes_available,
    todo_list_section_id:,
    todo_lists_enabled: todo_lists_available,
    scanned_documents_section_id: %>
</div>
