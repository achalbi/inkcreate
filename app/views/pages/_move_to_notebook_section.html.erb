<%
  move_form_id = local_assigns.fetch(:form_id)
  move_destination_notebooks = local_assigns[:move_destination_notebooks] || @move_destination_notebooks
  selected_move_destination_chapter_id = local_assigns[:selected_move_destination_chapter_id] || @selected_move_destination_chapter_id
  selected_move_destination_label = local_assigns[:selected_move_destination_label] || @selected_move_destination_label
  selected_move_destination_notebook = move_destination_notebooks.find { |notebook|
    notebook.chapters.any? { |chapter| chapter.id.to_s == selected_move_destination_chapter_id.to_s }
  }
  selected_move_destination_chapter = selected_move_destination_notebook&.chapters&.find { |chapter|
    chapter.id.to_s == selected_move_destination_chapter_id.to_s
  }
  move_modal_id = dom_id(page, :move_destination_modal)
  move_destination_input_id = "#{move_modal_id}_input"
  move_destination_display_id = "#{move_modal_id}_display"
  move_destination_data = move_destination_notebooks.map { |notebook|
    {
      notebookId: notebook.id,
      title: notebook.title,
      chapters: notebook.chapters.map { |chapter|
        {
          chapterId: chapter.id,
          notebookId: notebook.id,
          title: chapter.title,
          label: "#{notebook.title} > #{chapter.title}"
        }
      }
    }
  }
%>

<div class="row m-t-md">
  <div class="col-12">
    <div class="ibox notepad-entry-move-shell page-move-shell">
      <div class="ibox-title">
        <h5>Move page</h5>
        <div class="ibox-tools">
          <span class="label label-default">Page transfer</span>
        </div>
      </div>
      <div class="ibox-content">
        <section class="notepad-entry-move-panel">
          <% if page.errors.any? %>
            <% error_body = capture do %>
              <ul class="m-b-none m-t-sm">
                <% page.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            <% end %>
            <%= render "shared/inline_alert",
              type: :danger,
              title: "Could not move page",
              body_html: error_body %>
          <% end %>

          <div class="notepad-entry-move-panel__header">
            <div>
              <h6 class="notepad-entry-move-panel__title">Move this page into another chapter</h6>
              <p class="notepad-entry-move-panel__description">Keep the content intact while relocating this page to another notebook chapter.</p>
            </div>
          </div>

          <% if move_destination_notebooks.present? %>
            <div class="form-group">
              <%= label_tag :move_to_chapter_id, "Destination", class: "control-label" %>
              <%= hidden_field_tag :move_to_chapter_id,
                selected_move_destination_chapter_id,
                id: move_destination_input_id,
                form: move_form_id %>
              <button
                type="button"
                class="btn btn-white btn-sm notepad-entry-move-picker-button"
                data-bs-toggle="modal"
                data-bs-target="#<%= move_modal_id %>"
              >
                <span class="notepad-entry-move-picker-button__copy">
                  <span class="notepad-entry-move-picker-button__label">Selected destination</span>
                  <span id="<%= move_destination_display_id %>" class="notepad-entry-move-picker-button__value"><%= selected_move_destination_label.presence || "Choose a notebook and chapter" %></span>
                </span>
                <i class="ti ti-chevron-right" aria-hidden="true"></i>
              </button>
              <p class="help-block notepad-entry-move-panel__help">Choose a notebook in the modal, then pick a chapter and save the destination.</p>
            </div>

            <div class="workspace-form-actions notepad-entry-move-panel__actions">
              <%= button_tag "Move to notebook chapter",
                type: "submit",
                name: "intent",
                value: "move_to_notebook",
                form: move_form_id,
                class: "btn btn-white btn-sm notepad-entry-move-button",
                data: { disable_with: "Moving..." } %>
            </div>

            <div
              class="modal fade notebook-section-modal notepad-entry-move-modal"
              id="<%= move_modal_id %>"
              tabindex="-1"
              aria-labelledby="<%= "#{move_modal_id}-label" %>"
              aria-hidden="true"
            >
              <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                <div
                  class="modal-content"
                  data-controller="move-destination"
                  data-move-destination-placeholder-value="Choose a notebook and chapter"
                  data-move-destination-notebooks-value="<%= json_escape(move_destination_data.to_json) %>"
                  data-move-destination-input-id-value="<%= move_destination_input_id %>"
                  data-move-destination-display-label-id-value="<%= move_destination_display_id %>"
                >
                  <div class="modal-header notebook-section-modal__header">
                    <div>
                      <div class="notebook-section-modal__eyebrow">Move destination</div>
                      <h5 id="<%= "#{move_modal_id}-label" %>" class="modal-title notebook-section-modal__title">
                        Choose a notebook and chapter
                      </h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>

                  <div class="modal-body notebook-section-modal__body">
                    <div class="notepad-entry-move-modal__selection">
                      <span class="notepad-entry-move-modal__selection-label">Pending destination</span>
                      <span class="notepad-entry-move-modal__selection-value" data-move-destination-target="pendingLabel"><%= selected_move_destination_label.presence || "Choose a notebook and chapter" %></span>
                    </div>

                    <div class="notepad-entry-move-modal__field-stack">
                      <div class="form-group">
                        <label class="control-label" for="<%= "#{move_modal_id}_notebook_dropdown" %>">Notebook</label>
                        <div class="dropdown notepad-entry-move-modal__dropdown">
                          <button
                            id="<%= "#{move_modal_id}_notebook_dropdown" %>"
                            type="button"
                            class="btn btn-white notepad-entry-move-modal__dropdown-toggle dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                          >
                            <span data-move-destination-target="notebookButtonLabel"><%= selected_move_destination_notebook&.title.presence || "Choose a notebook" %></span>
                          </button>
                          <div
                            class="dropdown-menu w-100 notepad-entry-move-modal__dropdown-menu"
                            data-move-destination-target="notebookMenu"
                            aria-labelledby="<%= "#{move_modal_id}_notebook_dropdown" %>"
                          >
                            <% move_destination_notebooks.each do |notebook| %>
                              <% notebook_selected = notebook.id.to_s == selected_move_destination_notebook&.id.to_s %>
                              <button
                                type="button"
                                class="dropdown-item notepad-entry-move-modal__dropdown-item<%= " active" if notebook_selected %>"
                                data-action="click->move-destination#chooseNotebook"
                                data-notebook-id="<%= notebook.id %>"
                              >
                                <span class="notepad-entry-move-modal__dropdown-item-title"><%= notebook.title %></span>
                                <span class="notepad-entry-move-modal__dropdown-item-meta"><%= pluralize(notebook.chapters.size, "chapter") %></span>
                              </button>
                            <% end %>
                          </div>
                        </div>
                        <p class="help-block notepad-entry-move-modal__help">Select a notebook first to load its chapters.</p>
                      </div>

                      <div class="form-group m-b-none">
                        <label class="control-label" for="<%= "#{move_modal_id}_chapter_dropdown" %>">Chapter</label>
                        <div class="dropdown notepad-entry-move-modal__dropdown">
                          <button
                            id="<%= "#{move_modal_id}_chapter_dropdown" %>"
                            type="button"
                            class="btn btn-white notepad-entry-move-modal__dropdown-toggle dropdown-toggle"
                            data-bs-toggle="dropdown"
                            data-move-destination-target="chapterButton"
                            aria-expanded="false"
                            <%= "disabled" unless selected_move_destination_notebook.present? && selected_move_destination_notebook.chapters.any? %>
                          >
                            <span data-move-destination-target="chapterButtonLabel">
                              <%= if selected_move_destination_chapter.present?
                                    selected_move_destination_chapter.title
                                  elsif selected_move_destination_notebook.present?
                                    "Choose a chapter"
                                  else
                                    "Choose a notebook first"
                                  end %>
                            </span>
                          </button>
                          <div
                            class="dropdown-menu w-100 notepad-entry-move-modal__dropdown-menu"
                            data-move-destination-target="chapterMenu"
                            aria-labelledby="<%= "#{move_modal_id}_chapter_dropdown" %>"
                          >
                            <% if selected_move_destination_notebook.present? && selected_move_destination_notebook.chapters.any? %>
                              <% selected_move_destination_notebook.chapters.each do |chapter| %>
                                <% chapter_selected = chapter.id.to_s == selected_move_destination_chapter_id.to_s %>
                                <button
                                  type="button"
                                  class="dropdown-item notepad-entry-move-modal__dropdown-item<%= " active" if chapter_selected %>"
                                  data-action="click->move-destination#selectChapter"
                                  data-notebook-id="<%= selected_move_destination_notebook.id %>"
                                  data-chapter-id="<%= chapter.id %>"
                                >
                                  <span class="notepad-entry-move-modal__dropdown-item-title"><%= chapter.title %></span>
                                  <span class="notepad-entry-move-modal__dropdown-item-meta"><%= selected_move_destination_notebook.title %></span>
                                </button>
                              <% end %>
                            <% else %>
                              <button
                                type="button"
                                class="dropdown-item notepad-entry-move-modal__dropdown-item disabled"
                                disabled
                              >
                                <span class="notepad-entry-move-modal__dropdown-item-title">Choose a notebook first</span>
                                <span class="notepad-entry-move-modal__dropdown-item-meta">Chapter options appear after notebook selection.</span>
                              </button>
                            <% end %>
                          </div>
                        </div>
                        <p class="help-block notepad-entry-move-modal__help">Choose the chapter inside that notebook, then save the destination.</p>
                      </div>
                    </div>
                  </div>

                  <div class="modal-footer notebook-section-modal__footer">
                    <div class="notebook-section-modal__page-info">Save the destination here, then move the page from the main action below.</div>
                    <div class="notepad-entry-move-modal__footer-actions">
                      <button
                        type="button"
                        class="btn btn-primary btn-sm notepad-entry-move-modal__save-button"
                        data-move-destination-target="saveButton"
                        data-action="click->move-destination#save"
                      >
                        Save destination
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% else %>
            <%= render "shared/inline_alert",
              type: :info,
              title: "Create another chapter first",
              body: "You can move this page into another notebook chapter once one exists in your workspace." %>
          <% end %>
        </section>

        <% move_to_notepad_date = page.captured_on || Time.zone.today %>

        <hr>

        <section class="notepad-entry-move-panel">
          <div class="notepad-entry-move-panel__header">
            <div>
              <h6 class="notepad-entry-move-panel__title">Move this page into notepad</h6>
              <p class="notepad-entry-move-panel__description">Create a notepad entry dated <%= move_to_notepad_date.strftime("%b %-d, %Y") %> and keep the current notes, photos, voice notes, scans, and checklist together.</p>
            </div>
          </div>

          <div class="workspace-form-actions notepad-entry-move-panel__actions">
            <%= button_tag "Move to notepad",
              type: "submit",
              name: "intent",
              value: "move_to_notepad",
              form: move_form_id,
              class: "btn btn-white btn-sm notepad-entry-move-button",
              data: { disable_with: "Moving..." } %>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
