<%
  form = local_assigns[:form]
  auto_submit_on_save = local_assigns.fetch(:auto_submit_on_save, false)
  voice_notes = if notepad_entry.persisted? && VoiceNote.notepad_entries_supported?
    notepad_entry.voice_notes.recent_first.includes(audio_attachment: :blob)
  else
    []
  end
  recorder_mode = notepad_entry.persisted? ? :persisted : :form
  recorder_url = notepad_entry.persisted? ? notepad_entry_voice_notes_path(notepad_entry) : nil
%>

<section class="ibox">
  <div class="ibox-title">
    <div class="detail-photo-gallery-heading">
      <h5 class="detail-photo-gallery-title">Voice notes</h5>
      <span class="label label-info detail-photo-gallery-count"><%= voice_notes.size %></span>
    </div>
    <div class="ibox-tools">
      <% unless notepad_entry.persisted? %>
        <span class="label label-default">Saved with this form</span>
      <% end %>
      <%= render "shared/ibox_toggle_button", target_id: dom_id(notepad_entry, :voice_notes_content) %>
    </div>
  </div>

  <div id="<%= dom_id(notepad_entry, :voice_notes_content) %>" class="ibox-content collapse show">
    <%= render "pages/voice_note_recorder",
      form: form,
      mode: recorder_mode,
      create_url: recorder_url,
      param_key: form&.object_name || "notepad_entry",
      auto_submit_on_save: auto_submit_on_save %>

    <% if voice_notes.any? %>
      <div class="m-t-md voice-note-list-content">
        <div class="notebook-list-stack notebook-list-stack--separated">
          <% voice_notes.each do |voice_note| %>
            <%= render "shared/voice_note_list_item",
              voice_note: voice_note,
              delete_path: notepad_entry_voice_note_path(notepad_entry, voice_note),
              submit_transcript_path: submit_transcript_notepad_entry_voice_note_path(notepad_entry, voice_note) %>
          <% end %>
        </div>
      </div>
    <% elsif !form.present? %>
      <div class="m-t-md">
        <%= render "shared/empty_state", title: "No voice notes yet", description: "Record an audio note to capture spoken context for this daily page." %>
      </div>
    <% end %>
  </div>
</section>
