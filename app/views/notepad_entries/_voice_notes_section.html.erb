<%
  form = local_assigns[:form]
  auto_submit_on_save = local_assigns.fetch(:auto_submit_on_save, false)
  voice_notes = if notepad_entry.persisted? && VoiceNote.notepad_entries_supported?
    notepad_entry.voice_notes.recent_first.includes(audio_attachment: :blob)
  else
    []
  end
  recorder_mode = notepad_entry.persisted? ? :persisted : :form
  recorder_url = notepad_entry.persisted? ? notepad_entry_voice_notes_path(notepad_entry) : nil
  content_id = dom_id(notepad_entry, :voice_notes_content)
  param_key = form&.object_name || "notepad_entry"
%>

<section
  id="<%= dom_id(notepad_entry, :voice_notes_section) %>"
  class="ibox detail-section-anchor"
  data-controller="voice-recorder voice-note-list"
  data-voice-recorder-auto-submit-on-save-value="<%= auto_submit_on_save %>"
  data-voice-recorder-mode-value="<%= recorder_mode %>"
  data-voice-recorder-max-duration-seconds-value="<%= VoiceNote::MAX_DURATION_SECONDS %>"
  data-voice-recorder-param-key-value="<%= param_key %>"
  <% if recorder_url.present? %>
    data-voice-recorder-create-url-value="<%= recorder_url %>"
  <% end %>
>
  <div class="ibox-title">
    <div class="detail-photo-gallery-heading">
      <h5 class="detail-photo-gallery-title">Voice notes</h5>
      <span class="label label-info detail-photo-gallery-count"><%= voice_notes.size %></span>
    </div>
    <div class="ibox-tools d-flex align-items-center gap-2">
      <% if voice_notes.any? %>
        <button
          type="button"
          class="btn btn-white btn-sm btn-icon voice-note-list__toggle"
          data-voice-note-list-target="toggle"
          data-action="voice-note-list#toggle"
          aria-expanded="false"
          aria-label="Expand voice note details"
          title="Expand voice note details"
        >
          <i class="ti ti-chevron-right" aria-hidden="true"></i>
        </button>
      <% end %>
      <button type="button" class="btn btn-primary btn-sm" data-voice-recorder-target="startButton" data-action="voice-recorder#start">
        <i class="ti ti-microphone" aria-hidden="true"></i>
        <span>Record</span>
      </button>
      <%= render "shared/ibox_toggle_button", target_id: content_id %>
    </div>
  </div>

  <div id="<%= content_id %>" class="ibox-content collapse show" data-voice-recorder-target="panel">
    <div class="voice-note-recorder">
      <%= render "pages/voice_note_recorder_content",
        recorder_form: form,
        recorder_mode: recorder_mode,
        show_start_button: false %>
    </div>

    <% if voice_notes.any? %>
      <div class="m-t-md voice-note-list-content">
        <div class="notebook-list-stack notebook-list-stack--separated">
          <% voice_notes.each do |voice_note| %>
            <%= render "shared/voice_note_list_item",
              voice_note: voice_note,
              delete_path: notepad_entry_voice_note_path(notepad_entry, voice_note) %>
          <% end %>
        </div>
      </div>
    <% elsif !form.present? %>
      <div class="m-t-md">
        <%= render "shared/empty_state", title: "No voice notes yet", description: "Record an audio note to capture spoken context for this daily page." %>
      </div>
    <% end %>
  </div>
</section>
