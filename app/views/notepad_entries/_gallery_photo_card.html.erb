<article class="notepad-gallery-card">
  <div class="notepad-gallery-card__media thumbnail">
    <%= render "shared/photo_lightbox",
      photo: item[:photo],
      alt: item[:entry].display_title,
      image_style: "width: 100%; height: 220px; object-fit: cover;" %>
  </div>

  <div class="notepad-gallery-card__body">
    <%= link_to item[:entry].display_title, notepad_entry_path(item[:entry]), class: "notepad-gallery-card__title" %>
    <div class="notepad-gallery-card__meta">
      <span><%= item[:entry].entry_date.strftime("%b %-d, %Y") %></span>
      <span>Updated <%= time_ago_in_words(item[:entry].updated_at) %> ago</span>
    </div>
  </div>
</article>
