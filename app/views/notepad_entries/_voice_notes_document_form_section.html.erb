<section
  id="<%= dom_id(notepad_entry, :voice_notes_section) %>"
  class="notepad-doc__block notepad-doc__block--voice notepad-doc-edit__section detail-section-anchor"
  data-controller="voice-recorder"
  data-voice-recorder-auto-submit-on-save-value="false"
  data-voice-recorder-mode-value="form"
  data-voice-recorder-max-duration-seconds-value="<%= VoiceNote::MAX_DURATION_SECONDS %>"
  data-voice-recorder-param-key-value="<%= form.object_name %>"
>
  <div class="notepad-doc__block-header">
    <div class="notepad-doc__block-label">
      <i class="ti ti-microphone" aria-hidden="true"></i>
      Voice notes
    </div>
    <div class="notepad-doc__block-actions">
      <button
        type="button"
        class="btn btn-white btn-sm"
        data-voice-recorder-target="startButton"
        data-action="voice-recorder#start"
      >
        <i class="ti ti-microphone" aria-hidden="true"></i><span> Record</span>
      </button>
    </div>
  </div>

  <div data-voice-recorder-target="panel">
    <div class="voice-note-recorder">
      <%= render "pages/voice_note_recorder_content",
        recorder_form: form,
        recorder_mode: :form,
        show_start_button: false %>
    </div>
  </div>
</section>
