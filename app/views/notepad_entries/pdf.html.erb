<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.notepad_entries_supported?
  voice_notes = voice_notes_available ? @notepad_entry.voice_notes.recent_first.includes(audio_attachment: :blob) : []
  voice_note_count = voice_notes.size
  docs = @notepad_entry.scanned_documents.with_attached_enhanced_image.with_attached_document_pdf.recent_first
  todo_list = todo_lists_available ? @notepad_entry.todo_list : nil
  todo_items = todo_list ? todo_list.display_todo_items.to_a : []
  completed_count = todo_items.count(&:completed?)
  photo_count = @notepad_entry.photos.count
  scanned_document_count = docs.size
  autoprint = ActiveModel::Type::Boolean.new.cast(params[:autoprint])
  contact_section_id = dom_id(@notepad_entry, :contact_section)
  location_section_id = dom_id(@notepad_entry, :location_section)
  has_content = @notepad_entry.location_present? || @notepad_entry.contact_present? || @notepad_entry.plain_notes.present? || @notepad_entry.photos.attached? ||
                voice_note_count > 0 || todo_items.any? || docs.any?
%>
<!DOCTYPE html>
<html lang="en" data-export-format="pdf">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= @notepad_entry.display_title %> PDF export</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,600;0,700;1,400&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.35.0/dist/tabler-icons.min.css" rel="stylesheet">
    <link href="https://unpkg.com/trix@2.1.18/dist/trix.css" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/inapp/inapp_workspace.css") %>" rel="stylesheet">
    <link href="<%= versioned_public_asset_path("/inapp/notepad_pdf_export.css") %>" rel="stylesheet">
    <script src="<%= versioned_public_asset_path("/scripts/notepad_pdf_export.js") %>" defer></script>
  </head>
  <body
    class="workspace-body workspace-body--no-sidebar workspace-body--pdf-export"
    data-notepad-pdf-export
    data-autoprint="<%= autoprint %>"
  >
    <div class="notepad-pdf-toolbar" aria-label="PDF export actions">
      <%= link_to "Back to page", notepad_entry_path(@notepad_entry), class: "notepad-pdf-toolbar__link" %>
      <div class="notepad-pdf-toolbar__actions">
        <span class="notepad-pdf-toolbar__hint">This export mirrors the notepad HTML view. Use Print and choose Save as PDF.</span>
        <button type="button" class="notepad-pdf-toolbar__button" data-notepad-pdf-print>Print / Save as PDF</button>
      </div>
    </div>

    <main id="content" class="content notepad-pdf-main">
      <div class="container-fluid px-3 px-lg-4">
        <div class="wrapper wrapper-content">
          <div class="notepad-doc">
            <div class="notepad-doc__canvas">
              <header class="notepad-doc__header">
                <div class="notepad-doc__header-row">
                  <div class="notepad-doc__header-content">
                    <h1 class="notepad-doc__title"><%= @notepad_entry.display_title %></h1>
                    <p class="notepad-doc__date m-b-none"><%= @notepad_entry.entry_date.strftime("%A, %B %-d, %Y") %></p>
                  </div>
                </div>

                <div class="notepad-doc__meta">
                  <% if @notepad_entry.plain_notes.present? %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-file-text" aria-hidden="true"></i> Notes
                    </span>
                  <% end %>
                  <% if @notepad_entry.location_present? %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-map-pin" aria-hidden="true"></i>
                      <%= @notepad_entry.location_count_label %>
                    </span>
                  <% end %>
                  <% if @notepad_entry.contact_present? %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-address-book" aria-hidden="true"></i>
                      <%= @notepad_entry.contact_count_label %>
                    </span>
                  <% end %>
                  <% if photo_count > 0 %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-photo" aria-hidden="true"></i>
                      <%= pluralize(photo_count, "photo") %>
                    </span>
                  <% end %>
                  <% if voice_note_count > 0 %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-microphone" aria-hidden="true"></i>
                      <%= pluralize(voice_note_count, "voice note") %>
                    </span>
                  <% end %>
                  <% if todo_items.any? %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-checkbox" aria-hidden="true"></i>
                      <%= completed_count %>/<%= todo_items.size %>
                    </span>
                  <% end %>
                  <% if scanned_document_count > 0 %>
                    <span class="notepad-doc__meta-chip">
                      <i class="ti ti-scan" aria-hidden="true"></i>
                      <%= pluralize(scanned_document_count, "scan") %>
                    </span>
                  <% end %>
                </div>
              </header>

              <div class="notepad-doc__body">
                <% if @notepad_entry.plain_notes.present? %>
                  <div class="notepad-doc__block notepad-doc__block--text">
                    <div class="detail-notes-copy trix-content workspace-trix-content">
                      <%= render "shared/rich_notes", notes: @notepad_entry.notes %>
                    </div>
                  </div>
                <% end %>

                <div class="notepad-doc__block notepad-doc__block--media">
                  <div class="notepad-doc__block-header">
                    <div class="notepad-doc__block-label">
                      <i class="ti ti-photo" aria-hidden="true"></i>
                      Photos<% if photo_count > 0 %> · <%= photo_count %><% end %>
                    </div>
                  </div>

                  <% if @notepad_entry.photos.attached? %>
                    <%= render "notepad_entries/photo_strip", notepad_entry: @notepad_entry, export_mode: true %>
                  <% else %>
                    <p class="text-muted m-b-none" style="font-size: 0.875rem;">No photos yet.</p>
                  <% end %>
                </div>

                <% if voice_notes_available %>
                  <%= render "notepad_entries/voice_notes_document_section",
                    notepad_entry: @notepad_entry,
                    pdf_export_mode: true %>
                <% end %>

                <% if todo_lists_available %>
                  <%= render "notepad_entries/todo_list_document_section",
                    notepad_entry: @notepad_entry,
                    pdf_export_mode: true %>
                <% end %>

                <%= render "notepad_entries/scanned_documents_document_section",
                  notepad_entry: @notepad_entry,
                  pdf_export_mode: true %>

                <% if @notepad_entry.contact_present? %>
                  <%= render "pages/contact_section", record: @notepad_entry, section_id: contact_section_id %>
                <% end %>

                <% if @notepad_entry.location_present? %>
                  <%= render "pages/location_section", record: @notepad_entry, section_id: location_section_id %>
                <% end %>

                <% unless has_content %>
                  <div class="notepad-doc__block notepad-doc__block--empty">
                    <p class="text-muted m-b-none">No content yet on this page.</p>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
