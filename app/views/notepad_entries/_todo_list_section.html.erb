<%
  todo_list = notepad_entry.todo_list
  todo_items = todo_list&.display_todo_items&.to_a || []
  reminders_available = Reminder.schema_ready?
  completed_count = todo_items.count(&:completed?)
  progress_percent = todo_items.any? ? ((completed_count.to_f / todo_items.size) * 100).round : 0
  initial_filter = todo_list&.hide_completed? ? "active" : "all"
%>

<section
  id="<%= dom_id(notepad_entry, :todo_list_section) %>"
  class="ibox"
  data-controller="todo-list"
  data-todo-list-mode-value="persisted"
  data-todo-list-filter-value="<%= initial_filter %>"
  data-todo-list-storage-key-value="<%= dom_id(notepad_entry, :todo_list_section) %>"
>
  <div class="ibox-title">
    <div class="detail-photo-gallery-heading">
      <h5 class="detail-photo-gallery-title">To-do list</h5>
      <span class="label label-info detail-photo-gallery-count"><%= todo_items.size %></span>
    </div>
    <div class="ibox-tools d-flex align-items-center gap-2">
      <% if todo_list&.enabled? && todo_items.any? %>
        <span class="label label-default"><%= todo_list.progress_label %></span>
      <% end %>
      <%= render "shared/ibox_toggle_button", target_id: dom_id(notepad_entry, :todo_list_content) %>
    </div>
  </div>

  <div id="<%= dom_id(notepad_entry, :todo_list_content) %>" class="ibox-content collapse show">
    <% if todo_list.blank? || !todo_list.enabled? %>
      <div class="vstack gap-3">
        <%= render "shared/empty_state", title: "To-do list disabled", description: "Enable a checklist on this page to track action items and attach reminders." %>

        <form action="<%= notepad_entry_todo_list_path(notepad_entry) %>" method="post" data-action="submit->todo-list#submit">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <input type="hidden" name="todo_list[enabled]" value="true">
          <button type="submit" class="btn btn-primary">Enable to-do list</button>
        </form>
      </div>
    <% else %>
      <div class="todo-list-section__utilities">
        <div class="todo-list-section__hint">Drag to reorder. Tap the circle to complete.</div>
      </div>

      <form action="<%= notepad_entry_todo_items_path(notepad_entry) %>" method="post" data-action="submit->todo-list#submit" class="todo-list-composer todo-list-composer--prompt">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="todo-list-composer__field">
          <textarea name="todo_item[content]" class="form-control todo-list-composer__input" placeholder="What needs to be done?" aria-label="Add a to-do item" rows="1" data-action="input->todo-list#resizeTextarea"></textarea>
        </div>
        <button type="submit" class="btn btn-primary todo-list-composer__submit todo-list-composer__submit--icon" aria-label="Add to-do item">
          <i class="ti ti-arrow-right" aria-hidden="true"></i>
        </button>
      </form>

      <div class="todo-list-filters" role="toolbar" aria-label="To-do list filters">
        <div class="todo-list-filters__group" role="tablist" aria-label="Filter to-do items">
          <button type="button" class="todo-list-filters__button <%= "is-active" if initial_filter == "all" %>" data-action="todo-list#setFilter" data-todo-list-filter-param="all" data-filter="all" data-todo-list-target="filterButton" aria-pressed="<%= initial_filter == "all" %>">All</button>
          <button type="button" class="todo-list-filters__button <%= "is-active" if initial_filter == "active" %>" data-action="todo-list#setFilter" data-todo-list-filter-param="active" data-filter="active" data-todo-list-target="filterButton" aria-pressed="<%= initial_filter == "active" %>">Active</button>
          <button type="button" class="todo-list-filters__button <%= "is-active" if initial_filter == "done" %>" data-action="todo-list#setFilter" data-todo-list-filter-param="done" data-filter="done" data-todo-list-target="filterButton" aria-pressed="<%= initial_filter == "done" %>">Done</button>
        </div>
      </div>

      <div class="todo-list-progress" aria-label="Checklist progress">
        <div class="todo-list-progress__track">
          <span class="todo-list-progress__value" style="width: <%= progress_percent %>%"></span>
        </div>
        <span class="todo-list-progress__summary"><%= completed_count %> of <%= todo_items.size %></span>
      </div>

      <div class="todo-list-items" data-todo-list-target="items">
        <% todo_items.each_with_index do |todo_item, index| %>
          <% reminder_modal_id = dom_id(todo_item, :reminder_modal) %>
          <article
            class="todo-list-item <%= "is-completed" if todo_item.completed? %> <%= "has-reminder" if todo_item.reminder.present? %>"
            draggable="true"
            data-item-id="<%= todo_item.id %>"
            data-position="<%= index + 1 %>"
            data-reorder-url="<%= reorder_notepad_entry_todo_item_path(notepad_entry, todo_item) %>"
            data-action="dragstart->todo-list#dragStart dragover->todo-list#dragOver drop->todo-list#drop dragend->todo-list#dragEnd"
          >
            <div class="todo-list-item__header">
              <div class="todo-list-item__lead">
                <form action="<%= toggle_notepad_entry_todo_item_path(notepad_entry, todo_item) %>" method="post" data-action="submit->todo-list#submit" class="todo-list-item__toggle-form">
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <input type="hidden" name="_method" value="patch">
                  <button type="submit" class="btn btn-white btn-sm todo-list-item__check <%= "is-completed" if todo_item.completed? %>" aria-label="<%= todo_item.completed? ? "Mark incomplete" : "Mark complete" %>">
                    <span class="todo-list-item__check-indicator" aria-hidden="true"></span>
                  </button>
                </form>

                <form action="<%= notepad_entry_todo_item_path(notepad_entry, todo_item) %>" method="post" data-action="submit->todo-list#submit" class="todo-list-item__edit">
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <input type="hidden" name="_method" value="patch">
                  <textarea
                    name="todo_item[content]"
                    class="form-control todo-list-item__input"
                    aria-label="To-do item text"
                    title="<%= todo_item.content %>"
                    rows="1"
                    data-initial-value="<%= todo_item.content %>"
                    data-action="input->todo-list#resizeTextarea keydown->todo-list#handleEditKeydown blur->todo-list#autosave"
                  ><%= todo_item.content %></textarea>
                </form>
              </div>

            </div>

            <div class="todo-list-item__meta">
              <% if reminders_available %>
                <% if todo_item.reminder.present? %>
                  <div class="todo-list-item__reminder todo-list-item__reminder--scheduled">
                    <i class="ti ti-bell" aria-hidden="true"></i>
                    <span class="todo-list-item__reminder-summary"><%= todo_item.reminder.fire_at.in_time_zone.strftime("%b %-d · %-I:%M %p") %></span>
                  </div>
                <% else %>
                  <div class="todo-list-item__reminder todo-list-item__reminder--empty">
                    <i class="ti ti-bell-off" aria-hidden="true"></i>
                    <span>No reminder</span>
                  </div>
                <% end %>
              <% else %>
                <div class="todo-list-item__meta-spacer" aria-hidden="true"></div>
              <% end %>

              <div class="todo-list-item__actions">
                <% if reminders_available %>
                  <button
                    type="button"
                    class="btn btn-white btn-sm btn-icon todo-list-item__action-button todo-list-item__reminder-toggle"
                    data-bs-toggle="modal"
                    data-bs-target="#<%= reminder_modal_id %>"
                    aria-controls="<%= reminder_modal_id %>"
                    aria-haspopup="dialog"
                    aria-label="<%= todo_item.reminder.present? ? "Edit reminder" : "Add reminder" %>"
                    title="<%= todo_item.reminder.present? ? "Edit reminder" : "Add reminder" %>"
                  >
                    <i class="ti <%= todo_item.reminder.present? ? "ti-bell-ringing" : "ti-bell" %>" aria-hidden="true"></i>
                  </button>
                <% end %>

                <form action="<%= notepad_entry_todo_item_path(notepad_entry, todo_item) %>" method="post" class="todo-list-item__delete-form">
                  <button
                    type="button"
                    class="btn btn-white btn-sm btn-icon todo-list-item__action-button todo-list-item__delete-button"
                    aria-label="Delete to-do item"
                    data-action="click->todo-list#confirmDelete"
                    data-todo-list-delete-url="<%= notepad_entry_todo_item_path(notepad_entry, todo_item) %>"
                    data-todo-list-item-content="<%= todo_item.content %>"
                  >
                    <i class="ti ti-trash" aria-hidden="true"></i>
                  </button>
                </form>

                <button type="button" class="btn btn-white btn-sm btn-icon todo-list-item__action-button todo-list-item__handle" aria-label="Reorder item">
                  <i class="ti ti-grip-vertical" aria-hidden="true"></i>
                </button>
              </div>
            </div>

            <% if reminders_available %>
              <%= render "shared/todo_item_reminder_modal",
                modal_id: reminder_modal_id,
                todo_item: todo_item,
                reminder: todo_item.reminder || current_user.reminders.new(title: todo_item.content) %>
            <% end %>
          </article>
        <% end %>
      </div>

      <div class="todo-list-empty" data-todo-list-target="filterEmpty" <%= "hidden" if todo_items.any? %>>
        Add your first item to get started.
      </div>
    <% end %>

    <%= render "shared/todo_item_delete_confirm_modal",
      modal_id: dom_id(notepad_entry, :todo_item_delete_confirm_modal),
      form_id: dom_id(notepad_entry, :todo_item_delete_confirm_form) %>
  </div>
</section>
