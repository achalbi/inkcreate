<article class="notebook-list-card">
  <%= link_to notepad_entry_path(entry), class: "notebook-list-card__body", aria: { label: "Open #{entry.display_title}" } do %>
    <div class="notebook-list-card__content">
      <div class="notebook-list-card__main">
        <div class="notebook-list-card__header">
          <h6 class="notebook-list-card__title"><%= entry.display_title %></h6>

          <div class="notebook-list-card__header-tools">
            <span class="label label-info notebook-list-card__status"><%= pluralize(entry.photos.count, "photo") %></span>
          </div>
        </div>

        <p class="notebook-list-card__description"><%= entry.notes.to_s.truncate(140).presence || "No notes yet." %></p>

        <div class="notebook-list-card__meta">
          <span class="notebook-list-card__meta-item">Stored <strong><%= entry.entry_date.strftime("%b %-d, %Y") %></strong></span>
          <span class="notebook-list-card__meta-item">Updated <%= time_ago_in_words(entry.updated_at) %> ago</span>
        </div>
      </div>

      <% if entry.photos.attached? %>
        <div class="notebook-list-card__preview">
          <%= image_tag entry.photos.first, class: "notebook-list-card__preview-image", alt: entry.display_title %>
        </div>
      <% end %>
    </div>
  <% end %>
</article>
