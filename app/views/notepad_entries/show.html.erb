<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.notepad_entries_supported?
  voice_note_count = voice_notes_available ? @notepad_entry.voice_notes.size : 0
  scanned_document_count = @notepad_entry.scanned_documents.size
  quick_edit_modal_id = dom_id(@notepad_entry, :quick_edit_modal)
  overview_section_id = dom_id(@notepad_entry, :overview_section)
  photos_section_id = dom_id(@notepad_entry, :photos_section)
  voice_notes_section_id = dom_id(@notepad_entry, :voice_notes_section)
  todo_list_section_id = dom_id(@notepad_entry, :todo_list_section)
  scanned_documents_section_id = dom_id(@notepad_entry, :scanned_documents_section)
  move_to_notebook_section_id = dom_id(@notepad_entry, :move_to_notebook_section)
  move_form_id = dom_id(@notepad_entry, :move_form)
  section_shortcuts = [
    { label: "Overview", short_label: "Overview", icon: "ti-file-text", target: overview_section_id },
    { label: "Photos", short_label: "Photos", icon: "ti-photo", target: photos_section_id }
  ]
  section_shortcuts << { label: "Voice notes", short_label: "Voice", icon: "ti-microphone", target: voice_notes_section_id } if voice_notes_available
  section_shortcuts << { label: "To-do list", short_label: "To-do", icon: "ti-checkbox", target: todo_list_section_id } if todo_lists_available
  section_shortcuts << { label: "Scanned documents", short_label: "Scans", icon: "ti-scan", target: scanned_documents_section_id }
  section_shortcuts << { label: "Move to notebook", short_label: "Move", icon: "ti-arrows-transfer-up-down", target: move_to_notebook_section_id }
  todo_progress_label = if todo_lists_available && @notepad_entry.todo_list&.enabled?
    "#{@notepad_entry.todo_list.completed_count}/#{@notepad_entry.todo_list.total_count} to-dos"
  end
%>

<div class="wrapper wrapper-content animated fadeInRight">
  <!-- <%= render "shared/workspace_breadcrumbs",
    items: [["Home", dashboard_path], ["Notepad", notepad_entries_path], @notepad_entry.display_title] %> --> 

  <nav class="detail-section-shortcuts" aria-label="Jump to daily page sections" data-controller="section-shortcuts">
    <div class="detail-section-shortcuts__rail" data-section-shortcuts-target="rail">
      <span class="detail-section-shortcuts__indicator" data-section-shortcuts-target="indicator" aria-hidden="true"></span>
      <% section_shortcuts.each_with_index do |shortcut, index| %>
        <a
          href="#<%= shortcut[:target] %>"
          class="detail-section-shortcut<%= " is-active" if index.zero? %>"
          title="<%= shortcut[:label] %>"
          aria-label="Jump to <%= shortcut[:label] %>"
          <% if index.zero? %>aria-current="location"<% end %>
          data-section-shortcuts-target="link"
          data-action="click->section-shortcuts#markActive"
        >
          <i class="ti <%= shortcut[:icon] %>" aria-hidden="true"></i>
          <span class="detail-section-shortcut__label"><%= shortcut[:short_label] %></span>
        </a>
      <% end %>
    </div>
  </nav>

  <section id="<%= overview_section_id %>" class="ibox float-e-margins detail-section-anchor">
    <div class="ibox-title">
      <h5>Page overview</h5>
      <div class="ibox-tools">
        <span class="label label-info">Daily page</span>
        <button
          type="button"
          class="btn btn-sm btn-icon notebook-overview-edit-button"
          title="Edit page"
          aria-label="Edit page"
          data-bs-toggle="modal"
          data-bs-target="#<%= quick_edit_modal_id %>"
        >
          <i class="ti ti-edit" aria-hidden="true"></i>
        </button>
        <%= render "shared/ibox_toggle_button", target_id: dom_id(@notepad_entry, :overview_content) %>
      </div>
    </div>
    <div id="<%= dom_id(@notepad_entry, :overview_content) %>" class="ibox-content collapse show">
      <div class="row">
        <div class="col-sm-8 detail-overview-stack">
          <h2 class="m-t-none"><%= @notepad_entry.display_title %></h2>
          <% if @notepad_entry.plain_notes.present? %>
            <div class="detail-overview-notes detail-notes-copy trix-content workspace-trix-content"><%= render "shared/rich_notes", notes: @notepad_entry.notes %></div>
          <% else %>
            <p class="detail-overview-notes detail-overview-notes--empty">No notes added yet.</p>
          <% end %>
          <p class="m-b-none detail-overview-meta">
            <span class="label label-default"><%= pluralize(@notepad_entry.photos.count, "photo") %></span>
            <% if voice_notes_available %>
              <span class="label label-default"><%= pluralize(voice_note_count, "voice note") %></span>
            <% end %>
            <span class="label label-default"><%= pluralize(scanned_document_count, "scanned document") %></span>
            <% if todo_progress_label.present? %>
              <span class="label label-default"><%= todo_progress_label %></span>
            <% end %>
            <span class="label label-info"><%= @notepad_entry.entry_date.strftime("%b %-d, %Y") %></span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="row notes-gallery-row">
    <div id="<%= photos_section_id %>" class="col-12 detail-section-anchor">
      <div class="ibox">
        <%= form_with model: @notepad_entry,
          data: { photo_capture_auto_save: true, controller: "photo-capture" },
          html: { class: "detail-photo-gallery-actions-form" } do |form| %>
          <%= render "shared/photo_gallery_actions",
            form:,
            tips_target_id: dom_id(@notepad_entry, :gallery_capture_tips),
            render_buttons: false,
            render_field: false %>

          <div class="ibox-title">
            <div class="detail-photo-gallery-heading">
              <h5 class="detail-photo-gallery-title">Photo gallery</h5>
              <span class="label label-info detail-photo-gallery-count"><%= @notepad_entry.photos.count %></span>
            </div>
            <div class="ibox-tools d-flex align-items-center gap-2">
              <button
                type="button"
                class="btn btn-white btn-sm btn-icon photo-section-info-button"
                data-bs-toggle="collapse"
                data-bs-target="#<%= dom_id(@notepad_entry, :gallery_capture_tips) %>"
                aria-expanded="false"
                aria-controls="<%= dom_id(@notepad_entry, :gallery_capture_tips) %>"
                title="Capture tips"
                aria-label="Capture tips"
              >
                <i class="ti ti-info-circle" aria-hidden="true"></i>
              </button>
              <%= render "shared/ibox_toggle_button", target_id: dom_id(@notepad_entry, :gallery_content) %>
            </div>
          </div>
          <div id="<%= dom_id(@notepad_entry, :gallery_content) %>" class="ibox-content collapse show">
            <div class="ibox-content__inner detail-photo-gallery-content-inner">
              <%= render "shared/photo_gallery_actions",
                form:,
                tips_target_id: dom_id(@notepad_entry, :gallery_capture_tips),
                hint_text: "Use these buttons to capture a photo or upload one from the gallery.",
                include_camera_input: false,
                render_info_button: false %>

              <% if @notepad_entry.photos.attached? %>
                <div class="detail-photo-grid detail-photo-grid--gallery">
                  <% @notepad_entry.photos.attachments.sort_by(&:created_at).reverse_each do |attachment| %>
                    <div class="detail-photo-grid__item">
                      <div class="thumbnail">
                        <%= render "shared/photo_lightbox",
                          photo: attachment,
                          alt: @notepad_entry.display_title,
                          image_style: "width: 100%; height: 240px; object-fit: cover;",
                          removal_path: photo_notepad_entry_path(@notepad_entry, attachment),
                          removal_message: "This photo will be removed from the daily page." %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <%= render "shared/empty_state", title: "No photos yet", description: "Upload one or more photos to keep this daily page visually complete." %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <% if voice_notes_available %>
      <div class="col-12">
        <%= render "notepad_entries/voice_notes_section", notepad_entry: @notepad_entry %>
      </div>
    <% end %>

    <% if todo_lists_available %>
      <div class="col-12">
        <%= render "notepad_entries/todo_list_section", notepad_entry: @notepad_entry %>
      </div>
    <% else %>
      <div class="col-12">
        <%= render "pages/todo_list_unavailable_section" %>
      </div>
    <% end %>

    <div class="col-12 notepad-entry-scanned-documents-column">
      <%= render "notepad_entries/scanned_documents_section", notepad_entry: @notepad_entry %>
    </div>
  </section>

  <%= form_with model: @notepad_entry, html: { id: move_form_id, class: "d-none" } do |form| %>
    <%= form.hidden_field :title, value: @notepad_entry.title %>
    <%= form.hidden_field :notes, value: @notepad_entry.notes.to_s %>
    <%= form.hidden_field :entry_date, value: @notepad_entry.entry_date %>
  <% end %>

  <div id="<%= move_to_notebook_section_id %>" class="detail-section-anchor">
    <%= render "notepad_entries/move_to_notebook_section",
      notepad_entry: @notepad_entry,
      form_id: move_form_id,
      move_destination_notebooks: @move_destination_notebooks,
      selected_move_destination_chapter_id: @selected_move_destination_chapter_id,
      selected_move_destination_label: @selected_move_destination_label %>
  </div>
</div>

<%= render "notepad_entries/quick_edit_modal", notepad_entry: @notepad_entry, open: @show_quick_edit_modal == true %>
