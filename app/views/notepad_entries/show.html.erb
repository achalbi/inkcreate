<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.notepad_entries_supported?
  voice_notes = voice_notes_available ? @notepad_entry.voice_notes.recent_first.includes(audio_attachment: :blob) : []
  voice_note_count = voice_notes.size
  docs = @notepad_entry.scanned_documents.with_attached_enhanced_image.with_attached_document_pdf.recent_first
  todo_list = todo_lists_available ? @notepad_entry.todo_list : nil
  todo_items = todo_list ? todo_list.display_todo_items.to_a : []
  completed_count = todo_items.count(&:completed?)
  photo_count = @notepad_entry.photos.count
  scanned_document_count = docs.size
  quick_edit_modal_id = dom_id(@notepad_entry, :quick_edit_modal)
  scan_capture_tips_id = dom_id(@notepad_entry, :scan_capture_tips)
  overview_section_id = dom_id(@notepad_entry, :overview_section)
  photos_section_id = dom_id(@notepad_entry, :photos_section)
  voice_notes_section_id = dom_id(@notepad_entry, :voice_notes_section)
  todo_list_section_id = dom_id(@notepad_entry, :todo_list_section)
  scanned_documents_section_id = dom_id(@notepad_entry, :scanned_documents_section)
  contact_section_id = dom_id(@notepad_entry, :contact_section)
  contact_add_button_id = dom_id(@notepad_entry, :contact_add_button)
  location_section_id = dom_id(@notepad_entry, :location_section)
  location_input_id = dom_id(@notepad_entry, :location_search_input)
  merge_section_id = dom_id(@notepad_entry, :merge_section)
  move_form_id = dom_id(@notepad_entry, :move_form)
  contact_form_id = dom_id(@notepad_entry, :contact_form)
  location_form_id = dom_id(@notepad_entry, :location_form)
  move_to_notebook_section_id = dom_id(@notepad_entry, :move_to_notebook_section)
  section_shortcuts = [
    { label: "Overview", short_label: "Overview", icon: "ti-file-text", target: overview_section_id },
    { label: "Photos", short_label: "Photos", icon: "ti-photo", target: photos_section_id }
  ]
  section_shortcuts << { label: "Voice notes", short_label: "Voice", icon: "ti-microphone", target: voice_notes_section_id } if voice_notes_available
  section_shortcuts << { label: "To-do list", short_label: "To-do", icon: "ti-checkbox", target: todo_list_section_id } if todo_lists_available
  section_shortcuts << { label: "Scanned documents", short_label: "Scans", icon: "ti-scan", target: scanned_documents_section_id }
  section_shortcuts << { label: "Contacts", short_label: "Contacts", icon: "ti-address-book", target: contact_section_id }
  section_shortcuts << { label: "Location", short_label: "Location", icon: "ti-map-pin", target: location_section_id }
  has_content = @notepad_entry.location_present? || @notepad_entry.contact_present? || @notepad_entry.plain_notes.present? || @notepad_entry.photos.attached? ||
                voice_note_count > 0 || todo_items.any? || docs.any?
%>

<div class="wrapper wrapper-content animated fadeInRight">
  <nav class="detail-section-shortcuts" aria-label="Jump to daily page sections" data-controller="section-shortcuts">
    <div class="detail-section-shortcuts__rail" data-section-shortcuts-target="rail">
      <span class="detail-section-shortcuts__indicator" data-section-shortcuts-target="indicator" aria-hidden="true"></span>
      <% section_shortcuts.each_with_index do |shortcut, index| %>
        <a
          href="#<%= shortcut[:target] %>"
          class="detail-section-shortcut<%= " is-active" if index.zero? %>"
          title="<%= shortcut[:label] %>"
          aria-label="Jump to <%= shortcut[:label] %>"
          <% if index.zero? %>aria-current="location"<% end %>
          data-section-shortcuts-target="link"
          data-action="click->section-shortcuts#markActive"
        >
          <i class="ti <%= shortcut[:icon] %>" aria-hidden="true"></i>
          <span class="detail-section-shortcut__label"><%= shortcut[:short_label] %></span>
        </a>
      <% end %>
    </div>
  </nav>

  <div class="notepad-doc">
    <%# ── Document canvas ─────────────────────────── %>
    <div class="notepad-doc__canvas">

      <%# ── Document header ────────────────────────── %>
      <header id="<%= overview_section_id %>" class="notepad-doc__header detail-section-anchor">
        <div class="notepad-doc__header-row">
          <div class="notepad-doc__header-content">
            <h1 class="notepad-doc__title"><%= @notepad_entry.display_title %></h1>
            <p class="notepad-doc__date m-b-none"><%= @notepad_entry.entry_date.strftime("%A, %B %-d, %Y") %></p>
          </div>
        </div>

        <div class="notepad-doc__meta">
          <% if @notepad_entry.plain_notes.present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-file-text" aria-hidden="true"></i> Notes
            </span>
          <% end %>
          <% if @notepad_entry.location_present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-map-pin" aria-hidden="true"></i>
              <%= @notepad_entry.location_count_label %>
            </span>
          <% end %>
          <% if @notepad_entry.contact_present? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-address-book" aria-hidden="true"></i>
              <%= @notepad_entry.contact_count_label %>
            </span>
          <% end %>
          <% if photo_count > 0 %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-photo" aria-hidden="true"></i>
              <%= pluralize(photo_count, "photo") %>
            </span>
          <% end %>
          <% if voice_note_count > 0 %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-microphone" aria-hidden="true"></i>
              <%= pluralize(voice_note_count, "voice note") %>
            </span>
          <% end %>
          <% if todo_items.any? %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-checkbox" aria-hidden="true"></i>
              <%= completed_count %>/<%= todo_items.size %>
            </span>
          <% end %>
          <% if scanned_document_count > 0 %>
            <span class="notepad-doc__meta-chip">
              <i class="ti ti-scan" aria-hidden="true"></i>
              <%= pluralize(scanned_document_count, "scan") %>
            </span>
          <% end %>

          <%= link_to pdf_notepad_entry_path(@notepad_entry, autoprint: 1),
            class: "notepad-doc__meta-chip notepad-doc__meta-action",
            target: "_blank",
            rel: "noopener",
            data: { turbo: false },
            title: "Export as PDF",
            aria: { label: "Export as PDF" } do %>
            <i class="ti ti-file-type-pdf" aria-hidden="true"></i>
            PDF
          <% end %>

          <%= link_to edit_notepad_entry_path(@notepad_entry),
            class: "notepad-doc__meta-chip notepad-doc__meta-action",
            title: "Full edit",
            aria: { label: "Full edit" } do %>
            <i class="ti ti-pencil" aria-hidden="true"></i>
            Edit
          <% end %>
        </div>
      </header>

      <%# ── Document body ───────────────────────────── %>
      <div class="notepad-doc__body">

        <%# ── Notes / rich text block ─────────────────── %>
        <% if @notepad_entry.plain_notes.present? %>
          <div class="notepad-doc__block notepad-doc__block--text">
            <div class="detail-notes-copy trix-content workspace-trix-content">
              <%= render "shared/rich_notes", notes: @notepad_entry.notes %>
            </div>
          </div>
        <% end %>

        <%# ── Photos block ─────────────────────────────── %>
        <div
          id="<%= photos_section_id %>"
          class="notepad-doc__block notepad-doc__block--media detail-section-anchor"
        >
          <%= form_with model: @notepad_entry,
            data: { photo_capture_auto_save: true, controller: "photo-capture" },
            html: { class: "d-contents" } do |form| %>

            <%# Hidden camera input required by photo-capture controller %>
            <input
              type="file"
              accept="image/*"
              capture="environment"
              tabindex="-1"
              aria-hidden="true"
              class="photo-section-camera-input"
              data-photo-capture-target="cameraInput"
              data-action="change->photo-capture#acceptCameraCapture"
            >
            <%= render "shared/photo_capture_field",
              form:,
              field_name: :photos %>

            <div class="notepad-doc__block-header">
              <div class="notepad-doc__block-label">
                <i class="ti ti-photo" aria-hidden="true"></i>
                Photos<% if photo_count > 0 %> · <%= photo_count %><% end %>
              </div>
              <div class="notepad-doc__block-actions">
                <button
                  type="button"
                  class="btn btn-white btn-sm"
                  data-action="photo-capture#openCameraApp"
                  data-photo-capture-target="cameraToggle"
                  aria-pressed="false"
                  title="Capture photo"
                >
                  <i class="ti ti-camera" aria-hidden="true"></i><span> Capture</span>
                </button>
                <button
                  type="button"
                  class="btn btn-white btn-sm"
                  data-action="photo-capture#chooseFromGallery"
                  title="Upload photo"
                >
                  <i class="ti ti-photo-plus" aria-hidden="true"></i><span> Upload</span>
                </button>
              </div>
            </div>

            <% if @notepad_entry.photos.attached? %>
              <div>
                <%= render "notepad_entries/photo_strip", notepad_entry: @notepad_entry %>
              </div>
            <% else %>
              <p class="text-muted m-b-none" style="font-size: 0.875rem;">No photos yet — use the buttons above to capture or upload.</p>
            <% end %>

          <% end %>
        </div>

        <%# ── Voice notes block ───────────────────────── %>
        <% if voice_notes_available %>
          <%= render "notepad_entries/voice_notes_document_section", notepad_entry: @notepad_entry %>
        <% end %>

        <%# ── To-do list block ────────────────────────── %>
        <% if todo_lists_available %>
          <%= render "notepad_entries/todo_list_document_section", notepad_entry: @notepad_entry %>
        <% end %>

        <%# ── Scanned documents block ──────────────────── %>
        <%= render "notepad_entries/scanned_documents_document_section", notepad_entry: @notepad_entry %>

        <%= form_with model: @notepad_entry,
          method: :patch,
          html: { id: contact_form_id, class: "d-contents" } do %>
          <%= hidden_field_tag "notepad_entry[title]", @notepad_entry.title %>
          <%= hidden_field_tag "notepad_entry[notes]", @notepad_entry.notes.to_s %>
          <%= hidden_field_tag "notepad_entry[entry_date]", @notepad_entry.entry_date %>
          <%= render "pages/contact_form_section",
            record: @notepad_entry,
            form_id: contact_form_id,
            section_id: contact_section_id,
            add_button_id: contact_add_button_id,
            auto_submit: true %>
        <% end %>

        <%= form_with model: @notepad_entry,
          method: :patch,
          html: { id: location_form_id, class: "d-contents" } do %>
          <%= hidden_field_tag "notepad_entry[title]", @notepad_entry.title %>
          <%= hidden_field_tag "notepad_entry[notes]", @notepad_entry.notes.to_s %>
          <%= hidden_field_tag "notepad_entry[entry_date]", @notepad_entry.entry_date %>
          <%= render "pages/location_form_section",
            record: @notepad_entry,
            form_id: location_form_id,
            section_id: location_section_id,
            auto_submit: true %>
        <% end %>

        <%# ── Empty state ──────────────────────────────── %>
        <% unless has_content %>
          <div class="notepad-doc__block notepad-doc__block--empty">
            <p class="text-muted m-b-none">No content yet. Use the <strong>+</strong> button below to add a contact, location, photos, voice notes, to-dos, or scanned documents.</p>
          </div>
        <% end %>

      </div><%# /notepad-doc__body %>
    </div><%# /notepad-doc__canvas %>

    <%= render "notepad_entries/merge_section",
      notepad_entry: @notepad_entry,
      merge_candidates: @merge_candidates %>

    <%# ── Move to notebook ─────────────────────────── %>
    <div id="<%= move_to_notebook_section_id %>" class="detail-section-anchor m-t-lg">
      <%= form_with model: @notepad_entry, html: { id: move_form_id, class: "d-none" } do |form| %>
        <%= form.hidden_field :title, value: @notepad_entry.title %>
        <%= form.hidden_field :notes, value: @notepad_entry.notes.to_s %>
        <%= form.hidden_field :entry_date, value: @notepad_entry.entry_date %>
        <%= hidden_field_tag "notepad_entry[contacts_json]", @notepad_entry.contacts_json, form: move_form_id %>
        <%= hidden_field_tag "notepad_entry[locations_json]", @notepad_entry.locations_json, form: move_form_id %>
      <% end %>
      <%= render "notepad_entries/move_to_notebook_section",
        notepad_entry: @notepad_entry,
        form_id: move_form_id,
        move_destination_notebooks: @move_destination_notebooks,
        selected_move_destination_chapter_id: @selected_move_destination_chapter_id,
        selected_move_destination_label: @selected_move_destination_label %>
    </div>

  </div><%# /notepad-doc %>

  <%# ── Quick actions FAB ───────────────────────── %>
  <div
    class="notepad-quick-actions"
    data-controller="notepad-quick-actions"
    data-action="click@window->notepad-quick-actions#closeOnWindow keydown.esc@window->notepad-quick-actions#close"
    data-notepad-quick-actions-photos-section-id-value="<%= photos_section_id %>"
    data-notepad-quick-actions-voice-section-id-value="<%= voice_notes_section_id %>"
    data-notepad-quick-actions-todo-section-id-value="<%= todo_list_section_id %>"
    data-notepad-quick-actions-scan-section-id-value="<%= scanned_documents_section_id %>"
    data-notepad-quick-actions-location-section-id-value="<%= location_section_id %>"
    data-notepad-quick-actions-location-input-id-value="<%= location_input_id %>"
    data-notepad-quick-actions-contact-section-id-value="<%= contact_section_id %>"
    data-notepad-quick-actions-contact-button-id-value="<%= contact_add_button_id %>"
  >
    <div class="notepad-quick-actions__menu" data-notepad-quick-actions-target="menu" aria-hidden="true">
      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openCamera"
        aria-label="Capture photo"
        title="Capture photo"
      >
        <i class="ti ti-camera" aria-hidden="true"></i>
      </button>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openGallery"
        aria-label="Upload from gallery"
        title="Upload from gallery"
      >
        <i class="ti ti-photo-plus" aria-hidden="true"></i>
      </button>

      <% if voice_notes_available %>
        <button
          type="button"
          class="notepad-quick-actions__item"
          data-notepad-quick-actions-target="item"
          data-action="click->notepad-quick-actions#openVoiceNote"
          aria-label="Record voice note"
          title="Record voice note"
        >
          <i class="ti ti-microphone" aria-hidden="true"></i>
        </button>
      <% end %>

      <% if todo_lists_available %>
        <button
          type="button"
          class="notepad-quick-actions__item"
          data-notepad-quick-actions-target="item"
          data-action="click->notepad-quick-actions#openTodo"
          aria-label="Open to-do list"
          title="Open to-do list"
        >
          <i class="ti ti-list-check" aria-hidden="true"></i>
        </button>
      <% end %>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openScan"
        aria-label="Scan document"
        title="Scan document"
      >
        <i class="ti ti-scan" aria-hidden="true"></i>
      </button>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openLocation"
        aria-label="Add location"
        title="Add location"
      >
        <i class="ti ti-map-pin" aria-hidden="true"></i>
      </button>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openContact"
        aria-label="Add contact"
        title="Add contact"
      >
        <i class="ti ti-address-book" aria-hidden="true"></i>
      </button>
    </div>

    <button
      type="button"
      class="notepad-quick-actions__toggle"
      data-notepad-quick-actions-target="toggle"
      data-action="click->notepad-quick-actions#toggle"
      aria-expanded="false"
      aria-pressed="false"
      aria-label="Open quick actions"
      title="Open quick actions"
    >
      <i class="ti ti-plus" aria-hidden="true"></i>
    </button>
  </div>

</div><%# /wrapper %>

<%= render "notepad_entries/quick_edit_modal", notepad_entry: @notepad_entry, open: @show_quick_edit_modal == true %>
