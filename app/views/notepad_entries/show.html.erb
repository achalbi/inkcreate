<div class="wrapper wrapper-content animated fadeInRight">
  <nav aria-label="breadcrumb" class="m-b-md">
    <ol class="breadcrumb">
      <li><%= link_to "Home", dashboard_path %></li>
      <li><%= link_to "Notepad", notepad_entries_path %></li>
      <li class="active"><%= @notepad_entry.display_title %></li>
    </ol>
  </nav>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Entry overview</h5>
      <div class="ibox-tools">
        <span class="label label-info">Daily capture</span>
      </div>
    </div>
    <div class="ibox-content">
      <div class="row">
        <div class="col-sm-8">
          <h2 class="m-t-none"><%= @notepad_entry.display_title %></h2>
          <p class="m-b-none">
            <span class="label label-info"><%= @notepad_entry.entry_date.strftime("%b %-d, %Y") %></span>
            <span class="label label-default"><%= pluralize(@notepad_entry.photos.count, "photo") %></span>
          </p>
        </div>
        <div class="col-sm-4">
          <div class="m-t-sm">
          <%= link_to "Edit entry", edit_notepad_entry_path(@notepad_entry), class: "btn btn-primary btn-sm" %>
          <%= button_to "Delete entry", notepad_entry_path(@notepad_entry),
            method: :delete,
            form: { style: "display: inline-block; margin: 0;", onsubmit: "return confirm('Delete this entry?');" },
            class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="row">
    <div class="col-lg-4">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Notes</h5>
        </div>
        <div class="ibox-content">
          <% if @notepad_entry.notes.present? %>
            <div><%= simple_format(@notepad_entry.notes) %></div>
          <% else %>
            <p class="text-muted m-b-none">No notes added yet.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Photo gallery</h5>
          <div class="ibox-tools">
            <%= link_to "Manage photos", edit_notepad_entry_path(@notepad_entry), class: "btn btn-white btn-sm" %>
          </div>
        </div>
        <div class="ibox-content">

          <% if @notepad_entry.photos.attached? %>
            <div class="row">
              <% @notepad_entry.photos.each do |photo| %>
                <div class="col-sm-6">
                  <div class="thumbnail">
                    <%= image_tag photo, class: "img-responsive", style: "width: 100%; height: 240px; object-fit: cover;", alt: @notepad_entry.display_title %>
                    <div class="caption">
                      <%= button_to "Remove photo", photo_notepad_entry_path(@notepad_entry, photo),
                        method: :delete,
                        form: { style: "margin: 0;", onsubmit: "return confirm('Remove this photo?');" },
                        class: "btn btn-danger btn-sm" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <%= render "shared/empty_state", title: "No photos yet", description: "Upload one or more photos to keep this daily entry visually complete." %>
          <% end %>
        </div>
      </div>
    </div>
  </section>
</div>
