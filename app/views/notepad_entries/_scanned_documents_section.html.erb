<%
  docs = notepad_entry.scanned_documents.with_attached_enhanced_image.with_attached_document_pdf.recent_first
  post_url = notepad_entry_scanned_documents_path(notepad_entry)
%>

<section
  id="<%= dom_id(notepad_entry, :scanned_documents_section) %>"
  class="ibox float-e-margins detail-section-anchor"
  data-controller="document-capture"
  data-document-capture-post-url-value="<%= post_url %>"
  data-document-capture-csrf-value="<%= form_authenticity_token %>"
>
  <div class="ibox-title">
    <div class="detail-photo-gallery-heading">
      <h5 class="detail-photo-gallery-title">Scanned documents</h5>
      <span class="label label-info detail-photo-gallery-count"><%= docs.size %></span>
    </div>
    <div class="ibox-tools d-flex align-items-center gap-2">
      <button
        type="button"
        class="btn btn-primary btn-sm"
        data-action="click->document-capture#open"
        aria-label="Scan a document"
      >
        <i class="ti ti-scan" aria-hidden="true"></i> Scan
      </button>
      <%= render "shared/ibox_toggle_button", target_id: dom_id(notepad_entry, :scanned_documents_content) %>
    </div>
  </div>

  <div id="<%= dom_id(notepad_entry, :scanned_documents_content) %>" class="ibox-content collapse show">
	    <% if docs.any? %>
	      <div class="sdoc-list">
	        <% docs.each do |doc| %>
	          <% pdf_view_url = doc.document_pdf.attached? ? rails_blob_path(doc.document_pdf, only_path: true, disposition: "inline") : nil %>
	          <% pdf_download_url = doc.document_pdf.attached? ? rails_blob_path(doc.document_pdf, only_path: true, disposition: "attachment") : nil %>
	          <% card_summary = pdf_view_url.present? ? "Open the PDF to review this scanned document." : "Scanned document preview available." %>
	          <div class="sdoc-card" id="<%= dom_id(doc) %>">
            <div class="sdoc-accent-bar"></div>
            <div class="sdoc-inner">
              <div class="sdoc-header">
                <% if pdf_view_url.present? %>
                  <button
                    type="button"
                    class="sdoc-title sdoc-title-button"
                    data-action="click->document-capture#openPdf"
                    data-pdf-url="<%= pdf_view_url %>"
                    title="View PDF"
                  ><%= doc.title.presence || "Untitled scan" %></button>
                <% else %>
                  <div class="sdoc-title"><%= doc.title.presence || "Untitled scan" %></div>
                <% end %>
	                <div class="sdoc-meta">
	                  <span class="sdoc-engine-label">PDF ready · <%= doc.created_at.strftime("%-d %b") %></span>
	                </div>
              </div>

              <div class="sdoc-body">
                <% if pdf_view_url.present? %>
                  <button
                    type="button"
                    class="sdoc-preview-button"
                    data-action="click->document-capture#openPdf"
                    data-pdf-url="<%= pdf_view_url %>"
                    title="View PDF"
                  >
                    <% if doc.enhanced_image.attached? %>
                      <%= image_tag doc.enhanced_image, class: "sdoc-thumb", alt: doc.title %>
                    <% else %>
                      <div class="sdoc-thumb sdoc-thumb--placeholder">
                        <i class="ti ti-file-text" aria-hidden="true"></i>
                      </div>
                    <% end %>
                  </button>
                <% else %>
                  <% if doc.enhanced_image.attached? %>
                    <%= image_tag doc.enhanced_image, class: "sdoc-thumb", alt: doc.title %>
                  <% else %>
                    <div class="sdoc-thumb sdoc-thumb--placeholder">
                      <i class="ti ti-file-text" aria-hidden="true"></i>
                    </div>
                  <% end %>
                <% end %>
                <% if pdf_view_url.present? %>
                  <button
                    type="button"
                    class="sdoc-excerpt sdoc-excerpt-button"
                    data-action="click->document-capture#openPdf"
                    data-pdf-url="<%= pdf_view_url %>"
                    title="View PDF"
	                  ><%= card_summary %></button>
	                <% else %>
	                  <p class="sdoc-excerpt">
	                    <%= card_summary %>
	                  </p>
	                <% end %>
	              </div>

	              <div class="sdoc-actions">
	                <% if pdf_view_url.present? %>
	                  <%= link_to pdf_view_url,
                      class: "btn btn-white btn-sm",
                      target: "_blank",
                      rel: "noopener",
                      data: { turbo: false },
                      title: "View PDF" do %>
                    <i class="ti ti-eye" aria-hidden="true"></i> View PDF
                  <% end %>
                <% end %>

                <% if pdf_download_url.present? %>
                  <%= link_to pdf_download_url,
                      class: "btn btn-white btn-sm",
                      data: { turbo: false },
                      download: doc.document_pdf.filename.to_s,
                      title: "Download PDF" do %>
                    <i class="ti ti-download" aria-hidden="true"></i> Download PDF
                  <% end %>
                <% end %>

	                <%= button_to notepad_entry_scanned_document_path(notepad_entry, doc),
	                    method: :delete,
	                    form: { data: { turbo_confirm: "Delete this scan?" } },
                    class: "btn btn-white btn-sm sdoc-delete-btn",
                    title: "Delete" do %>
                  <i class="ti ti-trash" aria-hidden="true"></i>
                  <span class="sr-only">Delete</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
	    <% else %>
	      <div class="sdoc-empty-state">
        <div class="sdoc-empty-icon">
          <i class="ti ti-file-text" aria-hidden="true"></i>
	        </div>
	        <div class="sdoc-empty-title">No scanned documents yet</div>
	        <div class="sdoc-empty-sub">Capture a document as a PDF to keep receipts, notes, and pages together.</div>
	        <button
	          type="button"
          class="btn btn-primary btn-sm"
          data-action="click->document-capture#open"
        ><i class="ti ti-scan" aria-hidden="true"></i> Scan your first document</button>
      </div>
    <% end %>
  </div>

  <%= render "shared/scanned_document_capture_overlay" %>
</section>
