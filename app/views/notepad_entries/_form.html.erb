<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
%>

<%= form_with model: notepad_entry, data: { photo_capture_auto_save: notepad_entry.persisted? } do |form| %>
  <% if notepad_entry.errors.any? %>
    <% error_body = capture do %>
      <ul class="m-b-none m-t-sm">
        <% notepad_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
    <%= render "shared/inline_alert", type: :danger, title: "Please fix the following:", body_html: error_body %>
  <% end %>

  <div class="row entry-photos-form-row" data-controller="photo-capture">
    <input
      type="file"
      accept="image/*"
      capture="environment"
      tabindex="-1"
      aria-hidden="true"
      class="photo-section-camera-input"
      data-photo-capture-target="cameraInput"
      data-action="change->photo-capture#acceptCameraCapture"
    >

    <div class="col-lg-7">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Page details</h5>
          <div class="ibox-tools">
            <button
              type="submit"
              class="btn btn-sm btn-icon notebook-overview-edit-button page-details-save-button"
              title="Save"
              aria-label="Save"
            >
              <i class="ti ti-device-floppy" aria-hidden="true"></i>
            </button>
            <%= render "shared/ibox_toggle_button", target_id: "notepad-entry-form-content" %>
          </div>
        </div>
        <div id="notepad-entry-form-content" class="ibox-content collapse show">
          <div class="row entry-details-fields-row">
            <div class="col-lg-8 entry-details-title-column">
              <div class="form-group">
                <%= form.label :title, class: "control-label" %>
                <%= form.text_field :title, class: "form-control", placeholder: "Daily review, meeting recap, ideas, or notes" %>
              </div>
            </div>
            <div class="col-lg-4">
              <div class="form-group">
                <%= form.label :entry_date, class: "control-label" %>
                <%= form.date_field :entry_date, class: "form-control" %>
              </div>
            </div>
          </div>

          <div class="form-group">
            <% notes_input_id = dom_id(notepad_entry, :notes_input) %>
            <%= form.label :notes, class: "control-label" %>
            <%= form.hidden_field :notes, id: notes_input_id %>
            <trix-editor
              input="<%= notes_input_id %>"
              class="workspace-rich-text-editor notepad-entry-notes-field"
              placeholder="Write the day's notes, observations, reminders, or quick captures."
              data-controller="rich-text"
              data-action="trix-file-accept->rich-text#preventFileAccept"
            ></trix-editor>
          </div>

          <% if notepad_entry.persisted? %>
            <div class="m-t-md workspace-form-actions">
              <%= form.submit "Save", class: "btn btn-primary btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Photos</h5>
          <div class="ibox-tools">
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-camera-button"
              data-action="photo-capture#openCameraApp"
              data-photo-capture-target="cameraToggle"
              aria-pressed="false"
              title="Open camera"
            >
              <i class="ti ti-camera" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-upload-button"
              data-action="photo-capture#chooseFromGallery"
              title="Upload from gallery"
            >
              <i class="ti ti-photo-plus" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-info-button"
              data-bs-toggle="collapse"
              data-bs-target="#notepad-entry-capture-tips"
              aria-expanded="false"
              aria-controls="notepad-entry-capture-tips"
              title="Capture tips"
            >
              <i class="ti ti-info-circle" aria-hidden="true"></i>
            </button>
            <%= render "shared/ibox_toggle_button", target_id: "notepad-entry-photos-content" %>
          </div>
        </div>
        <div id="notepad-entry-photos-content" class="ibox-content collapse show">
          <%= render "shared/photo_capture_field", form:, field_name: :photos, tips_target_id: "notepad-entry-capture-tips" %>

          <% if notepad_entry.photos.attached? %>
            <hr>
            <h5 class="m-t-none m-b-md">Current photos</h5>
            <div>
              <div class="detail-photo-grid detail-photo-grid--gallery">
                <% notepad_entry.photos.attachments.sort_by(&:created_at).reverse_each do |attachment| %>
                  <% photo = attachment.blob %>
                  <div class="detail-photo-grid__item">
                    <div class="thumbnail">
                      <%= render "shared/photo_lightbox",
                        photo:,
                        alt: notepad_entry.display_title,
                        group: dom_id(notepad_entry, :edit_gallery),
                        image_style: "width: 100%; height: 220px; object-fit: cover;",
                        removal_path: photo_notepad_entry_path(notepad_entry, attachment),
                        removal_message: "This photo will be removed from the daily page." %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <button
      type="button"
      class="workspace-fab photo-capture-fab"
      data-action="photo-capture#openCameraApp"
      data-photo-capture-target="cameraToggle"
      aria-pressed="false"
      aria-label="Open camera"
      title="Open camera"
    >
      <i class="ti ti-camera" aria-hidden="true"></i>
    </button>
  </div>

  <% if VoiceNote.notepad_entries_supported? %>
    <div class="row m-t-md">
      <div class="col-12">
        <%= render "notepad_entries/voice_notes_section", notepad_entry: notepad_entry, form: form %>
      </div>
    </div>
  <% end %>

  <div class="row m-t-md">
    <% if todo_lists_available %>
      <div class="col-12">
        <%= render "notepad_entries/todo_list_form_section", notepad_entry: notepad_entry, form: form %>
      </div>
    <% else %>
      <div class="col-12">
        <%= render "pages/todo_list_unavailable_section" %>
      </div>
    <% end %>
  </div>

  <% if notepad_entry.persisted? %>
    <div class="row m-t-md">
      <div class="col-12">
        <% move_modal_id = dom_id(notepad_entry, :move_destination_modal) %>
        <% move_destination_input_id = "#{move_modal_id}_input" %>
        <% move_destination_display_id = "#{move_modal_id}_display" %>
        <% move_destination_data = @move_destination_notebooks.map { |notebook|
          {
            notebookId: notebook.id,
            title: notebook.title,
            chapters: notebook.chapters.map { |chapter|
              {
                chapterId: chapter.id,
                notebookId: notebook.id,
                title: chapter.title,
                label: "#{notebook.title} > #{chapter.title}"
              }
            }
          }
        } %>
        <div class="ibox notepad-entry-move-shell">
          <div class="ibox-title">
            <h5>Move to notebook</h5>
            <div class="ibox-tools">
              <span class="label label-warning">Notepad to notebook</span>
            </div>
          </div>
          <div class="ibox-content">
            <section class="notepad-entry-move-panel">
              <div class="notepad-entry-move-panel__header">
                <div>
                  <h6 class="notepad-entry-move-panel__title">Move this page into a chapter</h6>
                  <p class="notepad-entry-move-panel__description">Convert this daily page into a notebook page inside one of your chapters.</p>
                </div>
              </div>

              <% if @move_destination_notebooks.present? %>
                <div class="form-group">
                  <%= label_tag :move_to_chapter_id, "Destination", class: "control-label" %>
                  <%= hidden_field_tag :move_to_chapter_id,
                    @selected_move_destination_chapter_id,
                    id: move_destination_input_id %>
                  <button
                    type="button"
                    class="btn btn-white btn-sm notepad-entry-move-picker-button"
                    data-bs-toggle="modal"
                    data-bs-target="#<%= move_modal_id %>"
                  >
                    <span class="notepad-entry-move-picker-button__copy">
                      <span class="notepad-entry-move-picker-button__label">Selected destination</span>
                      <span id="<%= move_destination_display_id %>" class="notepad-entry-move-picker-button__value"><%= @selected_move_destination_label.presence || "Choose a notebook and chapter" %></span>
                    </span>
                    <i class="ti ti-chevron-right" aria-hidden="true"></i>
                  </button>
                  <p class="help-block">Choose a notebook in the modal, then pick a chapter and save the destination.</p>
                </div>

                <div class="workspace-form-actions">
                  <%= button_tag "Move to notebook chapter",
                    type: "submit",
                    name: "intent",
                    value: "move_to_notebook",
                    class: "btn btn-white btn-sm notepad-entry-move-button",
                    data: { disable_with: "Moving..." } %>
                </div>

                <div
                  class="modal fade notebook-section-modal notepad-entry-move-modal"
                  id="<%= move_modal_id %>"
                  tabindex="-1"
                  aria-labelledby="<%= "#{move_modal_id}-label" %>"
                  aria-hidden="true"
                >
                  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                    <div
                      class="modal-content"
                      data-controller="move-destination"
                      data-move-destination-placeholder-value="Choose a notebook and chapter"
                      data-move-destination-notebooks-value="<%= json_escape(move_destination_data.to_json) %>"
                      data-move-destination-input-id-value="<%= move_destination_input_id %>"
                      data-move-destination-display-label-id-value="<%= move_destination_display_id %>"
                    >
                      <div class="modal-header notebook-section-modal__header">
                        <div>
                          <div class="notebook-section-modal__eyebrow">Move destination</div>
                          <h5
                            id="<%= "#{move_modal_id}-label" %>"
                            class="modal-title notebook-section-modal__title"
                            data-move-destination-target="modalTitle"
                          >
                            Choose a notebook and chapter
                          </h5>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>

                      <div class="modal-body notebook-section-modal__body">
                        <div class="notepad-entry-move-modal__selection">
                          <span class="notepad-entry-move-modal__selection-label">Pending destination</span>
                          <span class="notepad-entry-move-modal__selection-value" data-move-destination-target="pendingLabel"><%= @selected_move_destination_label.presence || "Choose a notebook and chapter" %></span>
                        </div>

                        <div class="notepad-entry-move-modal__field-stack">
                          <div class="form-group">
                            <label class="control-label" for="<%= "#{move_modal_id}_notebook" %>">Notebook</label>
                            <select
                              id="<%= "#{move_modal_id}_notebook" %>"
                              class="form-control"
                              data-move-destination-target="notebookSelect"
                              data-action="input->move-destination#chooseNotebook change->move-destination#chooseNotebook"
                            >
                              <option value="">Choose a notebook</option>
                              <% @move_destination_notebooks.each do |notebook| %>
                                <option value="<%= notebook.id %>"><%= notebook.title %></option>
                              <% end %>
                            </select>
                            <p class="help-block notepad-entry-move-modal__help">Select a notebook first to load its chapters.</p>
                          </div>

                          <div class="form-group m-b-none">
                            <label class="control-label" for="<%= "#{move_modal_id}_chapter" %>">Chapter</label>
                            <select
                              id="<%= "#{move_modal_id}_chapter" %>"
                              class="form-control"
                              data-move-destination-target="chapterSelect"
                              data-action="input->move-destination#selectChapter change->move-destination#selectChapter"
                              disabled
                            >
                              <option value="">Choose a chapter</option>
                            </select>
                            <p class="help-block notepad-entry-move-modal__help">Choose the chapter inside that notebook, then save the destination.</p>
                          </div>
                        </div>
                      </div>

                      <div class="modal-footer notebook-section-modal__footer">
                        <div class="notebook-section-modal__page-info">Save the destination here, then move the page from the main action below.</div>
                        <div class="notepad-entry-move-modal__footer-actions">
                          <button
                            type="button"
                            class="btn btn-primary btn-sm notepad-entry-move-modal__save-button"
                            data-move-destination-target="saveButton"
                            data-action="click->move-destination#save"
                          >
                            Save destination
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% else %>
                <%= render "shared/inline_alert",
                  type: :info,
                  title: "Create a chapter first",
                  body: "You can move this page once at least one notebook chapter exists in your workspace." %>
              <% end %>
            </section>
          </div>
        </div>
      </div>
    </div>
  <% end %>

<% end %>
