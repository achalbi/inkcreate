<%
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  voice_notes_available = VoiceNote.notepad_entries_supported?
  persisted_entry = notepad_entry.persisted?
  notepad_entry_form_id = dom_id(notepad_entry, :edit_form)
  details_section_id = dom_id(notepad_entry, :details_section)
  photos_section_id = dom_id(notepad_entry, :photos_section)
  photo_camera_input_id = dom_id(notepad_entry, :photo_camera_input)
  photo_camera_button_id = dom_id(notepad_entry, :photo_camera_button)
  voice_notes_section_id = dom_id(notepad_entry, :voice_notes_section)
  todo_list_section_id = persisted_entry ? dom_id(notepad_entry, :todo_list_section) : dom_id(notepad_entry, :todo_list_form_section)
  scanned_documents_section_id = dom_id(notepad_entry, :scanned_documents_section)
  move_to_notebook_section_id = dom_id(notepad_entry, :move_to_notebook_section)
%>

<%= form_with model: notepad_entry, data: { photo_capture_auto_save: persisted_entry }, html: { id: notepad_entry_form_id } do |form| %>
  <% if notepad_entry.errors.any? %>
    <% error_body = capture do %>
      <ul class="m-b-none m-t-sm">
        <% notepad_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
    <%= render "shared/inline_alert", type: :danger, title: "Please fix the following:", body_html: error_body %>
  <% end %>

  <div class="row entry-photos-form-row" data-controller="photo-capture">
    <input
      id="<%= photo_camera_input_id %>"
      type="file"
      accept="image/*"
      capture="environment"
      tabindex="-1"
      aria-hidden="true"
      class="photo-section-camera-input"
      data-photo-capture-target="cameraInput"
      data-action="change->photo-capture#acceptCameraCapture"
    >

    <div id="<%= details_section_id %>" class="col-lg-7 detail-section-anchor">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Page details</h5>
          <div class="ibox-tools">
            <button
              type="submit"
              class="btn btn-sm btn-icon notebook-overview-edit-button page-details-save-button"
              title="Save"
              aria-label="Save"
            >
              <i class="ti ti-device-floppy" aria-hidden="true"></i>
            </button>
            <% if persisted_entry %>
              <%= link_to notepad_entry_path(notepad_entry),
                class: "btn btn-sm btn-icon notebook-overview-delete-button",
                title: "Delete page",
                aria: { label: "Delete page" },
                data: { turbo_method: :delete, turbo_confirm: "Delete this page?" } do %>
                <i class="ti ti-trash" aria-hidden="true"></i>
              <% end %>
            <% end %>
            <%= render "shared/ibox_toggle_button", target_id: "notepad-entry-form-content" %>
          </div>
        </div>
        <div id="notepad-entry-form-content" class="ibox-content collapse show">
          <div class="row entry-details-fields-row">
            <div class="col-lg-8 entry-details-title-column">
              <div class="form-group">
                <%= form.label :title, class: "control-label" %>
                <%= form.text_field :title, class: "form-control", placeholder: "Daily review, meeting recap, ideas, or notes" %>
              </div>
            </div>
            <div class="col-lg-4">
              <div class="form-group">
                <%= form.label :entry_date, class: "control-label" %>
                <%= form.date_field :entry_date, class: "form-control" %>
              </div>
            </div>
          </div>

          <div class="form-group">
            <% notes_input_id = dom_id(notepad_entry, :notes_input) %>
            <%= form.label :notes, class: "control-label" %>
            <%= form.hidden_field :notes, id: notes_input_id %>
            <trix-editor
              input="<%= notes_input_id %>"
              class="workspace-rich-text-editor notepad-entry-notes-field"
              placeholder="Write the day's notes, observations, reminders, or quick captures."
              data-controller="rich-text"
              data-action="trix-file-accept->rich-text#preventFileAccept"
            ></trix-editor>
          </div>

          <% if notepad_entry.persisted? %>
            <div class="m-t-md workspace-form-actions">
              <%= form.submit "Save", class: "btn btn-primary btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div id="<%= photos_section_id %>" class="col-lg-5 detail-section-anchor">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Photos</h5>
          <div class="ibox-tools">
            <button
              type="button"
              id="<%= photo_camera_button_id %>"
              class="btn btn-white btn-sm btn-icon photo-section-camera-button"
              data-action="photo-capture#openCameraApp"
              data-photo-capture-target="cameraToggle"
              aria-pressed="false"
              title="Open camera"
            >
              <i class="ti ti-camera" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              class="btn btn-white btn-sm btn-icon photo-section-upload-button"
              data-action="photo-capture#chooseFromGallery"
              title="Upload from gallery"
            >
              <i class="ti ti-photo-plus" aria-hidden="true"></i>
            </button>
            <%= render "shared/ibox_toggle_button", target_id: "notepad-entry-photos-content" %>
          </div>
        </div>
        <div id="notepad-entry-photos-content" class="ibox-content collapse show">
          <%= render "shared/photo_capture_field", form:, field_name: :photos %>

          <% if notepad_entry.photos.attached? %>
            <hr>
            <h5 class="m-t-none m-b-md">Current photos</h5>
            <div>
              <div class="detail-photo-grid detail-photo-grid--gallery">
                <% notepad_entry.photos.attachments.sort_by(&:created_at).reverse_each do |attachment| %>
                  <% photo = attachment.blob %>
                  <div class="detail-photo-grid__item">
                    <div class="thumbnail">
                      <%= render "shared/photo_lightbox",
                        photo:,
                        alt: notepad_entry.display_title,
                        group: dom_id(notepad_entry, :edit_gallery),
                        image_style: "width: 100%; height: 220px; object-fit: cover;",
                        removal_path: photo_notepad_entry_path(notepad_entry, attachment),
                        removal_message: "This photo will be removed from the daily page." %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  </div>

  <div
    class="notepad-quick-actions"
    data-controller="notepad-quick-actions"
    data-action="click@window->notepad-quick-actions#closeOnWindow keydown.esc@window->notepad-quick-actions#close"
    data-notepad-quick-actions-photos-section-id-value="<%= photos_section_id %>"
    data-notepad-quick-actions-camera-input-id-value="<%= photo_camera_input_id %>"
    data-notepad-quick-actions-camera-button-id-value="<%= photo_camera_button_id %>"
    data-notepad-quick-actions-voice-section-id-value="<%= voice_notes_section_id %>"
    data-notepad-quick-actions-todo-section-id-value="<%= todo_list_section_id %>"
    data-notepad-quick-actions-scan-section-id-value="<%= scanned_documents_section_id %>"
  >
    <div class="notepad-quick-actions__menu" data-notepad-quick-actions-target="menu" aria-hidden="true">
      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openCamera"
        aria-label="Capture photo"
        title="Capture photo"
      >
        <i class="ti ti-camera" aria-hidden="true"></i>
      </button>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openGallery"
        aria-label="Upload from gallery"
        title="Upload from gallery"
      >
        <i class="ti ti-photo-plus" aria-hidden="true"></i>
      </button>

      <% if voice_notes_available %>
        <button
          type="button"
          class="notepad-quick-actions__item"
          data-notepad-quick-actions-target="item"
          data-action="click->notepad-quick-actions#openVoiceNote"
          aria-label="Record voice note"
          title="Record voice note"
        >
          <i class="ti ti-microphone" aria-hidden="true"></i>
        </button>
      <% end %>

      <% if todo_lists_available %>
        <button
          type="button"
          class="notepad-quick-actions__item"
          data-notepad-quick-actions-target="item"
          data-action="click->notepad-quick-actions#openTodo"
          aria-label="Open to-do list"
          title="Open to-do list"
        >
          <i class="ti ti-list-check" aria-hidden="true"></i>
        </button>
      <% end %>

      <button
        type="button"
        class="notepad-quick-actions__item"
        data-notepad-quick-actions-target="item"
        data-action="click->notepad-quick-actions#openScan"
        aria-label="Scan document"
        title="Scan document"
      >
        <i class="ti ti-scan" aria-hidden="true"></i>
      </button>
    </div>

    <button
      type="button"
      class="notepad-quick-actions__toggle"
      data-notepad-quick-actions-target="toggle"
      data-action="click->notepad-quick-actions#toggle"
      aria-expanded="false"
      aria-pressed="false"
      aria-label="Open quick actions"
      title="Open quick actions"
    >
      <i class="ti ti-plus" aria-hidden="true"></i>
    </button>
  </div>

  <% if voice_notes_available %>
    <div class="row m-t-md">
      <div class="col-12">
        <%= render "notepad_entries/voice_notes_section", notepad_entry: notepad_entry, form: form %>
      </div>
    </div>
  <% end %>

  <% unless persisted_entry %>
    <div class="row m-t-md">
      <div class="col-12 notepad-entry-scanned-documents-column">
        <%= render "shared/scanned_documents_form_section", form: form, record: notepad_entry %>
      </div>

      <% if todo_lists_available %>
        <div class="col-12">
          <%= render "notepad_entries/todo_list_form_section", notepad_entry: notepad_entry, form: form %>
        </div>
      <% else %>
        <div class="col-12">
          <%= render "pages/todo_list_unavailable_section" %>
        </div>
      <% end %>
    </div>
  <% end %>

<% end %>

<% if persisted_entry %>
  <div class="row m-t-md">
    <% if todo_lists_available %>
      <div class="col-12">
        <%= render "notepad_entries/todo_list_section", notepad_entry: notepad_entry %>
      </div>
    <% else %>
      <div class="col-12">
        <%= render "pages/todo_list_unavailable_section" %>
      </div>
    <% end %>

    <div class="col-12 notepad-entry-scanned-documents-column">
      <%= render "notepad_entries/scanned_documents_section", notepad_entry: notepad_entry %>
    </div>
  </div>

  <div id="<%= move_to_notebook_section_id %>" class="detail-section-anchor">
    <%= render "notepad_entries/move_to_notebook_section",
      notepad_entry: notepad_entry,
      form_id: notepad_entry_form_id,
      move_destination_notebooks: @move_destination_notebooks,
      selected_move_destination_chapter_id: @selected_move_destination_chapter_id,
      selected_move_destination_label: @selected_move_destination_label %>
  </div>
<% end %>
