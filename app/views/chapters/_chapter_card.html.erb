<article
  class="notebook-list-card"
  data-card-link="<%= notebook_chapter_path(notebook, chapter) %>"
  tabindex="0"
  role="link"
  aria-label="Open <%= chapter.title %>"
>
  <div class="notebook-list-card__body">
    <div class="notebook-list-card__header">
      <div class="notebook-list-card__main">
        <h6 class="notebook-list-card__title"><%= chapter.title %></h6>
        <p class="notebook-list-card__description"><%= chapter.description.presence || "No chapter description yet." %></p>
      </div>

      <div class="notebook-list-card__header-tools">
        <span class="label label-default notebook-list-card__status">Chapter <%= chapter.position %></span>
      </div>
    </div>

    <div class="notebook-list-card__meta">
      <span class="notebook-list-card__meta-item"><strong><%= chapter.pages.count %></strong> <%= "page".pluralize(chapter.pages.count) %></span>
      <span class="notebook-list-card__meta-item">Updated <%= time_ago_in_words(chapter.updated_at) %> ago</span>
    </div>

    <div class="content-list-actions">
      <%= button_to move_notebook_chapter_path(notebook, chapter, direction: :up),
        method: :patch,
        class: "btn btn-white btn-sm btn-icon",
        title: "Move chapter up",
        aria: { label: "Move #{chapter.title} up" },
        form: { class: "content-list-actions__form" } do %>
        <i class="ti ti-arrow-up" aria-hidden="true"></i>
      <% end %>

      <%= button_to move_notebook_chapter_path(notebook, chapter, direction: :down),
        method: :patch,
        class: "btn btn-white btn-sm btn-icon",
        title: "Move chapter down",
        aria: { label: "Move #{chapter.title} down" },
        form: { class: "content-list-actions__form" } do %>
        <i class="ti ti-arrow-down" aria-hidden="true"></i>
      <% end %>
    </div>
  </div>
</article>
