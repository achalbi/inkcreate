<article
  class="notebook-list-card notebook-list-card--chapter notebook-list-card--deleted"
  aria-label="Deleted chapter <%= chapter.title %>"
>
  <div class="notebook-list-card__body">
    <div class="notebook-list-card__symbol notebook-list-card__symbol--muted" aria-hidden="true">
      <i class="ti ti-book-off"></i>
    </div>

    <div class="notebook-list-card__main">
      <div class="notebook-list-card__title-row">
        <h6 class="notebook-list-card__title"><%= chapter.title %></h6>
        <span class="label label-default notebook-list-card__status">Deleted</span>
      </div>

      <p class="notebook-list-card__description"><%= chapter.description.presence || "No description." %></p>

      <div class="notebook-list-card__meta notebook-list-card__meta--chapter">
        <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
          <i class="ti ti-file-text" aria-hidden="true"></i>
          <strong><%= chapter.pages.count %></strong> <%= "page".pluralize(chapter.pages.count) %>
        </span>

        <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
          <i class="ti ti-archive" aria-hidden="true"></i>
          Deleted <%= time_ago_in_words(chapter.deleted_at) %> ago
        </span>
      </div>
    </div>

    <div class="notebook-list-card__trailing">
      <%= button_to restore_notebook_chapter_path(notebook, chapter),
        method: :patch,
        class: "btn btn-white btn-sm btn-icon chapter-restore-btn",
        title: "Restore chapter",
        aria: { label: "Restore #{chapter.title}" },
        form: { class: "content-list-actions__form" } do %>
        <i class="ti ti-restore" aria-hidden="true"></i>
      <% end %>
    </div>
  </div>
</article>
