<%= form_with model: [notebook, chapter] do |form| %>
  <div class="ibox">
    <div class="ibox-title">
      <h5>Chapter details</h5>
      <div class="ibox-tools">
        <%= render "shared/ibox_toggle_button", target_id: "chapter-form-content" %>
      </div>
    </div>
    <div id="chapter-form-content" class="ibox-content collapse show">
    <% if chapter.errors.any? %>
      <% error_body = capture do %>
        <ul class="m-b-none m-t-sm">
          <% chapter.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
      <%= render "shared/inline_alert", type: :danger, title: "Please fix the following:", body_html: error_body %>
    <% end %>

      <div class="form-group">
        <%= form.label :title, class: "control-label" %>
        <%= form.text_field :title, class: "form-control", placeholder: "Research findings" %>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "control-label" %>
        <%= form.text_area :description, rows: 5, class: "form-control", placeholder: "Optional context for what belongs in this chapter." %>
      </div>

      <div class="m-t-md workspace-form-actions">
        <%= form.submit class: "btn btn-primary btn-sm" %>
        <%= link_to "Cancel", chapter.persisted? ? notebook_chapter_path(notebook, chapter) : notebook_path(notebook), class: "btn btn-white btn-sm" %>
      </div>
    </div>
  </div>
<% end %>
