<div class="wrapper wrapper-content animated fadeInRight">
  <%= render "shared/workspace_breadcrumbs",
    items: [["Home", dashboard_path], ["Notebook", notebooks_path], [@notebook.title, notebook_path(@notebook)], @chapter.title] %>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Chapter overview</h5>
      <div class="ibox-tools">
        <%= link_to edit_notebook_chapter_path(@notebook, @chapter), class: "btn btn-sm btn-icon notebook-overview-edit-button", title: "Edit chapter", aria: { label: "Edit chapter" } do %>
          <i class="ti ti-edit" aria-hidden="true"></i>
        <% end %>
        <%= render "shared/ibox_toggle_button", target_id: dom_id(@chapter, :overview_content) %>
      </div>
    </div>
    <div id="<%= dom_id(@chapter, :overview_content) %>" class="ibox-content collapse show">
      <div class="row">
        <div class="col-sm-12">
          <h2 class="m-t-none"><%= @chapter.title %></h2>
          <p class="text-muted"><%= @chapter.description.presence || "Add a description if you want to clarify the purpose of this chapter." %></p>
          <p class="m-b-none">
            <span class="label label-default">Order: <%= @chapter.position %></span>
            <span class="label label-default"><%= pluralize(@pages.count, "page") %></span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Pages</h5>
      <div class="ibox-tools">
        <%= link_to new_notebook_chapter_page_path(@notebook, @chapter),
          class: "ibox-toggle-button notebook-detail-section__add",
          title: "Add page",
          aria: { label: "Add page" } do %>
          <i class="ti ti-plus" aria-hidden="true"></i>
        <% end %>
        <%= render "shared/ibox_toggle_button", target_id: dom_id(@chapter, :pages_content) %>
      </div>
    </div>
    <div id="<%= dom_id(@chapter, :pages_content) %>" class="ibox-content collapse show <%= "notebook-detail-page-list-content" if @pages.any? %>">
      <% if @pages.any? %>
        <div class="notebook-list-stack notebook-list-stack--separated">
          <% @pages.each do |page| %>
            <%= render "pages/page_card", notebook: @notebook, chapter: @chapter, page: page %>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No pages yet", description: "Add the first page to capture notes, upload photos, and store a date inside this chapter." %>
      <% end %>
    </div>
  </section>
</div>
