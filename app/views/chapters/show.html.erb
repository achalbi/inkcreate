<div class="wrapper wrapper-content animated fadeInRight">
  <nav aria-label="breadcrumb" class="m-b-md">
    <ol class="breadcrumb">
      <li><%= link_to "Home", dashboard_path %></li>
      <li><%= link_to "Notebook", notebooks_path %></li>
      <li><%= link_to @notebook.title, notebook_path(@notebook) %></li>
      <li class="active"><%= @chapter.title %></li>
    </ol>
  </nav>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Chapter overview</h5>
      <div class="ibox-tools">
        <span class="label label-default">Notebook section</span>
      </div>
    </div>
    <div class="ibox-content">
      <div class="row">
        <div class="col-sm-8">
          <h2 class="m-t-none"><%= @chapter.title %></h2>
          <p class="text-muted"><%= @chapter.description.presence || "Add a description if you want to clarify the purpose of this chapter." %></p>
          <p class="m-b-none">
            <span class="label label-default">Order: <%= @chapter.position %></span>
            <span class="label label-default"><%= pluralize(@pages.count, "page") %></span>
          </p>
        </div>
        <div class="col-sm-4">
          <div class="m-t-sm">
          <%= link_to "New page", new_notebook_chapter_page_path(@notebook, @chapter), class: "btn btn-primary btn-sm" %>
          <%= link_to "Edit chapter", edit_notebook_chapter_path(@notebook, @chapter), class: "btn btn-white btn-sm" %>
          <%= button_to "Delete chapter", notebook_chapter_path(@notebook, @chapter),
            method: :delete,
            form: { style: "display: inline-block; margin: 0;", onsubmit: "return confirm('Delete this chapter and all of its pages?');" },
            class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Pages</h5>
      <div class="ibox-tools">
        <%= link_to "Add page", new_notebook_chapter_page_path(@notebook, @chapter), class: "btn btn-primary btn-sm" %>
      </div>
    </div>
    <div class="ibox-content">
      <p class="text-muted m-b-md">Pages store the notes, photos, and capture dates inside this chapter.</p>
      <% if @pages.any? %>
        <% @pages.each do |page| %>
          <div class="panel panel-default">
            <div class="panel-body">
              <div class="row">
                <div class="col-sm-8">
                  <h4 class="m-t-none m-b-xs">
                    <%= link_to page.title, notebook_chapter_page_path(@notebook, @chapter, page) %>
                    <small>Page <%= page.position %></small>
                  </h4>
                  <p class="text-muted m-b-sm"><%= page.notes.to_s.truncate(140).presence || "No notes yet." %></p>
                  <p class="small text-muted m-b-none">
                    <% if page.captured_on.present? %>
                      Captured <%= page.captured_on.strftime("%b %-d, %Y") %>
                    <% else %>
                      No capture date yet
                    <% end %>
                  </p>
                </div>
                <div class="col-sm-4">
                  <p class="m-b-sm m-t-none"><span class="label label-info"><%= pluralize(page.photos.count, "photo") %></span></p>
                  <p class="m-b-none">
                    <%= button_to "Up", move_notebook_chapter_page_path(@notebook, @chapter, page, direction: :up),
                      method: :patch,
                      form: { style: "display: inline-block; margin: 0;" },
                      class: "btn btn-white btn-sm" %>
                    <%= button_to "Down", move_notebook_chapter_page_path(@notebook, @chapter, page, direction: :down),
                      method: :patch,
                      form: { style: "display: inline-block; margin: 0;" },
                      class: "btn btn-white btn-sm" %>
                    <%= link_to "Open", notebook_chapter_page_path(@notebook, @chapter, page), class: "btn btn-primary btn-sm" %>
                    <%= link_to "Edit", edit_notebook_chapter_page_path(@notebook, @chapter, page), class: "btn btn-white btn-sm" %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "No pages yet", description: "Add the first page to capture notes, upload photos, and store a date inside this chapter." %>
      <% end %>
    </div>
  </section>
</div>
