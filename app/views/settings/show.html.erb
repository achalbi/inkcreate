<div class="workspace-page settings-page settings-page--overview">
  <%= render "shared/workspace_header",
    # breadcrumbs: [["Home", dashboard_path], "Settings"],
    eyebrow: "Settings",
    title: "Privacy, storage, OCR mode, AI, and backup controls.",
    description: "The app stays local-first, explicit, and editable by making operational controls visible." %>

  <div class="row g-3">
    <div class="col-lg-6">
      <%= render "settings/time_zone_box" %>
    </div>

    <div class="col-lg-6">
      <%= render "settings/google_drive_box", detailed: true %>
    </div>

    <div class="col-lg-6">
      <% backup_enabled_value = @app_setting.backup_enabled.nil? ? true : @app_setting.backup_enabled %>
      <% backup_provider_value = @app_setting.backup_provider.presence || "google_drive" %>
      <section class="ibox h-100">
        <div class="ibox-title">
          <h5>Backup behavior</h5>
          <div class="ibox-tools">
            <%= render "shared/ibox_toggle_button", target_id: "settings-backup-behavior-content", expanded: false %>
          </div>
        </div>
        <div id="settings-backup-behavior-content" class="ibox-content collapse">
          <p class="text-secondary mb-4">Turn Drive backup on only after the connection and destination folder are ready.</p>

          <%= form_with model: @app_setting, url: settings_backup_path, method: :patch do |form| %>
            <div class="mb-3">
              <%= form.label :backup_enabled, "Enable backups", class: "form-label" %>
              <%= form.select :backup_enabled,
                options_for_select([["No", false], ["Yes", true]], backup_enabled_value),
                {},
                class: "form-select" %>
            </div>

            <div class="mb-4">
              <%= form.label :backup_provider, "Provider", class: "form-label" %>
              <%= form.select :backup_provider,
                options_for_select([["None", ""], ["Google Drive", "google_drive"]], backup_provider_value),
                {},
                class: "form-select" %>
            </div>

            <%= form.submit "Save backup settings", class: "btn btn-primary" %>
          <% end %>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <%= render "settings/privacy_box" %>
    </div>

    <div class="col-lg-6">
      <%= render "settings/notification_box" %>
    </div>

    <div class="col-lg-6">
      <section class="ibox h-100">
        <div class="ibox-title">
          <h5>Current app posture</h5>
        </div>
        <div class="ibox-content">
          <div class="vstack gap-3">
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="text-uppercase text-secondary fw-semibold small mb-1">OCR mode</div>
              <div class="fw-semibold"><%= @app_setting.ocr_mode %></div>
              <div class="text-secondary small">OCR is manual-only by design so capture speed never depends on text extraction.</div>
            </div>
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="text-uppercase text-secondary fw-semibold small mb-1">AI enabled</div>
              <div class="fw-semibold"><%= @app_setting.ai_enabled? ? "Yes" : "No" %></div>
              <div class="text-secondary small">AI enrichment is explicit and opt-in for each capture.</div>
            </div>
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="text-uppercase text-secondary fw-semibold small mb-1">Backup enabled</div>
              <div class="fw-semibold"><%= @app_setting.backup_enabled? ? "Yes" : "No" %></div>
              <div class="text-secondary small">Backups remain optional and user-controlled.</div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="ibox h-100">
        <div class="ibox-title">
          <h5>Storage health</h5>
        </div>
        <div class="ibox-content">
          <div class="vstack gap-3 mb-4">
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="fw-semibold"><%= @storage_stats[:captures] %> captures</div>
              <div class="text-secondary small">Primary note records persisted on the server.</div>
            </div>
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="fw-semibold"><%= @storage_stats[:attachments] %> attachments</div>
              <div class="text-secondary small">Supporting media and links attached to captures.</div>
            </div>
            <div class="border rounded-4 p-3 bg-light-subtle">
              <div class="fw-semibold"><%= @storage_stats[:pending_sync_jobs] %> pending sync jobs</div>
              <div class="text-secondary small">Deferred operations waiting for a clean client-server handshake.</div>
            </div>
          </div>

          <div class="border-top mt-4 pt-4">
            <div class="text-uppercase text-secondary fw-semibold small mb-2">Legal</div>
            <div class="text-secondary small mb-3">Review the public legal pages that cover how Inkcreate handles service usage and personal data.</div>

            <div class="d-flex flex-wrap gap-2">
              <%= link_to "Privacy Policy", privacy_policy_path, class: "btn btn-outline-secondary" %>
              <%= link_to "Terms of Service", terms_of_service_path, class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="ibox">
        <div class="ibox-title">
          <h5>Capture backup history</h5>
          <span class="badge rounded-pill text-bg-light"><%= @backup_records.size %> recent records</span>
        </div>
        <div class="ibox-content">
          <% if @backup_records.any? %>
            <div class="vstack gap-3">
              <% @backup_records.each do |backup_record| %>
                <article class="border rounded-4 p-3">
                  <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                    <div class="min-w-0">
                      <div class="text-uppercase text-secondary fw-semibold small mb-1"><%= backup_record.provider.humanize %></div>
                      <div class="fw-semibold break-anywhere"><%= link_to backup_record.capture.display_title, capture_path(backup_record.capture), class: "text-decoration-none" %></div>
                    </div>
                    <span class="badge rounded-pill text-bg-light"><%= backup_record.status.humanize %></span>
                  </div>
                  <div class="text-secondary small break-anywhere"><%= backup_record_detail_text(backup_record) %></div>
                </article>
              <% end %>
            </div>
          <% else %>
            <%= render "shared/empty_state", title: "No backup records yet", description: "Run a manual backup from a capture detail page to seed the history." %>
          <% end %>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="ibox">
        <div class="ibox-title">
          <h5>Record export history</h5>
          <span class="badge rounded-pill text-bg-light"><%= @record_exports.size %> recent exports</span>
        </div>
        <div class="ibox-content">
          <% if @record_exports.any? %>
            <div class="vstack gap-3">
              <% @record_exports.each do |google_drive_export| %>
                <article class="border rounded-4 p-3">
                  <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                    <div class="min-w-0">
                      <div class="text-uppercase text-secondary fw-semibold small mb-1"><%= google_drive_export.exportable_type.to_s.humanize %></div>
                      <% if (destination_path = google_drive_export_path(google_drive_export)).present? %>
                        <div class="fw-semibold break-anywhere"><%= link_to google_drive_export_title(google_drive_export), destination_path, class: "text-decoration-none" %></div>
                      <% else %>
                        <div class="fw-semibold break-anywhere"><%= google_drive_export_title(google_drive_export) %></div>
                      <% end %>
                    </div>
                    <span class="badge rounded-pill text-bg-light"><%= google_drive_export.status.humanize %></span>
                  </div>
                  <div class="text-secondary small break-anywhere"><%= google_drive_export_detail_text(google_drive_export) %></div>
                </article>
              <% end %>
            </div>
          <% else %>
            <%= render "shared/empty_state", title: "No record exports yet", description: "Enable Drive backup and edit a notebook or notepad page to start the export history." %>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
