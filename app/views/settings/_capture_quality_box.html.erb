<section class="ibox h-100">
  <div class="ibox-title">
    <h5>Capture quality</h5>
    <div class="ibox-tools">
      <%= render "shared/ibox_toggle_button", target_id: "settings-capture-quality-content", expanded: false %>
    </div>
  </div>
  <div id="settings-capture-quality-content" class="ibox-content collapse">
    <p class="text-secondary mb-4">Choose how browser-based image capture should balance file size and detail for photos and scanned documents.</p>

    <%= form_with url: settings_capture_quality_path, method: :patch, scope: :app_setting do |form| %>
      <div class="vstack gap-3 mb-4">
        <% AppSetting::CAPTURE_QUALITY_PROFILES.each do |preset, profile| %>
          <section class="border rounded-4 p-3 bg-light-subtle">
            <div class="fw-semibold mb-1"><%= profile.fetch("label") %></div>
            <div class="text-secondary small mb-3"><%= profile.fetch("description") %></div>
            <div class="form-check">
              <%= form.radio_button :capture_quality_preset,
                preset,
                checked: @app_setting.capture_quality_preset == preset,
                class: "form-check-input",
                id: "app_setting_capture_quality_preset_#{preset}" %>
              <%= form.label :"capture_quality_preset_#{preset}",
                "Use #{profile.fetch("label")}",
                for: "app_setting_capture_quality_preset_#{preset}",
                class: "form-check-label" %>
            </div>
          </section>
        <% end %>
      </div>

      <%= form.submit "Save capture quality", class: "btn btn-primary" %>
    <% end %>
  </div>
</section>
