<article class="notebook-list-card notebook-list-card--chapter notebook-list-card--reminder">
  <div class="notebook-list-card__body position-relative">
    <div class="notebook-list-card__content notebook-list-card__content--chapter">
      <div class="notebook-list-card__symbol home-reminder-card__symbol" aria-hidden="true">
        <i class="ti ti-bell-ringing"></i>
      </div>

      <div class="notebook-list-card__main">
        <div class="notebook-list-card__header home-reminder-card__header">
          <div class="notebook-list-card__header-copy">
            <div class="notebook-list-card__title-row">
              <h6 class="notebook-list-card__title">
                <%= link_to reminder.title,
                  reminder_path(reminder),
                  class: "stretched-link text-reset text-decoration-none home-reminder-card__title-link",
                  aria: { label: "Open reminder #{reminder.title}" } %>
              </h6>
              <span class="label label-default notebook-list-card__status home-reminder-card__status"><%= reminder.status.humanize %></span>
            </div>
          </div>

          <div class="notebook-list-card__header-tools home-reminder-card__tools">
            <% unless reminder.standalone? %>
              <%= link_to reminder.destination_path,
                class: "btn btn-sm btn-icon notebook-overview-edit-button home-reminder-card__tool home-reminder-card__tool--source",
                title: "Open source",
                aria: { label: "Open source for #{reminder.title}" } do %>
                <i class="ti ti-link" aria-hidden="true"></i>
              <% end %>
            <% end %>

            <% if reminder.status_pending? || reminder.status_snoozed? %>
              <%= button_tag type: "button",
                class: "btn btn-sm btn-icon notebook-overview-edit-button home-reminder-card__tool home-reminder-card__tool--snooze",
                title: "Snooze reminder",
                aria: { label: "Snooze reminder" },
                data: {
                  action: "reminder-snooze#open",
                  reminder_snooze_url: snooze_reminder_path(reminder),
                  reminder_snooze_title: reminder.title
                } do %>
                <i class="ti ti-clock-hour-4" aria-hidden="true"></i>
              <% end %>
            <% end %>
          </div>
        </div>

        <p class="notebook-list-card__description home-reminder-card__description"><%= reminder_source_label(reminder) %></p>

        <div class="notebook-list-card__meta notebook-list-card__meta--chapter home-reminder-card__meta">
          <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
            <i class="ti ti-clock-hour-4" aria-hidden="true"></i>
            <%= reminder_relative_time(reminder) %>
          </span>

          <span class="notebook-list-card__meta-item notebook-list-card__meta-item--chapter">
            <i class="ti ti-calendar-event" aria-hidden="true"></i>
            <%= reminder.fire_at.in_time_zone.strftime("%b %-d at %-I:%M %p") %>
          </span>
        </div>
      </div>
    </div>
  </div>
</article>
