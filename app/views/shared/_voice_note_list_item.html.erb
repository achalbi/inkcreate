<%
  delete_modal_id = dom_id(voice_note, :delete_confirm_modal)
  recorded_at_label = voice_note.recorded_at.in_time_zone.strftime("%b %-d, %Y at %-I:%M %p")
  duration_label = voice_note_duration_label(voice_note.duration_seconds)
  audio_url = if respond_to?(:rails_storage_proxy_path)
    rails_storage_proxy_path(voice_note.audio, only_path: true)
  else
    rails_blob_path(voice_note.audio, only_path: true)
  end
  download_url = rails_blob_path(voice_note.audio, disposition: "attachment", only_path: true)
  download_name = voice_note.audio.filename.to_s
%>

<article class="notebook-list-card voice-note-list-card">
  <div class="notebook-list-card__body">
    <div class="notebook-list-card__content notebook-list-card__content--chapter">
      <div class="notebook-list-card__symbol" aria-hidden="true">
        <i class="ti ti-microphone"></i>
      </div>

      <div class="notebook-list-card__main">
        <div class="notebook-list-card__header">
          <div class="notebook-list-card__header-copy">
            <h6 class="notebook-list-card__title">Recorded <%= recorded_at_label %></h6>
          </div>
        </div>

        <div class="notebook-list-card__meta">
          <span class="notebook-list-card__meta-item">
            <i class="ti ti-wave-sine" aria-hidden="true"></i>
            <strong><%= duration_label %></strong>
          </span>
          <span class="notebook-list-card__meta-dot" aria-hidden="true">&middot;</span>
          <span class="notebook-list-card__meta-item">
            <i class="ti ti-database" aria-hidden="true"></i>
            <strong><%= number_to_human_size(voice_note.byte_size) %></strong>
          </span>
        </div>
      </div>

      <div
        class="voice-note-player"
        data-controller="voice-note-player"
        data-voice-note-player-duration-value="<%= voice_note.duration_seconds.to_i %>"
        data-voice-note-player-url-value="<%= audio_url %>"
      >
        <div class="voice-note-player__surface">
          <button
            type="button"
            class="btn btn-white btn-sm btn-icon voice-note-player__toggle"
            data-action="voice-note-player#toggle"
            data-voice-note-player-target="playButton"
            aria-label="Play voice note recorded <%= recorded_at_label %>"
          >
            <i class="ti ti-player-play" data-voice-note-player-target="playIcon" aria-hidden="true"></i>
          </button>

          <div class="voice-note-player__content">
            <div
              class="voice-note-player__timeline"
              role="slider"
              tabindex="0"
              aria-label="Seek voice note recorded <%= recorded_at_label %>"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="0"
              aria-valuetext="00:00 of <%= duration_label %>"
              data-action="click->voice-note-player#seek keydown->voice-note-player#seekWithKeyboard"
              data-voice-note-player-target="timeline"
            >
              <div class="voice-note-player__waveform" data-voice-note-player-target="waveform" aria-hidden="true"></div>
            </div>

            <div class="voice-note-player__timing">
              <span
                class="voice-note-player__time voice-note-player__time--elapsed"
                data-voice-note-player-target="elapsedLabel"
              >
                00:00
              </span>
              <span
                class="voice-note-player__time voice-note-player__time--duration"
                data-voice-note-player-target="durationLabel"
              >
                <%= duration_label %>
              </span>
            </div>
          </div>

          <div class="btn-group-vertical voice-note-player__actions" aria-label="Voice note actions" role="group">
            <%= link_to download_url,
              class: "btn btn-white btn-sm voice-note-player__action voice-note-player__action--download",
              download: download_name,
              aria: { label: "Download voice note recorded #{recorded_at_label}" } do %>
              <i class="ti ti-download" aria-hidden="true"></i>
            <% end %>

            <button
              type="button"
              class="btn btn-white btn-sm voice-note-player__action voice-note-player__action--delete"
              aria-label="Delete voice note recorded <%= recorded_at_label %>"
              data-bs-toggle="modal"
              data-bs-target="#<%= delete_modal_id %>"
            >
              <i class="ti ti-trash" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= render "shared/voice_note_delete_confirm_modal",
    modal_id: delete_modal_id,
    delete_path: delete_path,
    message: "This voice note recorded on #{recorded_at_label} will be removed." %>
</article>
