<%
  show_workspace_sidebar = local_assigns.fetch(:show_workspace_sidebar, current_user&.admin?)
  shell_eyebrow, shell_title =
    case controller_path
    when "home"
      ["Home", "Workspace"]
    when "notebooks", "chapters", "pages"
      ["Notebook", "Project notebooks"]
    when "notepad_entries"
      ["Notepad", "Daily note capture"]
    when "settings", "settings/backup", "settings/privacy"
      ["Settings", "Workspace preferences"]
    when "search"
      ["Search", "Find captured notes"]
    else
      ["Workspace", "Inkcreate"]
    end
%>

<nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3 px-lg-4">
  <div class="d-flex align-items-center gap-2 flex-grow-1 min-w-0">
    <% if show_workspace_sidebar %>
      <button id="toggleBtn" class="d-none d-lg-inline-flex btn btn-light btn-icon btn-sm" type="button">
        <i class="ti ti-layout-sidebar-left-expand"></i>
      </button>

      <button id="mobileBtn" class="btn btn-light btn-icon btn-sm d-lg-none" type="button">
        <i class="ti ti-layout-sidebar-left-expand"></i>
      </button>
    <% end %>

    <div class="<%= [("ms-2" if show_workspace_sidebar), "min-w-0"].compact.join(" ") %>">
      <div class="text-uppercase text-secondary fw-semibold small"><%= shell_eyebrow %></div>
      <div class="fw-semibold text-truncate"><%= shell_title %></div>
    </div>
  </div>

  <div class="d-flex align-items-center gap-2 admin-topbar-actions">
    <%= form_tag search_page_path, method: :get, class: "d-none d-lg-flex align-items-center gap-2" do %>
      <%= text_field_tag :q, params[:q], class: "form-control form-control-sm", placeholder: "Search notes...", style: "width: 220px;" %>
    <% end %>

    <%= link_to new_notebook_path, class: "btn btn-primary d-none d-md-inline-flex" do %>
      <i class="ti ti-notebook me-1"></i>
      <span>New notebook</span>
    <% end %>

    <%= link_to new_notepad_entry_path, class: "btn btn-outline-secondary d-none d-md-inline-flex" do %>
      <i class="ti ti-calendar-plus me-1"></i>
      <span>New entry</span>
    <% end %>

    <div class="dropdown">
      <button type="button" data-bs-toggle="dropdown" data-shell-dropdown-backdrop aria-expanded="false" class="btn p-0 border-0 bg-transparent text-decoration-none">
        <span class="table-avatar"><%= current_user.email.first.upcase %></span>
      </button>
      <div class="dropdown-menu dropdown-menu-end shadow-sm border-0 p-0" style="min-width: 16rem;">
        <div class="px-3 py-3 border-bottom">
          <div class="admin-topbar-status">Signed in as</div>
          <strong class="break-anywhere"><%= current_user.email %></strong>
          <div class="admin-topbar-status"><%= current_user.role.humanize %> workspace</div>
        </div>
        <div class="p-2 d-grid gap-1">
          <%= link_to "Home", dashboard_path, class: "dropdown-item rounded-2" %>
          <%= link_to "Notebook", notebooks_path, class: "dropdown-item rounded-2" %>
          <%= link_to "Notepad", notepad_entries_path, class: "dropdown-item rounded-2" %>
          <%= link_to "Settings", settings_path, class: "dropdown-item rounded-2" %>
          <% if current_user.admin? %>
            <%= link_to "Admin console", admin_dashboard_path, class: "dropdown-item rounded-2" %>
          <% end %>
        </div>
        <div class="border-top p-2">
          <%= button_to "Sign out", browser_sign_out_path, method: :delete, class: "btn btn-outline-danger w-100", form_class: "d-grid" %>
        </div>
      </div>
    </div>
  </div>
</nav>
