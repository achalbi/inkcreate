<div class="form-group m-t-md" data-controller="photo-capture">
  <div class="clearfix m-b-sm">
    <div class="pull-left">
      <%= form.label field_name, label, class: "control-label" %>
      <div class="text-muted small">Use the rear phone camera for live preview capture, or fall back to the phone camera or gallery picker.</div>
    </div>
    <div class="pull-right m-t-xs">
      <span class="label label-default">Pending photos: <span data-photo-capture-target="count">0</span></span>
    </div>
  </div>

  <div class="row">
    <div class="col-sm-8">
      <div class="well well-sm text-center" data-photo-capture-target="cameraFrame" style="min-height: 260px; display: flex; align-items: center; justify-content: center; border: 2px dashed #e7eaec; border-radius: 6px; background: #fcfcfc;">
        <div class="small text-muted" style="max-width: 260px;">
        <strong>Live camera preview</strong>
        <p class="mb-0">Use the rear camera, keep the A5 page inside the frame, and capture when the notes look sharp.</p>
        </div>
      </div>
    </div>

    <div class="col-sm-4">
      <div class="panel panel-default">
        <div class="panel-body">
          <p class="text-navy m-b-xs"><strong>A5 capture tips</strong></p>
          <ul class="small text-muted m-b-none" style="padding-left: 18px;">
            <li>Keep the book flat with the whole page visible inside the guide.</li>
            <li>Use even lighting and avoid hard shadows from your hand or phone.</li>
            <li>Hold the camera directly above the notes for a cleaner save.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="m-t-sm">
    <button type="button" class="btn btn-primary btn-sm" data-action="photo-capture#start">Start live camera</button>
    <button type="button" class="btn btn-white btn-sm" data-action="photo-capture#capture">Capture photo</button>
    <button type="button" class="btn btn-white btn-sm" data-action="photo-capture#stop">Stop preview</button>
    <label class="btn btn-white btn-sm m-b-none">
      Use phone camera or gallery
      <%= form.file_field field_name, multiple: true, style: "display:none;", accept: "image/*", capture: "environment", data: { photo_capture_target: "input", action: "change->photo-capture#syncFromInput" } %>
    </label>
  </div>

  <div class="m-t-md">
    <p class="text-navy m-b-xs"><strong>Pending uploads</strong></p>
    <div class="row" data-photo-capture-target="previewGrid"></div>
    <div class="alert alert-info m-b-none" data-photo-capture-target="emptyState">
      No new photos selected yet. Start the camera or use the phone picker to attach note images before saving.
    </div>
  </div>
</div>
