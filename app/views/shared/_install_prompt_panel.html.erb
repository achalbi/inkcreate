<% variant = local_assigns.fetch(:variant, :landing).to_sym %>
<% panel_body_id = "install-prompt-#{variant}-content" %>

<% if variant == :workspace %>
  <section class="row g-2 g-md-3 m-b-sm">
    <div class="col-12">
      <div class="ibox float-e-margins" data-controller="install-prompt">
        <div class="ibox-title">
          <h5>Install Inkcreate</h5>
          <div class="ibox-tools">
            <span class="label label-info">Mobile PWA</span>
            <button
              type="button"
              class="ibox-toggle-button"
              aria-expanded="true"
              aria-controls="<%= panel_body_id %>"
              title="Collapse section"
              aria-label="Collapse section"
              data-install-prompt-target="collapseButton"
              data-action="install-prompt#toggleCollapse"
            >
              <svg class="ibox-toggle-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 15l6-6 6 6"></path>
              </svg>
            </button>
          </div>
        </div>

        <div id="<%= panel_body_id %>" class="ibox-content" data-install-prompt-target="panelBody">
          <p class="m-b-sm">
            Install Inkcreate on your phone for faster launch, app-like navigation, and offline shell access while you capture on the move.
          </p>
          <p class="text-muted m-b-md">
            Android Chrome can open the install prompt directly. iPhone Safari works with Share → Add to Home Screen.
          </p>

          <div class="workspace-form-actions">
            <button
              class="btn btn-primary btn-sm"
              type="button"
              data-install-prompt-target="promptButton"
              data-action="install-prompt#prompt"
            >
              Install app on mobile
            </button>
            <%= link_to "Install guide", install_path, class: "btn btn-white btn-sm" %>
          </div>

          <div class="alert alert-info m-t-md m-b-none" data-install-prompt-target="notificationSetup" hidden>
            <strong class="d-block m-b-xs">Enable background sync updates</strong>
            <p class="m-b-sm" data-install-prompt-target="notificationStatus">
              Install accepted. Finish setup by allowing notifications for background upload and sync updates on this device.
            </p>
            <button
              class="btn btn-primary btn-sm"
              type="button"
              data-install-prompt-target="notificationButton"
              data-action="install-prompt#requestNotifications"
            >
              Enable notifications
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
<% elsif variant == :install %>
  <div class="page-shell">
    <section class="section-card" data-controller="install-prompt">
      <div class="install-prompt-header">
        <div class="section-header install-prompt-header-main">
          <div class="eyebrow">Install</div>
          <h1>Install Inkcreate like an app.</h1>
        </div>

        <button
          type="button"
          class="ibox-toggle-button"
          aria-expanded="true"
          aria-controls="<%= panel_body_id %>"
          title="Collapse section"
          aria-label="Collapse section"
          data-install-prompt-target="collapseButton"
          data-action="install-prompt#toggleCollapse"
        >
          <svg class="ibox-toggle-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 15l6-6 6 6"></path>
          </svg>
        </button>
      </div>

      <div id="<%= panel_body_id %>" data-install-prompt-target="panelBody">
        <p class="install-prompt-summary">Android Chrome gets the strongest install flow. iPhone Safari works with a guided “Add to Home Screen” fallback.</p>

        <div class="feature-grid">
          <article class="feature-card">
            <div class="pill">Android Chrome</div>
            <h3>Best install path</h3>
            <p>Use the browser install prompt when available, then keep capture and sync behavior app-like.</p>
          </article>
          <article class="feature-card">
            <div class="pill">iPhone Safari</div>
            <h3>Manual install guidance</h3>
            <p>Share → Add to Home Screen remains the fallback path, so the UI should explain it clearly.</p>
          </article>
          <article class="feature-card">
            <div class="pill">Offline support</div>
            <h3>Cached shell</h3>
            <p>The service worker keeps the shell and queued drafts usable when the network disappears.</p>
          </article>
        </div>

        <div class="dashboard-actions">
          <button
            class="button button-primary"
            type="button"
            data-install-prompt-target="promptButton"
            data-action="install-prompt#prompt"
          >
            Try install prompt
          </button>
          <%= link_to "Open onboarding", onboarding_path, class: "button button-secondary" %>
        </div>

        <article class="feature-card mt-4" data-install-prompt-target="notificationSetup" hidden>
          <div class="pill">Notifications</div>
          <h3>Enable background sync updates</h3>
          <p data-install-prompt-target="notificationStatus">Install accepted. Finish setup by allowing notifications for background upload and sync updates on this device.</p>
          <div class="dashboard-actions">
            <button
              class="button button-primary"
              type="button"
              data-install-prompt-target="notificationButton"
              data-action="install-prompt#requestNotifications"
            >
              Enable notifications
            </button>
          </div>
        </article>
      </div>
    </section>
  </div>
<% else %>
  <section class="section-card" data-controller="install-prompt">
    <div class="install-prompt-header">
      <div class="section-header install-prompt-header-main">
        <div class="eyebrow">Install on mobile</div>
        <h2>Keep Inkcreate one tap away from your home screen.</h2>
      </div>

      <button
        type="button"
        class="ibox-toggle-button"
        aria-expanded="true"
        aria-controls="<%= panel_body_id %>"
        title="Collapse section"
        aria-label="Collapse section"
        data-install-prompt-target="collapseButton"
        data-action="install-prompt#toggleCollapse"
      >
        <svg class="ibox-toggle-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 15l6-6 6 6"></path>
        </svg>
      </button>
    </div>

    <div id="<%= panel_body_id %>" data-install-prompt-target="panelBody">
      <p class="install-prompt-summary">
        Open Inkcreate like an app on your phone for faster capture, offline shell access, and a cleaner return to notebooks and notepad.
      </p>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="pill">Android Chrome</div>
          <h3>One-tap install prompt</h3>
          <p>Use the browser prompt when it appears to pin Inkcreate directly from the landing page.</p>
        </article>
        <article class="feature-card">
          <div class="pill">iPhone Safari</div>
          <h3>Add to Home Screen</h3>
          <p>Use Share → Add to Home Screen when Safari does not expose the browser install prompt.</p>
        </article>
        <article class="feature-card">
          <div class="pill">After install</div>
          <h3>Enable notifications</h3>
          <p>Turn on notifications for background upload and sync updates after the app is added to your device.</p>
        </article>
      </div>

      <div class="dashboard-actions">
        <button
          class="button button-primary"
          type="button"
          data-install-prompt-target="promptButton"
          data-action="install-prompt#prompt"
        >
          Install app on mobile
        </button>
        <%= link_to "See install steps", install_path, class: "button button-secondary" %>
      </div>

      <article class="feature-card mt-4" data-install-prompt-target="notificationSetup" hidden>
        <div class="pill">Notifications</div>
        <h3>Finish device setup</h3>
        <p data-install-prompt-target="notificationStatus">Install accepted. Finish setup by allowing notifications for background upload and sync updates on this device.</p>
        <div class="dashboard-actions">
          <button
            class="button button-primary"
            type="button"
            data-install-prompt-target="notificationButton"
            data-action="install-prompt#requestNotifications"
          >
            Enable notifications
          </button>
        </div>
      </article>
    </div>
  </section>
<% end %>
