<% http_method = local_assigns.fetch(:method, :get).to_sym %>
<% class_name = ["workspace-fab", local_assigns[:class_name]].compact.join(" ") %>

<% if http_method == :get %>
  <%= link_to path,
    class: "#{class_name} d-lg-none",
    title: title,
    aria: { label: title } do %>
    <i class="ti ti-plus" aria-hidden="true"></i>
  <% end %>
<% else %>
  <%= button_to path,
    method: http_method,
    class: class_name,
    form_class: "button_to workspace-fab-form d-lg-none",
    title: title,
    aria: { label: title } do %>
    <i class="ti ti-plus" aria-hidden="true"></i>
  <% end %>
<% end %>
