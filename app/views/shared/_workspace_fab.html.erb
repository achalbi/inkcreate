<% http_method = local_assigns.fetch(:method, :get).to_sym %>

<% if http_method == :get %>
  <%= link_to path,
    class: "workspace-fab d-lg-none",
    title: title,
    aria: { label: title } do %>
    <i class="ti ti-plus" aria-hidden="true"></i>
  <% end %>
<% else %>
  <%= button_to path,
    method: http_method,
    class: "workspace-fab",
    form_class: "button_to workspace-fab-form d-lg-none",
    title: title,
    aria: { label: title } do %>
    <i class="ti ti-plus" aria-hidden="true"></i>
  <% end %>
<% end %>
