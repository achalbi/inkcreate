<%
  app_setting = local_assigns[:app_setting] || current_user.ensure_app_setting!
  entry_date = Time.zone.today
  storage_key = "workspace-launcher"
  overlay_id = "idle-shortcuts-#{storage_key}"
  title_id = "#{overlay_id}-title"
  reminders_available = Reminder.schema_ready?
  voice_notes_available = VoiceNote.notepad_entries_supported?
  todo_lists_available = TodoList.schema_ready? && TodoItem.schema_ready?
  scanned_documents_available = ScannedDocument.schema_ready?
  scan_entry = current_user.notepad_entries.new(entry_date: entry_date) if scanned_documents_available
  launcher_prefs_supported = app_setting.launcher_preferences_supported?
  continue_scope = launcher_prefs_supported ? app_setting.workspace_launcher_continue_scope : "today"
  continue_scope_update_url = settings_workspace_launcher_path
%>

<div
  id="<%= overlay_id %>"
  class="idle-shortcuts-backdrop"
  data-controller="idle-shortcuts"
  data-idle-shortcuts-idle-ms-value="<%= app_setting.workspace_launcher_idle_timeout_ms %>"
  data-idle-shortcuts-storage-key-value="<%= storage_key %>"
  data-idle-shortcuts-target="overlay"
  data-action="click->idle-shortcuts#backdropClick inkcreate:launcher:open@window->idle-shortcuts#show"
  role="dialog"
  aria-modal="true"
  aria-labelledby="<%= title_id %>"
  style="display:none"
>
  <div class="idle-shortcuts-modal idle-shortcuts-modal--launcher">
    <div class="idle-shortcuts-header idle-shortcuts-header--centered">
      <div class="idle-shortcuts-eyebrow">Workspace launcher</div>
      <h2 id="<%= title_id %>" class="idle-shortcuts-title">Jump into the next thing</h2>
      <p class="idle-shortcuts-description">Move across the workspace, start a fresh daily note action, or head into the general planning tools.</p>
    </div>

    <div class="idle-shortcuts-groups">
      <section class="idle-shortcuts-group">
        <div class="idle-shortcuts-group__header">
          <div class="idle-shortcuts-group__eyebrow">Daily Notepad</div>
          <span class="idle-shortcuts-group__title">Create something new</span>
        </div>

        <% if launcher_prefs_supported %>
          <div
            class="launcher-continue-scope"
            data-controller="launcher-continue-scope"
            data-launcher-continue-scope-url-value="<%= continue_scope_update_url %>"
            data-launcher-continue-scope-csrf-value="<%= form_authenticity_token %>"
            role="radiogroup"
            aria-label="Continue capture in"
          >
            <span class="launcher-continue-scope__label">Continue in</span>
            <div class="launcher-continue-scope__options">
              <% [["today", "Today's page"], ["latest", "Latest page"]].each do |value, label| %>
                <button
                  type="button"
                  class="launcher-continue-scope__option<%= continue_scope == value ? " is-active" : "" %>"
                  role="radio"
                  aria-checked="<%= continue_scope == value %>"
                  data-launcher-continue-scope-target="option"
                  data-scope-value="<%= value %>"
                  data-action="click->launcher-continue-scope#select"
                ><%= label %></button>
              <% end %>
            </div>
          </div>
        <% end %>
        <div class="idle-shortcuts-grid idle-shortcuts-grid--launcher idle-shortcuts-grid--daily" role="list">
          <div class="idle-shortcuts-card-wrap" data-controller="quick-capture" role="listitem">
            <%= form_with url: notepad_entries_path, scope: :notepad_entry, html: { multipart: true }, data: { quick_capture_target: "form" } do |form| %>
              <%= hidden_field_tag :after_create, "edit" %>
              <%= hidden_field_tag :continue, "1" %>
              <%= hidden_field_tag :open, "camera" %>
              <%= form.hidden_field :entry_date, value: entry_date %>
              <%= form.file_field :photos,
                multiple: true,
                accept: "image/*",
                capture: "environment",
                class: "quick-capture-input",
                tabindex: -1,
                aria: { hidden: true },
                data: { quick_capture_target: "cameraInput", action: "change->quick-capture#submitFromSelection" } %>

              <button
                type="button"
                class="idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button"
                data-action="click->idle-shortcuts#hideImmediately click->quick-capture#openCamera"
                data-quick-capture-target="cameraButton"
                title="Capture a photo and create a daily page"
                aria-label="Capture a photo and create a daily page"
              >
                <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                  <i class="ti ti-camera"></i>
                </span>
                <span class="idle-shortcuts-card__title">Capture photo</span>
                <span class="idle-shortcuts-card__description">Create a new daily page from the camera.</span>
              </button>

              <p class="idle-shortcuts-status" data-quick-capture-target="status" hidden></p>
            <% end %>
          </div>

          <% if voice_notes_available %>
            <%= button_tag type: "button",
              class: "idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button",
              data: {
                action: "click->idle-shortcuts#runCommand",
                idle_shortcuts_command: "open-modal",
                idle_shortcuts_modal_id: "workspace-voice-note-modal"
              },
              role: "listitem",
              title: "Record a voice note for a new daily page",
              aria: { label: "Record a voice note for a new daily page" } do %>
              <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                <i class="ti ti-microphone"></i>
              </span>
              <span class="idle-shortcuts-card__title">Record voice note</span>
              <span class="idle-shortcuts-card__description">Record and save audio into a new page.</span>
            <% end %>
          <% end %>

          <% if scanned_documents_available %>
            <%= button_tag type: "button",
              class: "idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button",
              data: {
                action: "click->idle-shortcuts#runCommand",
                idle_shortcuts_command: "open-modal",
                idle_shortcuts_modal_id: "workspace-scan-modal"
              },
              role: "listitem",
              title: "Scan documents into a new daily page",
              aria: { label: "Scan documents into a new daily page" } do %>
              <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                <i class="ti ti-scan"></i>
              </span>
              <span class="idle-shortcuts-card__title">Scan new document</span>
              <span class="idle-shortcuts-card__description">Capture PDFs, receipts, and paper notes.</span>
            <% end %>
          <% end %>

          <% if todo_lists_available %>
            <div class="idle-shortcuts-card-wrap" role="listitem">
              <%= form_with url: notepad_entries_path, scope: :notepad_entry do |form| %>
                <%= hidden_field_tag :after_create, "edit" %>
                <%= hidden_field_tag :continue, "1" %>
                <%= hidden_field_tag :open, "todo" %>
                <%= form.hidden_field :entry_date, value: entry_date %>
                <%= form.hidden_field :todo_list_enabled, value: "true" %>
                <button
                  type="submit"
                  class="idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button"
                  data-action="click->idle-shortcuts#hideImmediately"
                  title="Add a to-do to your daily page"
                  aria-label="Add a to-do to your daily page"
                >
                  <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                    <i class="ti ti-list-check"></i>
                  </span>
                  <span class="idle-shortcuts-card__title">New to-do</span>
                  <span class="idle-shortcuts-card__description">Append a checklist to your daily page.</span>
                </button>
              <% end %>
            </div>
          <% end %>

          <div
            class="idle-shortcuts-card-wrap"
            data-controller="launcher-location-capture"
            role="listitem"
          >
            <%= form_with url: notepad_entries_path,
              scope: :notepad_entry,
              data: { launcher_location_capture_target: "form" } do |form| %>
              <%= hidden_field_tag :after_create, "view" %>
              <%= hidden_field_tag :continue, "1" %>
              <%= hidden_field_tag :stamp_location, "1" %>
              <%= form.hidden_field :entry_date, value: entry_date %>
              <%= form.hidden_field :location_source, value: "current" %>
              <%= form.hidden_field :location_latitude, value: "", data: { launcher_location_capture_target: "latitude" } %>
              <%= form.hidden_field :location_longitude, value: "", data: { launcher_location_capture_target: "longitude" } %>

              <button
                type="button"
                class="idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button"
                data-action="click->idle-shortcuts#hideImmediately click->launcher-location-capture#stamp"
                data-launcher-location-capture-target="button"
                title="Stamp your current GPS on the latest daily page"
                aria-label="Stamp your current GPS on the latest daily page"
              >
                <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                  <i class="ti ti-map-pin"></i>
                </span>
                <span class="idle-shortcuts-card__title">Current location</span>
                <span class="idle-shortcuts-card__description" data-launcher-location-capture-target="status">Stamp your GPS onto the latest page.</span>
              </button>
            <% end %>
          </div>

          <div class="idle-shortcuts-card-wrap" role="listitem">
            <%= form_with url: notepad_entries_path, scope: :notepad_entry do |form| %>
              <%= hidden_field_tag :after_create, "edit" %>
              <%= hidden_field_tag :continue, "1" %>
              <%= hidden_field_tag :open, "contact" %>
              <%= form.hidden_field :entry_date, value: entry_date %>
              <button
                type="submit"
                class="idle-shortcuts-card idle-shortcuts-card--launcher idle-shortcuts-card--button"
                data-action="click->idle-shortcuts#hideImmediately"
                title="Add a contact to your daily page"
                aria-label="Add a contact to your daily page"
              >
                <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                  <i class="ti ti-user-plus"></i>
                </span>
                <span class="idle-shortcuts-card__title">New contact</span>
                <span class="idle-shortcuts-card__description">Save a contact card into your daily page.</span>
              </button>
            <% end %>
          </div>
        </div>
      </section>

      <section class="idle-shortcuts-group">
        <div class="idle-shortcuts-group__header">
          <div class="idle-shortcuts-group__eyebrow">General</div>
          <span class="idle-shortcuts-group__title">Planning and settings</span>
        </div>
        <div class="idle-shortcuts-grid idle-shortcuts-grid--launcher idle-shortcuts-grid--general" role="list">
          <% if reminders_available %>
            <%= link_to reminders_path,
              class: "idle-shortcuts-card idle-shortcuts-card--launcher",
              data: { action: "click->idle-shortcuts#followLink" },
              role: "listitem",
              title: "Open reminders" do %>
              <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
                <i class="ti ti-bell"></i>
              </span>
              <span class="idle-shortcuts-card__title">Reminders</span>
              <span class="idle-shortcuts-card__description">Review upcoming and active reminders.</span>
            <% end %>
          <% end %>

          <%= link_to tasks_path,
            class: "idle-shortcuts-card idle-shortcuts-card--launcher",
            data: { action: "click->idle-shortcuts#followLink" },
            role: "listitem",
            title: "Open the tasks workspace" do %>
            <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
              <i class="ti ti-checkbox"></i>
            </span>
            <span class="idle-shortcuts-card__title">Tasks</span>
            <span class="idle-shortcuts-card__description">Go to the shared task workspace.</span>
          <% end %>

          <%= link_to settings_path,
            class: "idle-shortcuts-card idle-shortcuts-card--launcher",
            data: { action: "click->idle-shortcuts#followLink" },
            role: "listitem",
            title: "Open settings" do %>
            <span class="idle-shortcuts-card__icon-shell" aria-hidden="true">
              <i class="ti ti-settings"></i>
            </span>
            <span class="idle-shortcuts-card__title">Settings</span>
            <span class="idle-shortcuts-card__description">Adjust backup, capture, and app preferences.</span>
          <% end %>
        </div>
      </section>
    </div>

    <div class="idle-shortcuts-actions">
      <button type="button" class="onboarding-btn onboarding-btn--primary idle-shortcuts-continue" data-action="click->idle-shortcuts#continue">
        Continue →
      </button>
    </div>
  </div>
</div>

<% if voice_notes_available %>
  <div class="modal fade" id="workspace-voice-note-modal" tabindex="-1" aria-labelledby="workspace-voice-note-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content workspace-launcher-modal">
        <div class="modal-header">
          <h5 class="modal-title" id="workspace-voice-note-modal-label">New voice note</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body workspace-launcher-modal__body">
          <p class="workspace-launcher-modal__intro">Record a voice note and save it to create today’s daily page in edit mode.</p>
          <%= form_with url: notepad_entries_path, scope: :notepad_entry do |form| %>
            <%= hidden_field_tag :after_create, "edit" %>
            <%= hidden_field_tag :continue, "1" %>
            <%= hidden_field_tag :open, "voice" %>
            <%= form.hidden_field :entry_date, value: entry_date %>
            <%= render "pages/voice_note_recorder",
              form: form,
              mode: :form,
              param_key: "notepad_entry",
              auto_submit_on_save: true,
              start_button_label: "Start recording" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if scanned_documents_available && scan_entry.present? %>
  <div class="modal fade" id="workspace-scan-modal" tabindex="-1" aria-labelledby="workspace-scan-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
      <div class="modal-content workspace-launcher-modal">
        <div class="modal-header">
          <h5 class="modal-title" id="workspace-scan-modal-label">Scan documents</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body workspace-launcher-modal__body workspace-launcher-modal__body--scan">
          <p class="workspace-launcher-modal__intro">Capture one or more scans, then create today’s daily page with the saved PDF and image files attached.</p>
          <%= form_with url: notepad_entries_path, scope: :notepad_entry do |form| %>
            <%= hidden_field_tag :after_create, "edit" %>
            <%= hidden_field_tag :continue, "1" %>
            <%= hidden_field_tag :open, "scan" %>
            <%= form.hidden_field :entry_date, value: entry_date %>
            <%= render "shared/scanned_documents_form_section", form: form, record: scan_entry, dom_prefix: "workspace_scan_entry" %>
            <div class="workspace-launcher-modal__actions">
              <%= form.submit "Create page with scan", class: "btn btn-primary btn-sm", data: { disable_with: "Creating..." } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
