<div class="page-shell">
  <%= render "shared/public_topbar" %>

  <% unless user_signed_in? %>
    <div class="landing-top-cta">
      <%= render "shared/public_auth_cta", show_install_prompt: google_only_auth_mode? %>
    </div>
  <% end %>

  <%# ── HERO ── %>
  <section class="hero">
    <article class="hero-copy">
      <div class="eyebrow">Your handwritten notes, finally searchable</div>
      <h1>Turn notebook pages into digital records.</h1>
      <p>
        Snap a photo of any notebook page. Inkcreate extracts the text in the background,
        organises it by notebook and chapter, and syncs everything to Google Drive — without
        interrupting your flow.
      </p>

      <div class="cta-row">
        <% if user_signed_in? %>
          <a class="button button-primary" href="<%= dashboard_path %>">Open workspace</a>
          <a class="button button-secondary" href="#how-it-works">See how it works</a>
        <% else %>
          <a class="button button-primary" href="<%= public_auth_entry_path %>"><%= google_only_auth_mode? ? "Start with Google" : "Get started free" %></a>
          <a class="button button-secondary" href="#how-it-works">See how it works</a>
        <% end %>
      </div>

      <div class="stat-row">
        <div class="stat">
          <div class="mini-label">Capture</div>
          <strong>Phone-first, any angle</strong>
        </div>
        <div class="stat">
          <div class="mini-label">Extract</div>
          <strong>Background OCR, non-blocking</strong>
        </div>
        <div class="stat">
          <div class="mini-label">Find</div>
          <strong>Full-text search across all pages</strong>
        </div>
      </div>
    </article>

    <aside class="hero-stack" aria-label="Product feature preview">
      <div class="paper-column">
        <article class="paper">
          <span class="paper-accent"></span>
          <div class="mini-label">Notebooks &amp; chapters</div>
          <h3>Structured like a real notebook</h3>
          <p>Create notebooks, divide them into chapters, and add pages — just the way you already think.</p>
        </article>

        <article class="paper">
          <span class="paper-accent"></span>
          <div class="mini-label">Background OCR</div>
          <h3>Text extraction while you work</h3>
          <p>Upload a page photo and keep going. OCR runs in the background and attaches results automatically.</p>
        </article>

        <article class="paper">
          <span class="paper-accent"></span>
          <div class="mini-label">Voice notes</div>
          <h3>Record thoughts in the moment</h3>
          <p>Attach voice memos to any page or notepad entry and play them back right in the workspace.</p>
        </article>

        <article class="paper">
          <span class="paper-accent"></span>
          <div class="mini-label">Google Drive sync</div>
          <h3>Your captures, in Drive automatically</h3>
          <p>Connect Google Drive once and every processed capture lands in your chosen folder.</p>
        </article>
      </div>
    </aside>
  </section>

  <main>
    <%= render "shared/install_prompt_panel", variant: :landing %>

    <%# ── FEATURES ── %>
    <section class="section-card" id="features">
      <div class="section-header">
        <div class="eyebrow">Features</div>
        <h2>Everything your paper workflow needs to go digital.</h2>
        <p>
          Inkcreate is built around how people actually use notebooks —
          not how apps want you to use them.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="pill">Capture Studio</div>
          <h3>Mobile-first camera capture</h3>
          <p>
            A dedicated capture interface optimised for phones. Uploads go straight to cloud
            storage with three quality presets — optimised, high, and original — so you control
            the trade-off between file size and readability.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Notebooks + Notepad</div>
          <h3>Two modes for two rhythms</h3>
          <p>
            Use <strong>Notebooks</strong> for project work — structured by chapter and page.
            Use the <strong>Notepad</strong> for daily capture — organised by date, fast to open,
            no hierarchy required.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Search</div>
          <h3>Find anything you wrote</h3>
          <p>
            Full-text search across every piece of extracted OCR text, title, and tag in your
            workspace. Results link directly to the page or capture where the match lives.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Todo Lists + Tasks</div>
          <h3>Actions live alongside content</h3>
          <p>
            Add inline todo lists to any page or notepad entry. Promote items to the global
            task tracker with one tap, add sub-tasks, and manage everything from the Tasks view.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Voice Notes</div>
          <h3>Capture what you can't write</h3>
          <p>
            Record voice memos directly from a page or notepad entry. Play back recordings
            in-app without leaving your current context.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Google Drive Backup</div>
          <h3>Automatic export, no cleanup needed</h3>
          <p>
            Connect your Drive account once. Processed captures sync to a folder you choose.
            Disconnect at any time and optionally clear all Drive metadata on your way out.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Projects &amp; Daily Logs</div>
          <h3>Cross-notebook organisation</h3>
          <p>
            Assign captures to <strong>Projects</strong> that span multiple notebooks.
            Browse <strong>Daily Logs</strong> to see everything that happened on a given day,
            regardless of which notebook it lives in.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Reminders</div>
          <h3>Don't lose track of follow-ups</h3>
          <p>
            Set time-based reminders on tasks or notepad entries. They surface in the Reminders
            view and push notifications land on any registered device.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Library + Tags</div>
          <h3>Browse your entire archive</h3>
          <p>
            The Library shows every capture in a flat chronological view. Tag captures to create
            horizontal groupings that cut across notebooks, and filter the library by tag.
          </p>
        </article>
      </div>
    </section>

    <%# ── HOW IT WORKS ── %>
    <section class="section-card" id="how-it-works">
      <div class="section-header">
        <div class="eyebrow">How it works</div>
        <h2>From page photo to searchable note in four steps.</h2>
        <p>
          The workflow is intentionally simple. Capture fast, let processing happen in the background,
          then find and use what you captured.
        </p>
      </div>

      <div class="flow">
        <article class="flow-step">
          <div class="mini-label">Step 1 — Capture</div>
          <strong>Photograph the page</strong>
          <p>Open Capture Studio on your phone. The app requests a signed upload URL and sends the image straight to cloud storage so the UI stays fast.</p>
        </article>

        <article class="flow-step">
          <div class="mini-label">Step 2 — Organise</div>
          <strong>Assign context</strong>
          <p>The capture is linked to a notebook page or notepad entry, carrying the OCR provider settings, template hints, and captured date with it.</p>
        </article>

        <article class="flow-step">
          <div class="mini-label">Step 3 — Extract</div>
          <strong>OCR runs in the background</strong>
          <p>Background workers preprocess the image, run text extraction, and attach structured results — all without blocking you or the upload response.</p>
        </article>

        <article class="flow-step">
          <div class="mini-label">Step 4 — Use</div>
          <strong>Search, tag, or export</strong>
          <p>Extracted text is searchable immediately. Tag captures, export to Google Drive, generate AI summaries, or review them in the Library.</p>
        </article>
      </div>
    </section>

    <%# ── CAPTURE SECTION ── %>
    <section class="section-card" id="capture">
      <div class="section-header">
        <div class="eyebrow">Capture</div>
        <h2>Built for real notebooks, not lab-perfect samples.</h2>
        <p>
          Most OCR tools assume clean, flat, evenly-lit documents. Inkcreate is designed for
          the way notebooks actually get photographed: on desks, in bags, under coffee-shop
          lighting, mid-session.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="pill">Quality presets</div>
          <h3>Optimised, High, or Original</h3>
          <p>
            <strong>Optimised</strong> keeps files small for fast uploads. <strong>High</strong>
            preserves fine handwriting detail. <strong>Original</strong> sends the full
            browser-provided resolution with minimal compression.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Async processing</div>
          <h3>Never wait for OCR</h3>
          <p>
            OCR and Drive sync happen entirely off the request path. Upload a page and immediately
            move to the next one — results appear when the job finishes.
          </p>
        </article>

        <article class="feature-card">
          <div class="pill">Reprocessing</div>
          <h3>Fix bad extractions</h3>
          <p>
            If a capture produces poor results, trigger re-extraction from the capture detail view.
            Use the OCR source viewer to inspect exactly what image the engine received.
          </p>
        </article>
      </div>
    </section>

  </main>

  <%= render "shared/public_footer" %>
</div>
