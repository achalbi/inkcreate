<div class="workspace-page">
    <%= render "shared/workspace_header",
      eyebrow: "Fast capture",
      title: "Capture a reusable notebook page.",
      description: "The PWA stores metadata locally first, lets you frame and preview the page, and only runs OCR when you explicitly ask for it later." %>

    <section class="workspace-grid">
      <article class="dashboard-card workspace-panel" data-controller="camera queue">
        <div class="section-header">
          <div class="eyebrow">Camera</div>
          <h2>Capture flow</h2>
          <p>Use camera capture on supported devices, or fall back to the photo library when needed.</p>
        </div>

        <div class="capture-camera-frame" data-camera-target="preview">
          <p>Camera preview initializes here when browser permissions are available.</p>
        </div>

        <div class="dashboard-actions">
          <button class="button button-primary" type="button" data-action="camera#start">Start camera</button>
          <button class="button button-secondary" type="button" data-action="camera#capture">Capture frame</button>
        </div>

        <form class="capture-form" data-queue-target="form">
          <div class="field">
            <label for="capture-title">Title</label>
            <input id="capture-title" name="title" type="text" placeholder="Sprint planning notes">
          </div>

          <div class="auth-form-row">
            <div class="field">
              <label for="capture-page-type">Page type</label>
              <select id="capture-page-type" name="page_type">
                <% @page_templates.each do |page_template| %>
                  <option value="<%= page_template.key %>"><%= page_template.name %></option>
                <% end %>
              </select>
            </div>

            <div class="field">
              <label for="capture-project">Project</label>
              <select id="capture-project" name="project_id">
                <option value="">Save without project</option>
                <% @projects.each do |project| %>
                  <option value="<%= project.id %>"><%= project.title %></option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="auth-form-row">
            <div class="field">
              <label for="capture-destination">Save destination</label>
              <select id="capture-destination" name="save_destination">
                <option value="">Save only</option>
                <option value="today">Add to Today</option>
              </select>
            </div>

            <div class="field">
              <label for="capture-physical-page">Physical page</label>
              <select id="capture-physical-page" name="physical_page_id">
                <option value="">Untracked page</option>
                <% @physical_pages.each do |physical_page| %>
                  <option value="<%= physical_page.id %>">Page <%= physical_page.page_number %> · <%= physical_page.template_type.humanize %></option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="dashboard-actions">
            <button class="button button-primary" type="button" data-action="queue#saveDraft">Save offline draft</button>
            <label class="button button-secondary">
              Upload from gallery
              <input type="file" accept="image/*" capture="environment" hidden data-action="queue#attachFile">
            </label>
          </div>
        </form>
      </article>

      <aside class="dashboard-card workspace-panel">
        <div class="section-header">
          <div class="eyebrow">Offline queue</div>
          <h2>Local-first behavior</h2>
          <p>Draft metadata, thumbnails, and pending uploads stay in IndexedDB until a network path is available.</p>
        </div>
        <div class="admin-note-list" data-controller="offline-status install-prompt">
          <div class="stack-note">
            <strong>Today’s bucket</strong>
            <p><%= link_to @today_log.display_title, daily_log_path(@today_log) %> is ready for quick-save routing.</p>
          </div>
          <div class="stack-note">
            <strong>Sync awareness</strong>
            <p data-offline-status-target="label">Connection status is tracked here for progressive sync UX.</p>
          </div>
          <div class="stack-note">
            <strong>Install</strong>
            <p>Prompt the user only when the browser signals install support and the workflow has shown value.</p>
            <button class="mini-button" type="button" data-action="install-prompt#prompt">Show install help</button>
          </div>
        </div>
      </aside>
    </section>
</div>
