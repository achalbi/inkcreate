<%= render "shared/workspace_header",
  breadcrumbs: [["Home", dashboard_path], "Capture"],
  eyebrow: "Fast capture",
  title: "Capture a new daily page",
  description: "Take a photo or choose one from the gallery. We'll create today's page, apply the same title logic automatically, and open it in edit mode." %>

<div class="wrapper wrapper-content animated fadeInRight">
  <section class="ibox quick-capture-card" data-controller="quick-capture">
    <div class="ibox-title">
      <h5>Quick capture</h5>
    </div>
    <div class="ibox-content collapse show">
      <div class="quick-capture-body">
        <p class="quick-capture-intro">
          Capture a page and continue editing right away. The first photo creates a new daily page dated
          <strong><%= @entry_date.strftime("%b %-d, %Y") %></strong>.
        </p>

        <%= form_with url: notepad_entries_path, scope: :notepad_entry, html: { multipart: true }, data: { quick_capture_target: "form" } do |form| %>
          <%= hidden_field_tag :after_create, "edit" %>
          <%= form.hidden_field :entry_date, value: @entry_date %>

          <%= form.file_field :photos,
            multiple: true,
            id: "quick-capture-camera-input",
            accept: "image/*",
            capture: "environment",
            class: "quick-capture-input",
            data: { quick_capture_target: "cameraInput", action: "change->quick-capture#submitFromSelection" } %>

          <%= form.file_field :photos,
            multiple: true,
            id: "quick-capture-gallery-input",
            accept: "image/*",
            class: "quick-capture-input",
            data: { quick_capture_target: "galleryInput", action: "change->quick-capture#submitFromSelection" } %>

          <div class="quick-capture-actions">
            <button
              type="button"
              class="quick-capture-action quick-capture-action--camera"
              data-action="quick-capture#openCamera"
              data-quick-capture-target="cameraButton"
            >
              <i class="ti ti-camera" aria-hidden="true"></i>
              <strong>Take photo</strong>
              <span>Open the device camera and save directly into a new daily page.</span>
            </button>

            <button
              type="button"
              class="quick-capture-action quick-capture-action--gallery"
              data-action="quick-capture#openGallery"
              data-quick-capture-target="galleryButton"
            >
              <i class="ti ti-photo-plus" aria-hidden="true"></i>
              <strong>Choose from gallery</strong>
              <span>Pick an existing image and continue editing the page after it is created.</span>
            </button>
          </div>
        <% end %>

        <p class="quick-capture-status text-muted" data-quick-capture-target="status" hidden></p>
      </div>
    </div>
  </section>
</div>
