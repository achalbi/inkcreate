<div class="workspace-page">
    <%= render "shared/workspace_header",
      eyebrow: "Inbox",
      title: "Uncategorized captures waiting for context.",
      description: "Inbox is the staging lane for fresh pages that still need a project, a day, or some richer context." %>

    <section class="dashboard-card workspace-panel">
      <% if @captures.any? %>
        <div class="capture-list">
          <% @captures.each do |capture| %>
            <%= render "shared/capture_card", capture: capture %>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "Inbox is clear", description: "Everything is already organized into projects or daily logs." %>
      <% end %>
    </section>
</div>
