<article class="notebook-list-card">
  <%= link_to notebook_path(notebook), class: "notebook-list-card__body", aria: { label: "Open #{notebook.title}" } do %>
    <div class="notebook-list-card__header">
      <div class="notebook-list-card__main">
        <h6 class="notebook-list-card__title"><%= notebook.title %></h6>
        <p class="notebook-list-card__description"><%= notebook.description.presence || "Add a short description so this notebook is easier to recognize later." %></p>
      </div>

      <div class="notebook-list-card__header-tools">
        <span class="label <%= notebook.status_active? ? "label-primary" : "label-default" %> notebook-list-card__status"><%= notebook.status.humanize %></span>
      </div>
    </div>

    <div class="notebook-list-card__meta">
      <span class="notebook-list-card__meta-item"><strong><%= notebook.chapters.size %></strong> <%= "chapter".pluralize(notebook.chapters.size) %></span>
      <span class="notebook-list-card__meta-item"><strong><%= notebook.pages.size %></strong> <%= "page".pluralize(notebook.pages.size) %></span>
      <span class="notebook-list-card__meta-item">Updated <%= time_ago_in_words(notebook.updated_at) %> ago</span>
    </div>
  <% end %>
</article>
