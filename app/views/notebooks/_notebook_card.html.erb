<div class="panel panel-default">
  <div class="panel-body">
    <div class="row">
      <div class="col-sm-8">
        <h4 class="m-t-none m-b-xs"><%= link_to notebook.title, notebook_path(notebook) %></h4>
        <p class="text-muted m-b-sm"><%= notebook.description.presence || "No description yet." %></p>
        <p class="small text-muted m-b-none">
          <strong><%= notebook.chapters.count %></strong> <%= "chapter".pluralize(notebook.chapters.count) %>
          <span class="m-l-md"><strong><%= notebook.pages.count %></strong> <%= "page".pluralize(notebook.pages.count) %></span>
          <span class="m-l-md">Updated <%= time_ago_in_words(notebook.updated_at) %> ago</span>
        </p>
      </div>
      <div class="col-sm-4">
        <p class="m-b-sm m-t-none">
          <span class="label <%= notebook.status_active? ? "label-primary" : "label-default" %>"><%= notebook.status.humanize %></span>
        </p>
        <p class="m-b-none">
          <%= link_to "Open", notebook_path(notebook), class: "btn btn-primary btn-sm" %>
          <%= link_to "Edit", edit_notebook_path(notebook), class: "btn btn-white btn-sm" %>
          <% if notebook.status_active? %>
            <%= button_to "Archive", archive_notebook_path(notebook),
              method: :patch,
              form: { style: "display: inline-block; margin: 0;", onsubmit: "return confirm('Archive this notebook?');" },
              class: "btn btn-white btn-sm" %>
          <% else %>
            <%= button_to "Restore", unarchive_notebook_path(notebook),
              method: :patch,
              form: { style: "display: inline-block; margin: 0;" },
              class: "btn btn-white btn-sm" %>
          <% end %>
        </p>
      </div>
    </div>
  </div>
</div>
