<article class="notebook-list-card">
  <%= link_to notebook_path(notebook), class: "notebook-list-card__body", aria: { label: "Open #{notebook.title}" } do %>
    <div class="notebook-list-card__content">
      <div class="notebook-list-card__symbol" aria-hidden="true">
        <i class="ti ti-notebook"></i>
      </div>

      <div class="notebook-list-card__main">
        <div class="notebook-list-card__header">
          <div class="notebook-list-card__header-copy">
            <h6 class="notebook-list-card__title"><%= notebook.title %></h6>
            <p class="notebook-list-card__description"><%= notebook.description.presence || "No description yet." %></p>
          </div>
          <span class="label <%= notebook.status_active? ? "label-primary" : "label-default" %> notebook-list-card__status"><%= notebook.status.humanize %></span>
        </div>

        <div class="notebook-list-card__meta">
          <span class="notebook-list-card__meta-item">
            <i class="ti ti-book-2" aria-hidden="true"></i>
            <strong><%= notebook.chapters.size %></strong> <%= "chapter".pluralize(notebook.chapters.size) %>
          </span>
          <span class="notebook-list-card__meta-dot" aria-hidden="true">&middot;</span>
          <span class="notebook-list-card__meta-item">
            <i class="ti ti-file-text" aria-hidden="true"></i>
            <strong><%= notebook.pages.size %></strong> <%= "page".pluralize(notebook.pages.size) %>
          </span>
          <span class="notebook-list-card__meta-dot" aria-hidden="true">&middot;</span>
          <span class="notebook-list-card__meta-item">
            <i class="ti ti-clock-hour-4" aria-hidden="true"></i>
            Updated <%= time_ago_in_words(notebook.updated_at) %> ago
          </span>
        </div>
      </div>
    </div>
  <% end %>
</article>
