<section class="ibox float-e-margins notebook-section-shell">
  <div class="ibox-title notebook-section-title">
    <div class="notebook-section-title-row">
      <div class="notebook-section-heading">
        <h5><%= title %></h5>
        <span class="label <%= badge_class %> notebook-section-badge"><%= badge_text %></span>
      </div>
      <div class="ibox-tools notebook-section-tools">
        <% if all_notebooks.any? %>
          <button
            type="button"
            class="notebook-section-open-button"
            data-bs-toggle="modal"
            data-bs-target="#<%= modal_id %>"
            aria-label="Open <%= title.downcase %> list"
            title="Open list"
          >
            <i class="ti ti-layout-list"></i>
          </button>
        <% end %>
        <%= render "shared/ibox_toggle_button", target_id: content_id %>
      </div>
    </div>
  </div>

  <div id="<%= content_id %>" class="ibox-content collapse show notebook-section-content <%= "notebook-section-list-content" if notebooks.any? %>">
    <% if notebooks.any? %>
      <div class="notebook-list-stack notebook-list-stack--separated">
        <% notebooks.each do |notebook| %>
          <%= render "notebook_card", notebook: notebook %>
        <% end %>
      </div>

      <% if local_assigns.fetch(:show_pagination, true) && total_pages > 1 %>
        <% total_count = local_assigns.fetch(:total_count, notebooks.size) %>
        <% per_page = local_assigns.fetch(:per_page, NotebooksController::NOTEBOOKS_PER_PAGE) %>
        <% first_item_number = ((current_page - 1) * per_page) + 1 %>
        <% last_item_number = [((current_page - 1) * per_page) + notebooks.size, total_count].min %>
        <div class="notebook-section-pagination">
          <div class="notebook-section-pagination__summary">
            <div class="notebook-section-pagination__meta">
              Showing <%= first_item_number %>-<%= last_item_number %> of <%= total_count %>
            </div>
            <div class="notebook-section-pagination__page-pill">
              Page <%= current_page %> of <%= total_pages %>
            </div>
          </div>

          <div class="notebook-section-pagination__actions" role="navigation" aria-label="<%= title %> pagination">
            <% if current_page > 1 %>
              <%= link_to request.query_parameters.merge(page_param => current_page - 1),
                class: "btn btn-white btn-sm notebook-section-pagination__button" do %>
                <i class="ti ti-chevron-left" aria-hidden="true"></i>
                <span>Previous</span>
              <% end %>
            <% else %>
              <span class="btn btn-white btn-sm notebook-section-pagination__button disabled" aria-disabled="true">
                <i class="ti ti-chevron-left" aria-hidden="true"></i>
                <span>Previous</span>
              </span>
            <% end %>

            <% if current_page < total_pages %>
              <%= link_to request.query_parameters.merge(page_param => current_page + 1),
                class: "btn btn-white btn-sm notebook-section-pagination__button" do %>
                <span>Next</span>
                <i class="ti ti-chevron-right" aria-hidden="true"></i>
              <% end %>
            <% else %>
              <span class="btn btn-white btn-sm notebook-section-pagination__button disabled" aria-disabled="true">
                <span>Next</span>
                <i class="ti ti-chevron-right" aria-hidden="true"></i>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <%= render "shared/empty_state", title: empty_title, description: empty_description %>
    <% end %>
  </div>
</section>

<% if all_notebooks.any? %>
  <%= render "section_modal", modal_id:, title:, notebooks: all_notebooks %>
<% end %>
