<!-- <%= render "shared/workspace_header",
  breadcrumbs: [["Home", dashboard_path], "Notebooks"],
  eyebrow: "Notebook",
  title: "Project notebooks",
  description: "Create project spaces, organize them into chapters, and store pages with notes, dates, and photos." %> -->

<div class="wrapper wrapper-content animated fadeInRight" data-controller="live-search" data-live-search-delay-value="220">
  <div class="workspace-index-actions notebook-index-actions">
    <div class="workspace-index-actions__left">
      <div class="workspace-index-controls">
        <div class="btn-group workspace-view-toggle" role="group" aria-label="Notebook scope" data-live-search-target="scope">
          <%= link_to notebooks_path(scope: "current", q: @query.presence),
            class: ["btn btn-sm workspace-view-toggle__button", ("active" if @notebook_scope == "current")].compact.join(" "),
            aria: { current: ("page" if @notebook_scope == "current") },
            title: "Current notebooks" do %>
            <i class="ti ti-notebook" aria-hidden="true"></i>
          <% end %>

          <%= link_to notebooks_path(scope: "archived", q: @query.presence),
            class: ["btn btn-sm workspace-view-toggle__button", ("active" if @notebook_scope == "archived")].compact.join(" "),
            aria: { current: ("page" if @notebook_scope == "archived") },
            title: "Archived notebooks" do %>
            <i class="ti ti-archive" aria-hidden="true"></i>
          <% end %>
        </div>

        <%= form_tag notebooks_path,
          method: :get,
          class: "notepad-gallery-search-form notebook-index-search-form",
          data: { live_search_target: "form", action: "submit->live-search#submitNow" } do %>
          <%= hidden_field_tag :scope, @notebook_scope %>
          <div class="notepad-gallery-search-wrap">
            <i class="ti ti-search notepad-gallery-search-icon" aria-hidden="true"></i>
            <%= search_field_tag :q,
              @query,
              class: "form-control notepad-gallery-search-input notebook-index-search-input",
              placeholder: "Search notebooks, descriptions, or chapter names",
              data: {
                live_search_target: "field",
                action: "input->live-search#queueSubmit search->live-search#queueSubmit compositionstart->live-search#pause compositionend->live-search#resume"
              } %>
          </div>
        <% end %>

        <div data-live-search-target="actions">
          <% if @query.present? %>
            <%= link_to "Clear", notebooks_path(scope: @notebook_scope), class: "btn btn-white btn-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div data-live-search-target="results">
    <% if @notebook_scope == "archived" %>
      <%= render "section",
        title: "Archived notebooks",
        description: "Completed notebooks remain searchable and can be restored any time.",
        badge_class: "label-default",
        badge_text: pluralize(@archived_notebook_count, "archived notebook"),
        content_id: "archived-notebooks-content",
        modal_id: "archived-notebooks-modal",
        notebooks: @archived_notebooks,
        all_notebooks: @archived_notebooks_all,
        page_param: :page,
        current_page: @archived_page,
        total_pages: @archived_total_pages,
        total_count: @archived_notebook_count,
        per_page: NotebooksController::NOTEBOOKS_PER_PAGE,
        show_pagination: true,
        empty_title: (@query.present? ? "No archived notebooks match" : "No archived notebooks"),
        empty_description: (@query.present? ? "Try another search term for notebook titles, descriptions, or chapter names." : "Archive completed notebooks when you want to keep the active list focused.") %>
    <% else %>
      <%= render "section",
        title: "Current notebooks",
        description: "Active notebooks stay first so ongoing work remains visible.",
        badge_class: "label-primary",
        badge_text: pluralize(@active_notebook_count, "active notebook"),
        content_id: "current-notebooks-content",
        modal_id: "current-notebooks-modal",
        notebooks: @active_notebooks,
        all_notebooks: @active_notebooks_all,
        page_param: :page,
        current_page: @active_page,
        total_pages: @active_total_pages,
        total_count: @active_notebook_count,
        per_page: NotebooksController::NOTEBOOKS_PER_PAGE,
        show_pagination: true,
        empty_title: (@query.present? ? "No current notebooks match" : "No active notebooks yet"),
        empty_description: (@query.present? ? "Try another search term for notebook titles, descriptions, or chapter names." : "Create your first notebook to start organizing project work by chapter and page.") %>
    <% end %>
  </div>

  <%= render "shared/workspace_fab", path: new_notebook_path, title: "Create new notebook" %>
</div>
