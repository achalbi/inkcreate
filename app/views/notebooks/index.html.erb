<%= render "shared/workspace_header",
  eyebrow: "Notebook",
  title: "Project notebooks",
  description: "Create project spaces, organize them into chapters, and store pages with notes, dates, and photos.",
  action_label: "New notebook",
  action_path: new_notebook_path %>

<div class="wrapper wrapper-content animated fadeInRight">
  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Current notebooks</h5>
      <div class="ibox-tools">
        <span class="label label-primary"><%= pluralize(@active_notebooks.count, "active notebook") %></span>
      </div>
    </div>
    <div class="ibox-content">
      <p class="text-muted m-b-md">Active notebooks stay first so ongoing work remains visible.</p>
      <% if @active_notebooks.any? %>
        <% @active_notebooks.each do |notebook| %>
          <%= render "notebook_card", notebook: notebook %>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "No active notebooks yet", description: "Create your first notebook to start organizing project work by chapter and page." %>
      <% end %>
    </div>
  </section>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Archived notebooks</h5>
      <div class="ibox-tools">
        <span class="label label-default"><%= pluralize(@archived_notebooks.count, "archived notebook") %></span>
      </div>
    </div>
    <div class="ibox-content">
      <p class="text-muted m-b-md">Completed notebooks remain searchable and can be restored any time.</p>
      <% if @archived_notebooks.any? %>
        <% @archived_notebooks.each do |notebook| %>
          <%= render "notebook_card", notebook: notebook %>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "No archived notebooks", description: "Archive completed notebooks when you want to keep the active list focused." %>
      <% end %>
    </div>
  </section>
</div>
