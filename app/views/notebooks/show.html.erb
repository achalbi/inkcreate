<div class="wrapper wrapper-content animated fadeInRight">
  <nav aria-label="breadcrumb" class="m-b-md">
    <ol class="breadcrumb">
      <li><%= link_to "Home", dashboard_path %></li>
      <li><%= link_to "Notebook", notebooks_path %></li>
      <li class="active"><%= @notebook.title %></li>
    </ol>
  </nav>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Notebook overview</h5>
      <div class="ibox-tools">
        <span class="label <%= @notebook.status_active? ? "label-primary" : "label-default" %>"><%= @notebook.status.humanize %></span>
        <%= link_to edit_notebook_path(@notebook), class: "btn btn-sm btn-icon notebook-overview-edit-button", title: "Edit notebook", aria: { label: "Edit notebook" } do %>
          <i class="ti ti-edit" aria-hidden="true"></i>
        <% end %>
        <%= render "shared/ibox_toggle_button", target_id: dom_id(@notebook, :overview_content) %>
      </div>
    </div>
    <div id="<%= dom_id(@notebook, :overview_content) %>" class="ibox-content collapse show">
      <div class="row">
        <div class="col-sm-12">
          <h2 class="m-t-none"><%= @notebook.title %></h2>
          <p class="text-muted"><%= @notebook.description.presence || "Add a description to make the purpose of this notebook clear to future-you." %></p>
          <p class="m-b-none">
            <span class="label label-default"><%= pluralize(@notebook.chapters.count, "chapter") %></span>
            <span class="label label-default"><%= pluralize(@notebook.pages.count, "page") %></span>
            <span class="label label-default">Created <%= @notebook.created_at.strftime("%b %-d, %Y") %></span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="ibox float-e-margins">
    <div class="ibox-title">
      <h5>Chapters</h5>
      <div class="ibox-tools">
        <%= link_to "Add chapter", new_notebook_chapter_path(@notebook), class: "btn btn-primary btn-sm" %>
        <%= render "shared/ibox_toggle_button", target_id: dom_id(@notebook, :chapters_content) %>
      </div>
    </div>
    <div id="<%= dom_id(@notebook, :chapters_content) %>" class="ibox-content collapse show">
      <p class="text-muted m-b-md">Chapters create the main sections of this notebook.</p>
      <% if @chapters.any? %>
        <div class="notebook-list-stack">
          <% @chapters.each do |chapter| %>
            <%= render "chapters/chapter_card", notebook: @notebook, chapter: chapter %>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No chapters yet", description: "Add the first chapter to start breaking this notebook into clear sections." %>
      <% end %>
    </div>
  </section>

  <% if @deleted_chapters.any? %>
    <section class="ibox float-e-margins">
      <div class="ibox-title">
        <h5>Deleted chapters</h5>
        <div class="ibox-tools">
          <span class="label label-default"><%= pluralize(@deleted_chapters.count, "chapter") %></span>
          <%= render "shared/ibox_toggle_button", target_id: "deleted-chapters-content" %>
        </div>
      </div>
      <div id="deleted-chapters-content" class="ibox-content collapse show">
        <p class="text-muted m-b-md">Chapters with pages are soft deleted here so their notes can be restored later instead of being removed.</p>
        <div class="notebook-list-stack">
          <% @deleted_chapters.each do |chapter| %>
            <%= render "chapters/deleted_chapter_card", notebook: @notebook, chapter: chapter %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</div>
