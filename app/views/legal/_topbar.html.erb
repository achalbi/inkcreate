<%= render "shared/public_topbar",
  menu_id: "legal-menu",
  nav_label: "Legal pages",
  nav_links: [
    { label: "Privacy Policy", path: privacy_policy_path },
    { label: "Terms of Service", path: terms_of_service_path }
  ],
  action_container_class: ("nav-actions-auth" unless user_signed_in?),
  action_links: if user_signed_in?
    [{ label: "Open workspace", path: dashboard_path, class_name: "mini-button mini-button-primary" }]
  else
    [
      { label: "Sign in", path: browser_sign_in_path, class_name: "mini-button" },
      { label: google_only_auth_mode? ? "Start with Google" : "Get started free", path: public_auth_entry_path, class_name: "mini-button mini-button-primary" }
    ]
  end %>
