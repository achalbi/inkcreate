<div class="page-shell">
  <header class="topbar">
    <a class="brand" href="<%= root_path %>">
      <img class="brand-mark" src="/icons/app-icon.svg" alt="Inkcreate icon">
      <span class="brand-copy">
        <strong>Inkcreate</strong>
        <span>Notebook OCR Companion</span>
      </span>
    </a>
  </header>

  <section class="auth-shell auth-shell-single">
    <article class="auth-panel">
      <div class="eyebrow">Create account</div>
      <h1>Start with a notebook-friendly workspace.</h1>
      <p>
        The first account becomes the bootstrap admin. Every account after that
        starts as a standard user, and admins can manage roles later.
      </p>

      <%= form_with model: @user, url: browser_sign_up_path, scope: :user, class: "auth-form" do |form| %>
        <div class="field">
          <%= form.label :email %>
          <%= form.email_field :email, autofocus: true, autocomplete: "email", required: true %>
        </div>

        <div class="auth-form-row">
          <div class="field">
            <%= form.label :password %>
            <%= form.password_field :password, autocomplete: "new-password", required: true %>
          </div>

          <div class="field">
            <%= form.label :password_confirmation %>
            <%= form.password_field :password_confirmation, autocomplete: "new-password", required: true %>
          </div>
        </div>

        <div class="auth-form-row">
          <div class="field">
            <%= form.label :time_zone %>
            <%= form.text_field :time_zone, required: true %>
          </div>

          <div class="field">
            <%= form.label :locale %>
            <%= form.text_field :locale, required: true %>
          </div>
        </div>

        <%= form.submit "Create account", class: "button button-primary" %>
      <% end %>

      <div class="helper-links">
        <a href="<%= browser_sign_in_path %>">Already registered? Sign in</a>
      </div>
    </article>
  </section>

  <%= render "shared/public_footer" %>
</div>
